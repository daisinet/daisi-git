@page "/new"
@inject RepositoryService RepoService
@inject OrganizationService OrgService
@inject AccountSettingsService SettingsService
@inject UserProfileService ProfileService
@inject NavigationManager Nav

<PageTitle>New Repository - Daisi Git</PageTitle>

<div class="row justify-content-center">
    <div class="col-md-8 col-lg-6">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h3 class="mb-0">Create a new repository</h3>
            <a href="/import" class="btn btn-outline-secondary btn-sm">
                <i class="fa-duotone fa-download me-1"></i> Import instead
            </a>
        </div>

        <EditForm Model="model" OnValidSubmit="HandleSubmit" FormName="CreateRepo">
            <div class="mb-3">
                <label class="form-label">Owner</label>
                <select class="form-select" value="@selectedOwner" @onchange="OnOwnerChange">
                    @if (!string.IsNullOrEmpty(userHandle))
                    {
                        <option value="@userHandle">@userHandle (personal)</option>
                    }
                    @foreach (var org in orgs)
                    {
                        <option value="@org.Slug">@org.Slug (@org.Name)</option>
                    }
                </select>
                @if (string.IsNullOrEmpty(userHandle) && orgs.Count == 0)
                {
                    <div class="alert alert-warning mt-2 small">
                        You need to <a href="/settings/profile">set up your personal handle</a> or join an organization before creating a repository.
                    </div>
                }
                else if (string.IsNullOrEmpty(userHandle))
                {
                    <div class="form-text">
                        <a href="/settings/profile">Set up your personal handle</a> to create personal repositories.
                    </div>
                }
            </div>

            <div class="mb-3">
                <label class="form-label">Repository name</label>
                <input type="text" class="form-control @(nameAvailable == false ? "is-invalid" : nameAvailable == true && !string.IsNullOrEmpty(slug) ? "is-valid" : "")"
                       value="@model.Name"
                       @oninput="OnNameInput"
                       @onblur="CheckNameAvailability"
                       placeholder="my-project" />
                @if (nameAvailable == false)
                {
                    <div class="invalid-feedback">Repository <code>@selectedOwner/@slug</code> already exists.</div>
                }
                else if (!string.IsNullOrEmpty(slug))
                {
                    <div class="form-text @(nameAvailable == true ? "text-success" : "")">
                        @if (checkingName)
                        {
                            <span class="spinner-border spinner-border-sm me-1"></span>
                        }
                        Your repository will be available at <code>@selectedOwner/@slug</code>
                    </div>
                }
            </div>

            <div class="mb-3">
                <label class="form-label">Description <span class="text-muted">(optional)</span></label>
                <InputText @bind-Value="model.Description" class="form-control" placeholder="A short description of your project" />
            </div>

            <div class="mb-3">
                <label class="form-label">Visibility</label>
                <InputSelect @bind-Value="model.Visibility" class="form-select">
                    <option value="@GitRepoVisibility.Private">Private</option>
                    <option value="@GitRepoVisibility.Internal">Internal</option>
                    <option value="@GitRepoVisibility.Public">Public</option>
                </InputSelect>
                <div class="form-text">
                    @switch (model.Visibility)
                    {
                        case GitRepoVisibility.Private:
                            <text>Only you can see this repository.</text>
                            break;
                        case GitRepoVisibility.Internal:
                            <text>Anyone in your organization can see this repository.</text>
                            break;
                        case GitRepoVisibility.Public:
                            <text>Anyone can see this repository.</text>
                            break;
                    }
                </div>
            </div>

            <div class="mb-4">
                <label class="form-label">Storage provider</label>
                <InputSelect @bind-Value="model.StorageProvider" class="form-select">
                    <option value="">Account default (@accountDefault)</option>
                    <option value="@StorageProvider.DaisiDrive">Daisi Drive</option>
                    <option value="@StorageProvider.AzureBlob">Azure Blob Storage</option>
                </InputSelect>
                <div class="form-text">
                    Where git objects are stored. Leave as account default unless you have a specific need.
                </div>
            </div>

            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <div class="alert alert-danger">@errorMessage</div>
            }

            <button type="submit" class="btn btn-primary" disabled="@submitting">
                @if (submitting)
                {
                    <span class="spinner-border spinner-border-sm me-1"></span>
                }
                Create repository
            </button>
        </EditForm>
    </div>
</div>

@code {
    [CascadingParameter(Name = "AccountId")] string AccountId { get; set; } = "";
    [CascadingParameter(Name = "UserName")] string userName { get; set; } = "";
    [CascadingParameter(Name = "UserId")] string UserId { get; set; } = "";

    private CreateRepoModel model = new();
    private List<GitOrganization> orgs = [];
    private string selectedOwner = "";
    private string? userHandle;
    private string slug = "";
    private string accountDefault = "Daisi Drive";
    private string? errorMessage;
    private bool submitting;
    private bool? nameAvailable;
    private bool checkingName;

    private string ComputeSlug(string name)
    {
        if (string.IsNullOrWhiteSpace(name)) return "";
        return System.Text.RegularExpressions.Regex.Replace(
            name.ToLowerInvariant().Trim(), @"[^a-z0-9\-]", "-").Trim('-');
    }

    private void OnOwnerChange(ChangeEventArgs e)
    {
        selectedOwner = e.Value?.ToString() ?? "";
        nameAvailable = null;
    }

    private void OnNameInput(ChangeEventArgs e)
    {
        model.Name = e.Value?.ToString() ?? "";
        slug = ComputeSlug(model.Name);
        nameAvailable = null; // Reset until blur check
    }

    private async Task CheckNameAvailability()
    {
        if (string.IsNullOrEmpty(slug) || string.IsNullOrEmpty(selectedOwner))
            return;

        checkingName = true;
        StateHasChanged();
        try
        {
            var existing = await RepoService.GetRepositoryBySlugAsync(selectedOwner, slug);
            nameAvailable = existing == null;
        }
        catch
        {
            nameAvailable = null;
        }
        checkingName = false;
    }

    private bool settingsLoaded;

    protected override async Task OnParametersSetAsync()
    {
        if (!settingsLoaded && !string.IsNullOrEmpty(AccountId))
        {
            settingsLoaded = true;
            try
            {
                var profile = await ProfileService.GetProfileAsync(UserId, AccountId);
                userHandle = profile?.Handle;
                orgs = await OrgService.ListAsync(AccountId);

                // Default to personal handle if available, otherwise first org
                selectedOwner = !string.IsNullOrEmpty(userHandle) ? userHandle
                    : orgs.Count > 0 ? orgs[0].Slug : "";

                var settings = await SettingsService.GetSettingsAsync(AccountId);
                accountDefault = settings.DefaultStorageProvider switch
                {
                    StorageProvider.AzureBlob => "Azure Blob Storage",
                    _ => "Daisi Drive"
                };
            }
            catch { }
        }
    }

    private async Task HandleSubmit()
    {
        if (string.IsNullOrWhiteSpace(selectedOwner))
        {
            errorMessage = "Please select an owner. Set up your personal handle or join an organization.";
            return;
        }
        if (string.IsNullOrWhiteSpace(model.Name) || model.Name.Trim().Length < 5)
        {
            errorMessage = "Repository name must be at least 5 characters.";
            return;
        }

        submitting = true;
        errorMessage = null;

        try
        {
            var ownerName = selectedOwner;
            var ownerId = UserId;

            // If owner is an org, use the org slug as owner name
            var org = orgs.FirstOrDefault(o => o.Slug == selectedOwner);
            if (org != null)
            {
                ownerName = org.Slug;
                ownerId = org.id;
            }

            var repo = await RepoService.CreateRepositoryAsync(
                AccountId, ownerId, ownerName,
                model.Name.Trim(), model.Description?.Trim(), model.Visibility,
                model.StorageProvider);

            Nav.NavigateTo($"/{repo.OwnerName}/{repo.Slug}");
        }
        catch (InvalidOperationException ex)
        {
            errorMessage = ex.Message;
        }
        catch (Exception ex)
        {
            errorMessage = $"Failed to create repository: {ex.Message}";
        }
        finally
        {
            submitting = false;
        }
    }

    private class CreateRepoModel : System.ComponentModel.INotifyPropertyChanged
    {
        private string _name = "";
        private string? _description;
        private GitRepoVisibility _visibility = GitRepoVisibility.Private;

        public string Name
        {
            get => _name;
            set { _name = value; PropertyChanged?.Invoke(this, new(nameof(Name))); }
        }

        public string? Description
        {
            get => _description;
            set { _description = value; PropertyChanged?.Invoke(this, new(nameof(Description))); }
        }

        public GitRepoVisibility Visibility
        {
            get => _visibility;
            set { _visibility = value; PropertyChanged?.Invoke(this, new(nameof(Visibility))); }
        }

        public StorageProvider? StorageProvider { get; set; }

        public event System.ComponentModel.PropertyChangedEventHandler? PropertyChanged;
    }
}
