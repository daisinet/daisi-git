@page "/settings"
@inject NavigationManager Nav

<PageTitle>Daisi Git - Settings</PageTitle>

<h4 class="mb-4">Settings</h4>

<div class="dg-settings-grid">
    <a class="dg-settings-card" href="/settings/account">
        <i class="fa-duotone fa-sliders"></i>
        <h6>Account Settings</h6>
        <p>Default storage provider and account-level preferences.</p>
    </a>
    <a class="dg-settings-card" href="organizations">
        <i class="fa-duotone fa-building"></i>
        <h6>Organizations</h6>
        <p>Create and manage organizations, members, and teams.</p>
    </a>
    <a class="dg-settings-card" href="/settings/profile">
        <i class="fa-duotone fa-user"></i>
        <h6>Personal Profile</h6>
        <p>Set your handle, display name, and bio.</p>
    </a>
</div>
