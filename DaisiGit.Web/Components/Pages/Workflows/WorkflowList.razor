@page "/{Owner}/{RepoSlug}/workflows"
@inject WorkflowService WorkflowService
@inject RepositoryService RepoService
@inject NavigationManager Nav

<PageTitle>Workflows - @Owner/@RepoSlug - Daisi Git</PageTitle>

<RepositoryLayout Owner="@Owner" RepoSlug="@RepoSlug" ActiveTab="workflows">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h5 class="mb-0">Workflows</h5>
        <a href="/@Owner/@RepoSlug/workflows/new" class="btn btn-sm btn-success">
            <i class="fa-duotone fa-plus me-1"></i> New Workflow
        </a>
    </div>

    @if (!string.IsNullOrEmpty(runMessage))
    {
        <div class="alert alert-danger alert-dismissible">@runMessage</div>
    }

    @if (loading)
    {
        <div class="text-center py-4">
            <div class="spinner-border spinner-border-sm text-primary"></div>
        </div>
    }
    else if (workflows.Count == 0)
    {
        <div class="text-center py-5 text-muted">
            <i class="fa-duotone fa-bolt fa-3x mb-3 d-block"></i>
            <h5>No workflows yet</h5>
            <p>Automate your repository with workflows that trigger on push, PR, issue, and more.</p>
            <a href="/@Owner/@RepoSlug/workflows/new" class="btn btn-primary">
                Create your first workflow
            </a>
        </div>
    }
    else
    {
        <div class="list-group">
            @foreach (var wf in workflows)
            {
                <div class="list-group-item">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <div class="fw-semibold">
                                <i class="fa-duotone fa-bolt me-1 @(wf.IsEnabled ? "text-success" : "text-muted")"></i>
                                <a href="/@Owner/@RepoSlug/workflows/edit/@wf.id" class="text-decoration-none">@wf.Name</a>
                                @if (wf.RepositoryId == null)
                                {
                                    <span class="badge bg-info ms-1">Account-wide</span>
                                }
                            </div>
                            <div class="text-muted small mt-1">
                                <span class="badge bg-secondary">@FormatTrigger(wf.TriggerType)</span>
                                <span class="ms-2">@wf.Steps.Count step@(wf.Steps.Count != 1 ? "s" : "")</span>
                                @if (wf.TriggerType == GitTriggerType.Scheduled && wf.TriggerFilters?.ContainsKey("schedule") == true)
                                {
                                    <span class="ms-2 badge bg-light text-dark border">@CronScheduleService.Describe(wf.TriggerFilters["schedule"])</span>
                                    @if (wf.NextScheduledRunUtc != null)
                                    {
                                        <span class="ms-2 text-muted">Next: @wf.NextScheduledRunUtc.Value.ToString("g") UTC</span>
                                    }
                                }
                                else if (wf.TriggerFilters is { Count: > 0 })
                                {
                                    foreach (var (key, value) in wf.TriggerFilters)
                                    {
                                        <span class="ms-2 badge bg-light text-dark border">@key: @value</span>
                                    }
                                }
                            </div>
                        </div>
                        <div class="d-flex align-items-center gap-2">
                            <div class="form-check form-switch mb-0">
                                <input class="form-check-input" type="checkbox" checked="@wf.IsEnabled"
                                       @onchange="() => ToggleEnabled(wf)" />
                            </div>
                            <button class="btn btn-sm btn-outline-success" @onclick="() => RunNow(wf)" title="Run now"
                                    disabled="@(runningWorkflowId == wf.id)">
                                @if (runningWorkflowId == wf.id)
                                {
                                    <span class="spinner-border spinner-border-sm"></span>
                                }
                                else
                                {
                                    <i class="fa-duotone fa-play"></i>
                                }
                            </button>
                            <a href="/@Owner/@RepoSlug/workflows/@wf.id/history" class="btn btn-sm btn-outline-secondary" title="History">
                                <i class="fa-duotone fa-clock-rotate-left"></i>
                            </a>
                            <a href="/@Owner/@RepoSlug/workflows/edit/@wf.id" class="btn btn-sm btn-outline-primary" title="Edit">
                                <i class="fa-duotone fa-pen-to-square"></i>
                            </a>
                            <button class="btn btn-sm btn-outline-danger" @onclick="() => ConfirmDelete(wf)" title="Delete">
                                <i class="fa-duotone fa-trash"></i>
                            </button>
                        </div>
                    </div>
                </div>
            }
        </div>
    }

    @if (runInputsTarget != null)
    {
        <div class="modal d-block" tabindex="-1" style="background: rgba(0,0,0,0.4);" @onclick="() => runInputsTarget = null">
            <div class="modal-dialog modal-dialog-centered" @onclick:stopPropagation="true">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title">Run @runInputsTarget.Name</h5>
                        <button type="button" class="btn-close" @onclick="() => runInputsTarget = null"></button>
                    </div>
                    <div class="modal-body">
                        @foreach (var input in runInputsTarget.Inputs)
                        {
                            var nm = input.Name;
                            <div class="mb-3">
                                <label class="form-label">@(string.IsNullOrEmpty(input.Description) ? input.Name : input.Description)
                                    @if (input.Required) { <span class="text-danger ms-1">*</span> }
                                </label>
                                @if (input.Type == "choice" && input.Choices is { Count: > 0 })
                                {
                                    <select class="form-select form-select-sm" value="@runInputValues.GetValueOrDefault(nm, input.Default ?? "")"
                                            @onchange="e => runInputValues[nm] = e.Value?.ToString() ?? string.Empty">
                                        @if (!input.Required) { <option value="">— None —</option> }
                                        @foreach (var c in input.Choices)
                                        {
                                            <option value="@c">@c</option>
                                        }
                                    </select>
                                }
                                else if (input.Type == "boolean")
                                {
                                    <select class="form-select form-select-sm" value="@runInputValues.GetValueOrDefault(nm, input.Default ?? "false")"
                                            @onchange="e => runInputValues[nm] = e.Value?.ToString() ?? string.Empty">
                                        <option value="true">true</option>
                                        <option value="false">false</option>
                                    </select>
                                }
                                else
                                {
                                    <input type="@(input.Type == "number" ? "number" : "text")" class="form-control form-control-sm"
                                           value="@runInputValues.GetValueOrDefault(nm, input.Default ?? "")"
                                           @oninput="e => runInputValues[nm] = e.Value?.ToString() ?? string.Empty" />
                                }
                            </div>
                        }
                        @if (!string.IsNullOrEmpty(runMessage))
                        {
                            <div class="alert alert-danger small">@runMessage</div>
                        }
                    </div>
                    <div class="modal-footer">
                        <button class="btn btn-sm btn-outline-secondary" @onclick="() => runInputsTarget = null">Cancel</button>
                        <button class="btn btn-sm btn-success" @onclick="RunWithInputsConfirmed" disabled="@(runningWorkflowId != null)">
                            @if (runningWorkflowId != null) { <span class="spinner-border spinner-border-sm me-1"></span> }
                            Run
                        </button>
                    </div>
                </div>
            </div>
        </div>
    }

    @if (deleteTarget != null)
    {
        <div class="modal d-block" tabindex="-1" style="background: rgba(0,0,0,0.4);" @onclick="() => deleteTarget = null">
            <div class="modal-dialog modal-dialog-centered modal-sm" @onclick:stopPropagation="true">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title">Delete workflow</h5>
                        <button type="button" class="btn-close" @onclick="() => deleteTarget = null"></button>
                    </div>
                    <div class="modal-body">
                        Are you sure you want to delete <strong>@deleteTarget.Name</strong>? This cannot be undone.
                    </div>
                    <div class="modal-footer">
                        <button class="btn btn-sm btn-outline-secondary" @onclick="() => deleteTarget = null">Cancel</button>
                        <button class="btn btn-sm btn-danger" @onclick="DeleteConfirmed">Delete</button>
                    </div>
                </div>
            </div>
        </div>
    }
</RepositoryLayout>

@code {
    [Parameter] public string Owner { get; set; } = "";
    [Parameter] public string RepoSlug { get; set; } = "";
    [CascadingParameter(Name = "AccountId")] string AccountId { get; set; } = "";
    [CascadingParameter(Name = "UserId")] string UserId { get; set; } = "";
    [CascadingParameter(Name = "UserName")] string UserName { get; set; } = "";

    private List<GitWorkflow> workflows = [];
    private GitRepository? repo;
    private bool loading = true;
    private string? runningWorkflowId;
    private string? runMessage;
    private GitWorkflow? deleteTarget;

    protected override async Task OnParametersSetAsync()
    {
        loading = true;
        try
        {
            repo = await RepoService.GetRepositoryBySlugAsync(Owner, RepoSlug);
            if (repo != null)
            {
                var all = await WorkflowService.ListAsync(repo.AccountId);
                workflows = all.Where(w => w.RepositoryId == null || w.RepositoryId == repo.id).ToList();
            }
        }
        catch { }
        loading = false;
    }

    private async Task ToggleEnabled(GitWorkflow wf)
    {
        wf.IsEnabled = !wf.IsEnabled;
        await WorkflowService.UpdateAsync(wf);
    }

    private async Task RunNow(GitWorkflow wf)
    {
        if (repo == null) return;
        if (wf.Inputs is { Count: > 0 })
        {
            runInputsTarget = wf;
            runInputValues = new Dictionary<string, string>();
            runMessage = null;
            return;
        }
        await RunWithInputs(wf, null);
    }

    private GitWorkflow? runInputsTarget;
    private Dictionary<string, string> runInputValues = new();

    private async Task RunWithInputsConfirmed()
    {
        var wf = runInputsTarget;
        if (wf == null) return;
        // Drop empty values so server-side defaults / required-checks see "missing", not "blank".
        var supplied = runInputValues
            .Where(kv => !string.IsNullOrEmpty(kv.Value))
            .ToDictionary(kv => kv.Key, kv => kv.Value);
        await RunWithInputs(wf, supplied);
    }

    private async Task RunWithInputs(GitWorkflow wf, Dictionary<string, string>? inputs)
    {
        if (repo == null) return;
        runningWorkflowId = wf.id;
        runMessage = null;
        try
        {
            var execution = await WorkflowService.RunNowAsync(wf, repo, UserId, UserName, inputs: inputs);
            runInputsTarget = null;
            Nav.NavigateTo($"/{Owner}/{RepoSlug}/workflows/{wf.id}/history");
        }
        catch (Exception ex)
        {
            runMessage = ex.Message;
        }
        finally
        {
            runningWorkflowId = null;
        }
    }

    private void ConfirmDelete(GitWorkflow wf) => deleteTarget = wf;

    private async Task DeleteConfirmed()
    {
        if (deleteTarget == null) return;
        await WorkflowService.DeleteAsync(deleteTarget.id, deleteTarget.AccountId);
        workflows.Remove(deleteTarget);
        deleteTarget = null;
    }

    private static string FormatTrigger(GitTriggerType trigger) => trigger switch
    {
        GitTriggerType.PushToRef => "Push",
        GitTriggerType.BranchCreated => "Branch Created",
        GitTriggerType.BranchDeleted => "Branch Deleted",
        GitTriggerType.TagCreated => "Tag Created",
        GitTriggerType.TagDeleted => "Tag Deleted",
        GitTriggerType.PullRequestCreated => "PR Opened",
        GitTriggerType.PullRequestUpdated => "PR Updated",
        GitTriggerType.PullRequestClosed => "PR Closed",
        GitTriggerType.PullRequestMerged => "PR Merged",
        GitTriggerType.IssueCreated => "Issue Opened",
        GitTriggerType.IssueClosed => "Issue Closed",
        GitTriggerType.IssueReopened => "Issue Reopened",
        GitTriggerType.CommentCreated => "Comment",
        GitTriggerType.ReviewSubmitted => "Review",
        GitTriggerType.RepositoryForked => "Fork",
        GitTriggerType.Scheduled => "Scheduled",
        _ => trigger.ToString()
    };
}
