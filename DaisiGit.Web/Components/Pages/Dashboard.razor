@page "/"
@inject RepositoryService RepoService
@inject OrganizationService OrgService
@inject WorkflowService WorkflowService
@inject BrowseService BrowseService
@using DaisiGit.Core.Git

<PageTitle>Dashboard - Daisi Git</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="mb-0">Dashboard</h4>
    <a href="/new" class="btn btn-primary btn-sm">
        <i class="fa-duotone fa-plus me-1"></i> New Repository
    </a>
</div>

@if (loading)
{
    <div class="text-center py-5">
        <div class="spinner-border text-primary"></div>
    </div>
}
else
{
    <!-- Summary cards -->
    <div class="row g-3 mb-4">
        <div class="col-md-3">
            <div class="card text-center">
                <div class="card-body py-3">
                    <div class="text-muted small">Repositories</div>
                    <div class="fs-3 fw-bold">@repositories.Count</div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-center">
                <div class="card-body py-3">
                    <div class="text-muted small">Organizations</div>
                    <div class="fs-3 fw-bold">@orgs.Count</div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-center">
                <div class="card-body py-3">
                    <div class="text-muted small">Team Members</div>
                    <div class="fs-3 fw-bold">@totalMembers</div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-center">
                <div class="card-body py-3">
                    <div class="text-muted small">Commits (30d)</div>
                    <div class="fs-3 fw-bold">@dailyCounts.Sum()</div>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <!-- Commit density chart -->
        <div class="col-md-8">
            <div class="card">
                <div class="card-header">
                    <i class="fa-duotone fa-chart-bar me-1"></i> Commits (last 30 days)
                </div>
                <div class="card-body">
                    @if (dailyCounts.Length > 0 && dailyCounts.Any(c => c > 0))
                    {
                        <svg viewBox="0 0 600 120" class="w-100" style="height: 120px;">
                            @{ var maxCount = Math.Max(1, dailyCounts.Max()); }
                            @for (var i = 0; i < dailyCounts.Length; i++)
                            {
                                var barHeight = dailyCounts[i] > 0 ? Math.Max(4, (int)(100.0 * dailyCounts[i] / maxCount)) : 0;
                                var x = i * 20;
                                var y = 110 - barHeight;
                                <rect x="@x" y="@y" width="16" height="@barHeight" rx="2"
                                      fill="var(--bs-primary)" opacity="0.7">
                                    <title>@chartDates[i].ToString("MMM d"): @dailyCounts[i] commit(s)</title>
                                </rect>
                            }
                            <!-- X-axis labels (rendered as foreignObject to avoid Razor <text> conflict) -->
                            @for (var i = 0; i < dailyCounts.Length; i += 7)
                            {
                                <foreignObject x="@(i * 20 - 5)" y="108" width="40" height="14">
                                    <span style="font-size:9px;color:var(--bs-secondary)">@chartDates[i].ToString("M/d")</span>
                                </foreignObject>
                            }
                        </svg>
                    }
                    else
                    {
                        <div class="text-center text-muted py-4">No commit activity in the last 30 days</div>
                    }
                </div>
            </div>

            <!-- Recent commits across all repos -->
            <div class="card mt-3">
                <div class="card-header">
                    <i class="fa-duotone fa-code-commit me-1"></i> Recent Commits
                </div>
                <div class="card-body p-0">
                    @if (recentCommits.Count == 0)
                    {
                        <div class="text-center text-muted py-4">No recent commits</div>
                    }
                    else
                    {
                        <div class="list-group list-group-flush">
                            @foreach (var c in recentCommits)
                            {
                                <a href="/@c.Owner/@c.RepoSlug/commit/@c.Sha" class="list-group-item list-group-item-action py-2 text-decoration-none">
                                    <div class="d-flex align-items-center gap-2">
                                        <code class="text-muted small" style="min-width:5em;">@c.ShortSha</code>
                                        <div class="flex-grow-1">
                                            <div class="small fw-semibold">@c.MessageFirstLine</div>
                                            <div class="text-muted small">
                                                @c.Owner/@c.RepoSlug · @c.AuthorName
                                            </div>
                                        </div>
                                        <span class="text-muted small ms-auto">@FormatRelative(c.AuthorDateUtc)</span>
                                    </div>
                                </a>
                            }
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- Sidebar: repos + team -->
        <div class="col-md-4">
            <!-- Repositories -->
            <div class="card mb-3">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <span><i class="fa-duotone fa-code-branch me-1"></i> Repositories</span>
                    <a href="/repositories" class="btn btn-sm btn-link p-0">View all</a>
                </div>
                <div class="list-group list-group-flush">
                    @foreach (var repo in repositories.Take(8))
                    {
                        <a href="/@repo.OwnerName/@repo.Slug" class="list-group-item list-group-item-action py-2">
                            <div class="d-flex justify-content-between align-items-center">
                                <span class="small fw-semibold d-flex align-items-center gap-1">
                                    <OwnerAvatar OwnerName="@repo.OwnerName" Size="18" />
                                    @repo.OwnerName/@repo.Name
                                </span>
                                <span class="badge bg-@(repo.Visibility == GitRepoVisibility.Public ? "success" : "secondary") small">
                                    @repo.Visibility
                                </span>
                            </div>
                        </a>
                    }
                    @if (repositories.Count > 8)
                    {
                        <a href="/repositories" class="list-group-item list-group-item-action text-center text-muted small py-2">
                            +@(repositories.Count - 8) more
                        </a>
                    }
                </div>
            </div>

            <!-- Team members -->
            <div class="card">
                <div class="card-header">
                    <i class="fa-duotone fa-users me-1"></i> Team Members
                </div>
                <div class="list-group list-group-flush">
                    @if (members.Count == 0)
                    {
                        <div class="list-group-item text-muted small py-3 text-center">
                            No organization members yet.
                            <a href="/organizations" class="d-block mt-1">Create an organization</a>
                        </div>
                    }
                    else
                    {
                        @foreach (var member in members.Take(12))
                        {
                            <div class="list-group-item py-2">
                                <div class="d-flex justify-content-between align-items-center">
                                    <span class="small">
                                        <i class="fa-duotone fa-user me-1 text-muted"></i>
                                        @member.UserName
                                    </span>
                                    <span class="badge text-secondary border small">@member.Role</span>
                                </div>
                            </div>
                        }
                    }
                </div>
            </div>
        </div>
    </div>
}

@code {
    [CascadingParameter(Name = "AccountId")] string AccountId { get; set; } = "";
    [CascadingParameter(Name = "UserId")] string UserId { get; set; } = "";

    private List<GitRepository> repositories = [];
    private List<GitOrganization> orgs = [];
    private List<OrgMember> members = [];
    private List<RecentCommit> recentCommits = [];
    private int totalMembers;
    private int[] dailyCounts = [];
    private DateTime[] chartDates = [];
    private bool loading = true;

    private record RecentCommit(string Owner, string RepoSlug, string Sha, string ShortSha,
        string MessageFirstLine, string AuthorName, DateTime AuthorDateUtc);

    protected override async Task OnParametersSetAsync()
    {
        if (string.IsNullOrEmpty(AccountId)) return;

        loading = true;
        try
        {
            repositories = await RepoService.GetRepositoriesAsync(AccountId);
            orgs = await OrgService.ListAsync(AccountId);

            // Collect members across all orgs
            members = [];
            foreach (var org in orgs)
            {
                var orgMembers = await OrgService.GetMembersAsync(org.id);
                foreach (var m in orgMembers)
                {
                    if (!members.Any(x => x.UserId == m.UserId))
                        members.Add(m);
                }
            }
            totalMembers = members.Count;

            // 30-day commit chart from per-repo rollups (no log walk required).
            BuildActivityChart();

            // Recent commits: walk the default branch of each repo that had a commit in the
            // window, take a few most recent each, then merge across repos. Bounded by
            // taking only repos that had any activity in the window.
            await BuildRecentCommitsAsync();
        }
        catch { }
        loading = false;
    }

    private void BuildActivityChart()
    {
        var today = DateTime.UtcNow.Date;
        var days = 30;
        chartDates = Enumerable.Range(0, days).Select(i => today.AddDays(-days + 1 + i)).ToArray();
        dailyCounts = new int[days];

        foreach (var repo in repositories)
        {
            if (repo.CommitCountsByDate is not { Count: > 0 } map) continue;
            foreach (var (dateKey, count) in map)
            {
                if (!DateTime.TryParse(dateKey, out var d)) continue;
                var idx = (d.Date - chartDates[0]).Days;
                if (idx >= 0 && idx < days)
                    dailyCounts[idx] += count;
            }
        }
    }

    private async Task BuildRecentCommitsAsync()
    {
        var cutoff = DateTime.UtcNow.AddDays(-30);
        var recent = repositories
            .Where(r => r.CommitCountsByDate is { Count: > 0 } &&
                        r.CommitCountsByDate.Any(kv =>
                            DateTime.TryParse(kv.Key, out var d) && d >= cutoff))
            .OrderByDescending(r => r.UpdatedUtc ?? r.CreatedUtc)
            .Take(15)
            .ToList();

        var collected = new List<RecentCommit>();
        foreach (var repo in recent)
        {
            try
            {
                var headSha = await BrowseService.ResolveRefAsync(repo.id, repo.DefaultBranch);
                if (headSha == null) continue;
                var log = await BrowseService.GetCommitLogAsync(repo.id, headSha, 5);
                foreach (var c in log)
                {
                    collected.Add(new RecentCommit(
                        repo.OwnerName, repo.Slug,
                        c.Sha, c.ShortSha, c.MessageFirstLine,
                        c.AuthorName, c.AuthorDate.UtcDateTime));
                }
            }
            catch { }
        }

        recentCommits = collected
            .OrderByDescending(c => c.AuthorDateUtc)
            .Take(15)
            .ToList();
    }

    private static string EventColor(GitTriggerType t) => t switch
    {
        GitTriggerType.PushToRef or GitTriggerType.BranchCreated => "primary",
        GitTriggerType.PullRequestCreated => "info",
        GitTriggerType.PullRequestMerged => "success",
        GitTriggerType.PullRequestClosed => "secondary",
        GitTriggerType.IssueCreated => "warning",
        GitTriggerType.IssueClosed => "secondary",
        GitTriggerType.CommentCreated => "light",
        GitTriggerType.ReviewSubmitted => "info",
        _ => "secondary"
    };

    private static string EventIcon(GitTriggerType t) => t switch
    {
        GitTriggerType.PushToRef => "↑",
        GitTriggerType.BranchCreated => "+",
        GitTriggerType.BranchDeleted => "−",
        GitTriggerType.PullRequestCreated => "PR",
        GitTriggerType.PullRequestMerged => "✓",
        GitTriggerType.PullRequestClosed => "×",
        GitTriggerType.IssueCreated => "!",
        GitTriggerType.IssueClosed => "✓",
        GitTriggerType.CommentCreated => "💬",
        GitTriggerType.ReviewSubmitted => "👁",
        GitTriggerType.RepositoryForked => "⑂",
        _ => "•"
    };

    private static string EventVerb(GitTriggerType t) => t switch
    {
        GitTriggerType.PushToRef => "pushed to",
        GitTriggerType.BranchCreated => "created branch",
        GitTriggerType.BranchDeleted => "deleted branch",
        GitTriggerType.PullRequestCreated => "opened PR",
        GitTriggerType.PullRequestMerged => "merged PR",
        GitTriggerType.PullRequestClosed => "closed PR",
        GitTriggerType.IssueCreated => "opened issue",
        GitTriggerType.IssueClosed => "closed issue",
        GitTriggerType.IssueReopened => "reopened issue",
        GitTriggerType.CommentCreated => "commented on",
        GitTriggerType.ReviewSubmitted => "reviewed",
        GitTriggerType.RepositoryForked => "forked",
        _ => t.ToString()
    };

    private static string FormatRelative(DateTime utc)
    {
        var diff = DateTime.UtcNow - utc;
        if (diff.TotalMinutes < 1) return "just now";
        if (diff.TotalMinutes < 60) return $"{(int)diff.TotalMinutes}m ago";
        if (diff.TotalHours < 24) return $"{(int)diff.TotalHours}h ago";
        if (diff.TotalDays < 7) return $"{(int)diff.TotalDays}d ago";
        return utc.ToString("MMM d");
    }
}
