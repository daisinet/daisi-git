@page "/{Slug}/settings"
@page "/{Slug}/settings/{SettingsTab}"
@page "/org/{Slug}/settings"
@inject OrganizationService OrgService
@inject SecretService SecretService
@inject RepoGroupService RepoGroupService
@inject GitHubBulkImportService GitHubImporter
@inject NavigationManager Navigation
@implements IDisposable
@using DaisiGit.Core.Enums

<PageTitle>Settings - @(org?.Name ?? "Organization") - Daisi Git</PageTitle>

@if (org != null)
{
    <h4 class="mb-3">
        <a href="/@Slug" class="text-decoration-none text-muted">@org.Name</a>
        <span class="text-muted">/</span> Settings
    </h4>

    <div class="row">
        <!-- Vertical tabs -->
        <div class="col-md-3">
            <div class="nav flex-column nav-pills">
                <a class="nav-link @(activeTab == "general" ? "active" : "")"
                   href="/@Slug/settings/general">
                    <i class="fa-duotone fa-sliders me-1"></i> General
                </a>
                <a class="nav-link @(activeTab == "secrets" ? "active" : "")"
                   href="/@Slug/settings/secrets">
                    <i class="fa-duotone fa-key me-1"></i> Secrets
                </a>
                <a class="nav-link @(activeTab == "vars" ? "active" : "")"
                   href="/@Slug/settings/vars">
                    <i class="fa-duotone fa-tag me-1"></i> Vars
                </a>
                <a class="nav-link @(activeTab == "groups" ? "active" : "")"
                   href="/@Slug/settings/groups">
                    <i class="fa-duotone fa-folder-tree me-1"></i> Repo Groups
                </a>
                <a class="nav-link @(activeTab == "import" ? "active" : "")"
                   href="/@Slug/settings/import">
                    <i class="fa-brands fa-github me-1"></i> Import from GitHub
                </a>
            </div>
        </div>

        <!-- Tab content -->
        <div class="col-md-9">
            @if (activeTab == "general")
            {
                <h5 class="mb-3">General</h5>
                <div class="card" style="max-width: 600px;">
                    <div class="card-body">
                        <div class="mb-4">
                            <label class="form-label fw-semibold">Avatar</label>
                            <AvatarUpload EntityType="org" EntityId="@(org?.id ?? "")" CurrentUrl="@orgAvatarUrl"
                                          OnAvatarChanged="OnOrgAvatarChanged" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-semibold">Organization name</label>
                            <input type="text" class="form-control" @bind="name" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-semibold">URL handle</label>
                            <div class="input-group">
                                <span class="input-group-text text-muted">/</span>
                                <input type="text" class="form-control" @bind="handle" />
                            </div>
                            <div class="form-text">Changing this will update all URLs. Must be unique.</div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-semibold">Description</label>
                            <textarea class="form-control" rows="3" @bind="description"></textarea>
                        </div>

                        @if (!string.IsNullOrEmpty(error))
                        {
                            <div class="alert alert-danger">@error</div>
                        }
                        @if (saved)
                        {
                            <div class="alert alert-success">Settings saved.</div>
                        }

                        <button class="btn btn-primary" @onclick="Save" disabled="@saving">
                            @if (saving) { <span class="spinner-border spinner-border-sm me-1"></span> }
                            Save Changes
                        </button>
                    </div>
                </div>
            }
            else if (activeTab == "groups")
            {
                <h5 class="mb-3">Repo Groups</h5>
                <p class="text-muted small">
                    Sections shown on the org profile under <strong>Repositories</strong>.
                    Assign repos to a group from each repo's <em>Settings → General</em>.
                </p>

                <div class="card mb-3" style="max-width: 700px;">
                    <div class="card-body">
                        <div class="row g-2 align-items-end">
                            <div class="col-md-4">
                                <label class="form-label small mb-1">Name</label>
                                <input type="text" class="form-control form-control-sm" @bind="newGroupName" placeholder="Backend" />
                            </div>
                            <div class="col-md-7">
                                <label class="form-label small mb-1">Description (optional)</label>
                                <input type="text" class="form-control form-control-sm" @bind="newGroupDescription" placeholder="Services, libraries, ..." />
                            </div>
                            <div class="col-md-1 d-grid">
                                <button class="btn btn-sm btn-success" @onclick="AddGroup" disabled="@addingGroup">
                                    @if (addingGroup) { <span class="spinner-border spinner-border-sm"></span> } else { <text>Add</text> }
                                </button>
                            </div>
                        </div>
                        @if (!string.IsNullOrEmpty(groupError))
                        {
                            <div class="text-danger small mt-2">@groupError</div>
                        }
                    </div>
                </div>

                @if (groups.Count == 0)
                {
                    <div class="text-muted small">No groups yet.</div>
                }
                else
                {
                    <div class="card" style="max-width: 700px;">
                        <ul class="list-group list-group-flush">
                            @foreach (var g in groups)
                            {
                                var gid = g.id;
                                <li class="list-group-item">
                                    @if (editingGroupId == gid)
                                    {
                                        <div class="row g-2 align-items-center">
                                            <div class="col-md-4">
                                                <input type="text" class="form-control form-control-sm" @bind="editGroupName" />
                                            </div>
                                            <div class="col-md-5">
                                                <input type="text" class="form-control form-control-sm" @bind="editGroupDescription" />
                                            </div>
                                            <div class="col-md-2">
                                                <input type="number" class="form-control form-control-sm" @bind="editGroupSortOrder" title="Sort order" />
                                            </div>
                                            <div class="col-md-1 d-flex gap-1">
                                                <button class="btn btn-sm btn-primary" @onclick="() => SaveGroup(gid)" title="Save"><i class="fa-solid fa-check"></i></button>
                                                <button class="btn btn-sm btn-outline-secondary" @onclick="CancelEditGroup" title="Cancel"><i class="fa-solid fa-xmark"></i></button>
                                            </div>
                                        </div>
                                    }
                                    else
                                    {
                                        <div class="d-flex justify-content-between align-items-center">
                                            <div>
                                                <strong>@g.Name</strong>
                                                <span class="text-muted small ms-2">order @g.SortOrder</span>
                                                @if (!string.IsNullOrEmpty(g.Description))
                                                {
                                                    <div class="text-muted small">@g.Description</div>
                                                }
                                            </div>
                                            <div class="d-flex gap-1">
                                                <button class="btn btn-sm btn-outline-secondary" @onclick="() => StartEditGroup(g)" title="Edit"><i class="fa-solid fa-pen"></i></button>
                                                <button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteGroup(gid)" title="Delete"><i class="fa-solid fa-trash"></i></button>
                                            </div>
                                        </div>
                                    }
                                </li>
                            }
                        </ul>
                    </div>
                }
            }
            else if (activeTab == "vars")
            {
                <h5 class="mb-3">Variables</h5>
                <p class="text-muted small">
                    Non-secret config values exposed to workflows as <code>{{vars.NAME}}</code>.
                    Repo-level vars override these when set.
                </p>
                <div class="card mb-3" style="max-width: 700px;">
                    <div class="card-body">
                        <div class="row g-2 align-items-end">
                            <div class="col-md-4">
                                <label class="form-label small mb-1">Name</label>
                                <input type="text" class="form-control form-control-sm" @bind="newVarName"
                                       placeholder="DAISI_CRM_DOMAIN" style="text-transform: uppercase;" />
                            </div>
                            <div class="col-md-7">
                                <label class="form-label small mb-1">Value</label>
                                <input type="text" class="form-control form-control-sm" @bind="newVarValue" />
                            </div>
                            <div class="col-md-1 d-grid">
                                <button class="btn btn-sm btn-success" @onclick="AddVar">Add</button>
                            </div>
                        </div>
                        @if (!string.IsNullOrEmpty(varError))
                        {
                            <div class="text-danger small mt-2">@varError</div>
                        }
                    </div>
                </div>

                @if (orgVars.Count > 0)
                {
                    <div class="card" style="max-width: 700px;">
                        <ul class="list-group list-group-flush">
                            @foreach (var (k, v) in orgVars)
                            {
                                var key = k;
                                <li class="list-group-item d-flex justify-content-between align-items-center">
                                    <div><code class="me-2">@key</code><span class="text-muted">@v</span></div>
                                    <button class="btn btn-sm btn-outline-danger" @onclick="() => RemoveVar(key)"><i class="fa-solid fa-xmark"></i></button>
                                </li>
                            }
                        </ul>
                    </div>
                }
                else
                {
                    <div class="text-muted small">No variables yet.</div>
                }
            }
            else if (activeTab == "import")
            {
                <h5 class="mb-3">Import from GitHub</h5>
                <p class="text-muted small">
                    Pulls every repo from a GitHub organization into <strong>@org.Name</strong>.
                    Existing repos with the same name are skipped.
                </p>

                <div class="card mb-3" style="max-width: 700px;">
                    <div class="card-body">
                        <div class="mb-3">
                            <label class="form-label small">GitHub organization</label>
                            <input type="text" class="form-control form-control-sm" @bind="ghOrg" placeholder="daisinet" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label small">Personal access token <span class="text-muted">(optional, required for private repos)</span></label>
                            <input type="password" class="form-control form-control-sm" @bind="ghToken" placeholder="ghp_..." />
                            <div class="form-text">Stored in memory for the duration of this import only — never persisted.</div>
                        </div>
                        <div class="form-check form-switch mb-3">
                            <input class="form-check-input" type="checkbox" id="ghPrivate" @bind="ghIncludePrivate" />
                            <label class="form-check-label small" for="ghPrivate">Include private repos</label>
                        </div>
                        <div class="row g-2">
                            <div class="col-md-6">
                                <label class="form-label small">Visibility for public source repos</label>
                                <select class="form-select form-select-sm" @bind="ghPublicVisibility">
                                    <option value="@GitRepoVisibility.Public">Public</option>
                                    <option value="@GitRepoVisibility.Internal">Internal</option>
                                    <option value="@GitRepoVisibility.Private">Private</option>
                                </select>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label small">Visibility for private source repos</label>
                                <select class="form-select form-select-sm" @bind="ghPrivateVisibility">
                                    <option value="@GitRepoVisibility.Private">Private</option>
                                    <option value="@GitRepoVisibility.Internal">Internal</option>
                                    <option value="@GitRepoVisibility.Public">Public</option>
                                </select>
                            </div>
                        </div>
                        @if (!string.IsNullOrEmpty(importError))
                        {
                            <div class="alert alert-danger small mt-3 mb-0">@importError</div>
                        }
                        <button class="btn btn-primary mt-3" @onclick="StartImport" disabled="@startingImport">
                            @if (startingImport) { <span class="spinner-border spinner-border-sm me-1"></span> }
                            <i class="fa-brands fa-github me-1"></i> Start Import
                        </button>
                    </div>
                </div>

                @if (importJob != null)
                {
                    <div class="card" style="max-width: 800px;">
                        <div class="card-header py-2 d-flex justify-content-between align-items-center">
                            <span class="fw-semibold">
                                @if (importJob.IsComplete)
                                {
                                    <i class="fa-solid fa-check text-success me-1"></i> <text>Done.</text>
                                }
                                else
                                {
                                    <span class="spinner-border spinner-border-sm me-1"></span>
                                    <text>Importing...</text>
                                }
                                <span class="ms-1 text-muted small">@importJob.CompletedCount / @importJob.Items.Count</span>
                            </span>
                            <span class="text-muted small">@importJob.ImportedCount imported, @importJob.FailedCount failed</span>
                        </div>
                        <ul class="list-group list-group-flush" style="max-height: 400px; overflow-y: auto;">
                            @foreach (var it in importJob.Items)
                            {
                                <li class="list-group-item py-2">
                                    <div class="d-flex justify-content-between align-items-center">
                                        <div>
                                            @StatusIcon(it.Status)
                                            <strong class="ms-1">@it.Name</strong>
                                            @if (it.IsPrivate)
                                            {
                                                <i class="fa-solid fa-lock text-muted ms-1" style="font-size:0.75rem;"></i>
                                            }
                                            @if (!string.IsNullOrEmpty(it.LastMessage) && it.Status == "InProgress")
                                            {
                                                <span class="text-muted small ms-2">— @it.LastMessage</span>
                                            }
                                            @if (!string.IsNullOrEmpty(it.Error))
                                            {
                                                <div class="text-danger small">@it.Error</div>
                                            }
                                        </div>
                                        @if (it.Status == "Imported" && !string.IsNullOrEmpty(it.DaisiRepoSlug))
                                        {
                                            <a href="/@org.Slug/@it.DaisiRepoSlug" class="btn btn-sm btn-outline-secondary">View</a>
                                        }
                                    </div>
                                </li>
                            }
                        </ul>
                    </div>
                }
            }
            else if (activeTab == "secrets")
            {
                <h5 class="mb-3">Organization Secrets</h5>
                <p class="text-muted small">Secrets set here are inherited by all repositories in this organization. Repo-level secrets with the same name take priority.</p>

                <div class="card" style="max-width: 700px;">
                    <div class="card-body">
                        <div class="d-flex gap-2 mb-3">
                            <input type="text" class="form-control form-control-sm" @bind="newOrgSecretName"
                                   placeholder="SECRET_NAME" style="max-width: 200px; text-transform: uppercase;" />
                            <input type="password" class="form-control form-control-sm" @bind="newOrgSecretValue"
                                   placeholder="Value" />
                            <button type="button" class="btn btn-sm btn-success text-nowrap" @onclick="AddOrgSecret"
                                    disabled="@addingOrgSecret">
                                @if (addingOrgSecret) { <span class="spinner-border spinner-border-sm me-1"></span> }
                                Add Secret
                            </button>
                        </div>

                        @if (!string.IsNullOrEmpty(orgSecretError))
                        {
                            <div class="alert alert-danger small py-2">@orgSecretError</div>
                        }
                        @if (orgSecretSaved)
                        {
                            <div class="alert alert-success small py-2">Secret saved.</div>
                        }

                        @if (orgSecretNames.Count > 0)
                        {
                            <table class="table table-sm mb-0">
                                <thead><tr><th>Name</th><th>Value</th><th></th></tr></thead>
                                <tbody>
                                    @foreach (var sn in orgSecretNames)
                                    {
                                        var n = sn;
                                        <tr>
                                            <td><code>@n</code></td>
                                            <td class="text-muted">********</td>
                                            <td>
                                                <button class="btn btn-sm btn-outline-danger" @onclick="() => RemoveOrgSecret(n)">
                                                    <i class="fa-solid fa-xmark"></i>
                                                </button>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        }
                        else
                        {
                            <div class="text-muted small">No organization secrets configured.</div>
                        }
                    </div>
                </div>
            }
        </div>
    </div>
}
else if (!loading)
{
    <div class="text-center py-4 text-muted">Organization not found.</div>
}

@code {
    [Parameter] public string Slug { get; set; } = "";
    [Parameter] public string? SettingsTab { get; set; }

    private string activeTab => SettingsTab?.ToLowerInvariant() switch
    {
        "secrets" => "secrets",
        "groups" => "groups",
        "import" => "import",
        "vars" => "vars",
        _ => "general"
    };

    private GitOrganization? org;
    private string name = "";
    private string handle = "";
    private string? description;
    private string? orgAvatarUrl;
    private string? error;
    private bool loading = true;
    private bool saving;
    private bool saved;

    // GitHub bulk import
    private string ghOrg = "";
    private string ghToken = "";
    private bool ghIncludePrivate;
    private GitRepoVisibility ghPublicVisibility = GitRepoVisibility.Public;
    private GitRepoVisibility ghPrivateVisibility = GitRepoVisibility.Private;
    private bool startingImport;
    private string? importError;
    private GitHubImportJob? importJob;
    private System.Threading.Timer? importPollTimer;

    // Vars
    private Dictionary<string, string> orgVars = new();
    private string newVarName = "";
    private string newVarValue = "";
    private string? varError;

    // Repo groups
    private List<RepoGroup> groups = [];
    private string newGroupName = "";
    private string? newGroupDescription;
    private bool addingGroup;
    private string? groupError;
    private string? editingGroupId;
    private string editGroupName = "";
    private string? editGroupDescription;
    private int editGroupSortOrder;

    // Org secrets
    private List<string> orgSecretNames = [];
    private string newOrgSecretName = "";
    private string newOrgSecretValue = "";
    private bool addingOrgSecret;
    private string? orgSecretError;
    private bool orgSecretSaved;

    protected override async Task OnParametersSetAsync()
    {
        loading = true;
        try
        {
            org = await OrgService.GetBySlugAsync(Slug);
            if (org != null)
            {
                name = org.Name;
                handle = org.Slug;
                description = org.Description;
                orgAvatarUrl = org.AvatarUrl;
                await LoadOrgSecrets();
                await LoadGroups();
                orgVars = new(org.Vars ?? new());
            }
        }
        catch { }
        loading = false;
    }

    private async Task LoadGroups()
    {
        if (org != null)
            try { groups = await RepoGroupService.ListAsync(org.id); } catch { }
    }

    private async Task AddGroup()
    {
        if (org == null || string.IsNullOrWhiteSpace(newGroupName))
        {
            groupError = "Name is required.";
            return;
        }
        addingGroup = true;
        groupError = null;
        try
        {
            await RepoGroupService.CreateAsync(org.id, org.AccountId, newGroupName.Trim(), newGroupDescription?.Trim());
            newGroupName = "";
            newGroupDescription = null;
            await LoadGroups();
        }
        catch (Exception ex) { groupError = ex.Message; }
        addingGroup = false;
    }

    private void StartEditGroup(RepoGroup g)
    {
        editingGroupId = g.id;
        editGroupName = g.Name;
        editGroupDescription = g.Description;
        editGroupSortOrder = g.SortOrder;
    }

    private void CancelEditGroup() => editingGroupId = null;

    private async Task SaveGroup(string id)
    {
        if (org == null) return;
        try
        {
            await RepoGroupService.UpdateAsync(id, org.id, editGroupName, editGroupDescription, editGroupSortOrder);
            editingGroupId = null;
            await LoadGroups();
        }
        catch (Exception ex) { groupError = ex.Message; }
    }

    private async Task AddVar()
    {
        if (org == null) return;
        varError = null;
        var name = (newVarName ?? "").Trim();
        if (!System.Text.RegularExpressions.Regex.IsMatch(name, @"^[A-Za-z_][A-Za-z0-9_]*$"))
        {
            varError = "Name must match ENV-style identifier ([A-Za-z_][A-Za-z0-9_]*).";
            return;
        }
        orgVars[name] = newVarValue ?? "";
        newVarName = "";
        newVarValue = "";
        await SaveVars();
    }

    private async Task RemoveVar(string key)
    {
        if (org == null) return;
        orgVars.Remove(key);
        await SaveVars();
    }

    private async Task SaveVars()
    {
        if (org == null) return;
        try
        {
            org.Vars = new(orgVars);
            await OrgService.UpdateAsync(org);
        }
        catch (Exception ex) { varError = ex.Message; }
    }

    private async Task DeleteGroup(string id)
    {
        if (org == null) return;
        try
        {
            await RepoGroupService.DeleteAsync(id, org.id);
            await LoadGroups();
        }
        catch (Exception ex) { groupError = ex.Message; }
    }

    private async Task Save()
    {
        error = null;
        saved = false;
        if (org == null || string.IsNullOrWhiteSpace(name)) { error = "Name is required."; return; }
        if (string.IsNullOrWhiteSpace(handle)) { error = "URL handle is required."; return; }

        saving = true;
        try
        {
            org.Name = name.Trim();
            org.Description = description?.Trim();
            org.AvatarUrl = orgAvatarUrl;
            org = await OrgService.UpdateAsync(org, handle.Trim());
            saved = true;

            if (org.Slug != Slug)
                Navigation.NavigateTo($"/{org.Slug}/settings", replace: true);
        }
        catch (Exception ex) { error = ex.Message; }
        saving = false;
    }

    private async Task OnOrgAvatarChanged(string? url)
    {
        orgAvatarUrl = url;
        if (org != null)
        {
            try { org.AvatarUrl = url; await OrgService.UpdateAsync(org); } catch { }
        }
    }

    // ── Org Secrets ──

    private async Task LoadOrgSecrets()
    {
        if (org != null)
            try { orgSecretNames = await SecretService.ListOrgSecretNamesAsync(org.id); } catch { }
    }

    private async Task AddOrgSecret()
    {
        if (org == null || string.IsNullOrWhiteSpace(newOrgSecretName) || string.IsNullOrWhiteSpace(newOrgSecretValue))
        {
            orgSecretError = "Name and value are required.";
            return;
        }
        addingOrgSecret = true;
        orgSecretError = null;
        orgSecretSaved = false;
        try
        {
            await SecretService.SetOrgSecretAsync(org.id, newOrgSecretName.Trim(), newOrgSecretValue);
            newOrgSecretName = "";
            newOrgSecretValue = "";
            orgSecretSaved = true;
            await LoadOrgSecrets();
        }
        catch (Exception ex) { orgSecretError = ex.Message; }
        addingOrgSecret = false;
    }

    // ── GitHub bulk import ──

    private async Task StartImport()
    {
        if (org == null) return;
        importError = null;
        if (string.IsNullOrWhiteSpace(ghOrg)) { importError = "GitHub organization is required."; return; }

        startingImport = true;
        try
        {
            importJob = await GitHubImporter.StartAsync(
                daisiOrgId: org.id, daisiOrgSlug: org.Slug,
                accountId: org.AccountId,
                actorUserId: org.id /* org as actor; user identity not exposed here */,
                actorUserName: org.Name,
                githubOrg: ghOrg.Trim(),
                githubToken: string.IsNullOrWhiteSpace(ghToken) ? null : ghToken.Trim(),
                includePrivate: ghIncludePrivate,
                defaultPublicVisibility: ghPublicVisibility,
                defaultPrivateVisibility: ghPrivateVisibility,
                storageProvider: null);

            // Don't keep the token in memory longer than necessary.
            ghToken = "";

            StartPollingImport();
        }
        catch (Exception ex) { importError = ex.Message; }
        startingImport = false;
    }

    private void StartPollingImport()
    {
        importPollTimer?.Dispose();
        importPollTimer = new System.Threading.Timer(_ =>
        {
            if (importJob == null) return;
            var fresh = GitHubImporter.GetJob(importJob.Id);
            if (fresh != null) importJob = fresh;
            InvokeAsync(StateHasChanged);
            if (importJob?.IsComplete == true)
            {
                importPollTimer?.Dispose();
                importPollTimer = null;
            }
        }, null, TimeSpan.FromSeconds(2), TimeSpan.FromSeconds(2));
    }

    public void Dispose()
    {
        importPollTimer?.Dispose();
    }

    private static MarkupString StatusIcon(string status) => new(status switch
    {
        "Pending"    => "<i class='fa-regular fa-hourglass text-muted'></i>",
        "InProgress" => "<i class='fa-solid fa-spinner fa-spin text-primary'></i>",
        "Imported"   => "<i class='fa-solid fa-check text-success'></i>",
        "Skipped"    => "<i class='fa-solid fa-forward text-muted'></i>",
        "Failed"     => "<i class='fa-solid fa-xmark text-danger'></i>",
        _            => "<i class='fa-regular fa-circle text-muted'></i>"
    });

    private async Task RemoveOrgSecret(string secretName)
    {
        if (org == null) return;
        try
        {
            await SecretService.DeleteOrgSecretAsync(org.id, secretName);
            await LoadOrgSecrets();
        }
        catch { }
    }
}
