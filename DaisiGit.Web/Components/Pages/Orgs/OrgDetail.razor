@page "/{Slug}"
@page "/org/{Slug}"
@inject OrganizationService OrgService
@inject RepositoryService RepoService
@inject TeamService TeamService
@inject BrowseService BrowseService
@inject OrgActivityService ActivityService
@inject DaisiGit.Web.Services.DaisiUserService UserService

<PageTitle>@(org?.Name ?? "Organization") - Daisi Git</PageTitle>

@if (org != null)
{
    <div class="d-flex justify-content-between align-items-start mb-3">
        <div>
            <h3>
                <i class="fa-duotone fa-building me-1 text-muted"></i>
                @org.Name
            </h3>
            @if (!string.IsNullOrEmpty(org.Description))
            {
                <p class="text-muted mb-0">@org.Description</p>
            }
        </div>
        @if (!isAnonymous)
        {
            <a href="/@Slug/settings" class="btn btn-sm btn-outline-secondary">
                <i class="fa-duotone fa-gear me-1"></i> Settings
            </a>
        }
    </div>

    <!-- Tabs -->
    <ul class="nav nav-tabs mb-3">
        <li class="nav-item">
            <a class="nav-link @(activeTab == "repos" ? "active" : "")" href="#" @onclick:preventDefault @onclick="SetTabRepos">
                <i class="fa-duotone fa-code-branch me-1"></i> Repositories
            </a>
        </li>
        <li class="nav-item">
            <a class="nav-link @(activeTab == "activity" ? "active" : "")" href="#" @onclick:preventDefault @onclick="SetTabActivity">
                <i class="fa-duotone fa-chart-simple me-1"></i> Activity
            </a>
        </li>
        @if (!isAnonymous)
        {
            <li class="nav-item">
                <a class="nav-link @(activeTab == "members" ? "active" : "")" href="#" @onclick:preventDefault @onclick="SetTabMembers">
                    <i class="fa-duotone fa-users me-1"></i> Members (@members.Count)
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link @(activeTab == "teams" ? "active" : "")" href="#" @onclick:preventDefault @onclick="SetTabTeams">
                    <i class="fa-duotone fa-people-group me-1"></i> Teams (@teams.Count)
                </a>
            </li>
        }
    </ul>

    @if (activeTab == "repos")
    {
        @if (!string.IsNullOrEmpty(profileReadme))
        {
            <div class="card mb-3">
                <div class="card-header py-2 d-flex justify-content-between align-items-center">
                    <span class="text-muted small">
                        <i class="fa-regular fa-file-lines me-1"></i> @Slug/.daisi/README.md
                    </span>
                    @if (!isAnonymous)
                    {
                        <a href="/@Slug/.daisi/edit/main/README.md" class="text-muted small text-decoration-none">
                            <i class="fa-regular fa-pen-to-square"></i>
                        </a>
                    }
                </div>
                <div class="card-body">
                    <MarkdownView Content="@profileReadme" />
                </div>
            </div>
        }

        @if (repos.Count > 0)
        {
            <div class="list-group">
                @foreach (var r in repos)
                {
                    <a href="/@org.Slug/@r.Slug" class="list-group-item list-group-item-action">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <div class="fw-semibold">@r.Name</div>
                                @if (!string.IsNullOrEmpty(r.Description))
                                {
                                    <div class="text-muted small">@r.Description</div>
                                }
                            </div>
                            <span class="badge bg-@(r.Visibility == GitRepoVisibility.Public ? "success" : r.Visibility == GitRepoVisibility.Internal ? "warning" : "secondary")">
                                @r.Visibility
                            </span>
                        </div>
                    </a>
                }
            </div>
        }
        else
        {
            <div class="text-center py-4 text-muted">
                <p>No repositories in this organization yet.</p>
            </div>
        }
    }
    else if (activeTab == "activity")
    {
        <div class="d-flex flex-wrap gap-2 align-items-center mb-3">
            <label class="text-muted small mb-0">Range</label>
            <select class="form-select form-select-sm" style="width:auto;" @bind="activityDays" @bind:after="ReloadActivity">
                <option value="7">7 days</option>
                <option value="30">30 days</option>
                <option value="90">90 days</option>
                <option value="180">180 days</option>
                <option value="365">1 year</option>
            </select>

            <label class="text-muted small mb-0 ms-2">Granularity</label>
            <select class="form-select form-select-sm" style="width:auto;" @bind="activityGranularity" @bind:after="ReloadActivity">
                <option value="day">Day</option>
                <option value="week">Week</option>
                <option value="month">Month</option>
            </select>

            @if (!isAnonymous)
            {
                <div class="form-check form-switch ms-2 mb-0">
                    <input class="form-check-input" type="checkbox" id="includePriv" @bind="includePrivate" @bind:after="ReloadActivity" />
                    <label class="form-check-label small text-muted" for="includePriv">Include private repos</label>
                </div>
            }

            @if (loadingActivity)
            {
                <span class="spinner-border spinner-border-sm text-muted ms-2"></span>
            }
        </div>

        @if (activity != null && activity.Buckets.Count > 0)
        {
            var maxCount = activity.Repos.SelectMany(r => r.Counts).DefaultIfEmpty(0).Max();
            <div class="card">
                <div class="card-body p-0" style="overflow-x:auto;">
                    <table class="table table-sm mb-0" style="min-width:100%;">
                        <thead>
                            <tr class="text-muted small">
                                <th style="position:sticky;left:0;background:var(--bs-body-bg);z-index:1;">Repository</th>
                                @foreach (var b in activity.Buckets)
                                {
                                    <th class="text-center small fw-normal" style="font-size:0.7rem;white-space:nowrap;">@b.Label</th>
                                }
                                <th class="text-center small">Total</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var r in activity.Repos)
                            {
                                var total = r.Counts.Sum();
                                <tr>
                                    <td style="position:sticky;left:0;background:var(--bs-body-bg);z-index:1;">
                                        <a href="/@r.OwnerName/@r.Slug" class="text-decoration-none">@r.Slug</a>
                                        @if (r.Visibility != GitRepoVisibility.Public)
                                        {
                                            <span class="badge bg-secondary ms-1" style="font-size:0.6rem;">@r.Visibility</span>
                                        }
                                    </td>
                                    @for (var i = 0; i < r.Counts.Length; i++)
                                    {
                                        var idx = i; // capture
                                        var count = r.Counts[idx];
                                        var bucket = activity.Buckets[idx];
                                        <td class="text-center p-0" style="cursor:pointer;"
                                            title="@($"{r.Slug} on {bucket.Label}: {count} commit{(count == 1 ? "" : "s")}")"
                                            @onclick="() => OpenCommitsModal(r, idx)">
                                            <div style="display:inline-block;width:18px;height:18px;border-radius:3px;@CellStyle(count, maxCount)"></div>
                                        </td>
                                    }
                                    <td class="text-center small text-muted">@total</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
                <div class="card-footer text-muted small d-flex align-items-center gap-2">
                    Less
                    <span style="display:inline-block;width:14px;height:14px;border-radius:2px;@CellStyle(0, maxCount)"></span>
                    <span style="display:inline-block;width:14px;height:14px;border-radius:2px;@CellStyle(Math.Max(1, maxCount/4), maxCount)"></span>
                    <span style="display:inline-block;width:14px;height:14px;border-radius:2px;@CellStyle(Math.Max(1, maxCount/2), maxCount)"></span>
                    <span style="display:inline-block;width:14px;height:14px;border-radius:2px;@CellStyle(Math.Max(1, (3*maxCount)/4), maxCount)"></span>
                    <span style="display:inline-block;width:14px;height:14px;border-radius:2px;@CellStyle(maxCount, maxCount)"></span>
                    More
                </div>
            </div>
        }
        else if (!loadingActivity)
        {
            <div class="text-center py-5 text-muted">
                <i class="fa-duotone fa-chart-simple fa-2x mb-2 d-block"></i>
                <p>No commit activity in this range.</p>
            </div>
        }

        @if (modalRepo != null && modalBucketIndex >= 0)
        {
            var bucket = activity!.Buckets[modalBucketIndex];
            var inBucket = modalRepo.Commits.Where(c => c.BucketIndex == modalBucketIndex).ToList();
            <div class="modal d-block" tabindex="-1" style="background:rgba(0,0,0,0.5);" @onclick="CloseCommitsModal">
                <div class="modal-dialog modal-dialog-centered modal-lg" @onclick:stopPropagation>
                    <div class="modal-content">
                        <div class="modal-header">
                            <h5 class="modal-title">
                                <a href="/@modalRepo.OwnerName/@modalRepo.Slug" class="text-decoration-none">@modalRepo.Slug</a>
                                <span class="text-muted">·</span> @bucket.Label
                                <span class="text-muted small ms-1">(@inBucket.Count commit@(inBucket.Count == 1 ? "" : "s"))</span>
                            </h5>
                            <button class="btn-close" @onclick="CloseCommitsModal"></button>
                        </div>
                        <div class="modal-body p-0">
                            @if (inBucket.Count == 0)
                            {
                                <div class="text-center text-muted p-4">No commits.</div>
                            }
                            else
                            {
                                <ul class="list-group list-group-flush">
                                    @foreach (var c in inBucket)
                                    {
                                        <li class="list-group-item">
                                            <div class="d-flex justify-content-between align-items-start">
                                                <div>
                                                    <a href="/@modalRepo.OwnerName/@modalRepo.Slug/commit/@c.Sha" class="fw-semibold text-decoration-none">@c.MessageFirstLine</a>
                                                    <div class="text-muted small">
                                                        @c.AuthorName · @c.AuthorDateUtc.ToLocalTime().ToString("MMM d, HH:mm")
                                                    </div>
                                                </div>
                                                <code class="text-muted small">@c.ShortSha</code>
                                            </div>
                                        </li>
                                    }
                                </ul>
                            }
                        </div>
                    </div>
                </div>
            </div>
        }
    }
    else if (activeTab == "members")
    {
        <div class="d-flex justify-content-between align-items-center mb-2">
            <h6>Members</h6>
            <button class="btn btn-sm btn-outline-primary" @onclick="ToggleAddMember">
                <i class="fa-duotone fa-user-plus me-1"></i> Import from Daisinet
            </button>
        </div>

        @if (showAddMember)
        {
            <div class="card mb-3">
                <div class="card-header">
                    <i class="fa-duotone fa-magnifying-glass me-1"></i> Search Daisinet Users
                </div>
                <div class="card-body">
                    <div class="input-group input-group-sm mb-2">
                        <input type="text" class="form-control" @bind="userSearchTerm" @bind:event="oninput"
                               placeholder="Search by name..." @onkeyup="OnSearchKeyUp" />
                        <button class="btn btn-outline-secondary" @onclick="SearchUsers" disabled="@searching">
                            @if (searching)
                            {
                                <span class="spinner-border spinner-border-sm"></span>
                            }
                            else
                            {
                                <i class="fa-duotone fa-search"></i>
                            }
                        </button>
                    </div>

                    @if (searchResults.Count > 0)
                    {
                        <div class="list-group list-group-flush">
                            @foreach (var user in searchResults)
                            {
                                var alreadyMember = existingMemberIds.Contains(user.Id);
                                <div class="list-group-item d-flex justify-content-between align-items-center py-2 px-0">
                                    <div>
                                        <strong class="small">@user.Name</strong>
                                        <span class="text-muted small ms-1">@user.Email</span>
                                    </div>
                                    @if (alreadyMember)
                                    {
                                        <span class="badge bg-secondary">Already a member</span>
                                    }
                                    else
                                    {
                                        <div class="d-flex align-items-center gap-1">
                                            <select class="form-select form-select-sm" style="width: auto;" @bind="newMemberRole">
                                                <option value="@GitRole.Read">Read</option>
                                                <option value="@GitRole.Write">Write</option>
                                                <option value="@GitRole.Maintain">Maintain</option>
                                                <option value="@GitRole.Admin">Admin</option>
                                            </select>
                                            <button class="btn btn-sm btn-primary" @onclick="() => AddMember(user)">
                                                Add
                                            </button>
                                        </div>
                                    }
                                </div>
                            }
                        </div>
                    }
                    else if (hasSearched && !searching)
                    {
                        <div class="text-muted small text-center py-2">No users found.</div>
                    }

                    @if (!string.IsNullOrEmpty(memberError))
                    {
                        <div class="text-danger small mt-2">@memberError</div>
                    }
                </div>
            </div>
        }

        <div class="list-group">
            @foreach (var m in members)
            {
                <div class="list-group-item d-flex justify-content-between align-items-center">
                    <div>
                        <strong>@m.UserName</strong>
                        <span class="badge bg-@(RoleBadgeColor(m.Role)) ms-2">@m.Role</span>
                    </div>
                    <div class="text-muted small">
                        Joined @m.JoinedUtc.ToString("MMM d, yyyy")
                    </div>
                </div>
            }
        </div>
    }
    else if (activeTab == "teams")
    {
        <div class="d-flex justify-content-between align-items-center mb-2">
            <h6>Teams</h6>
            <a href="/@Slug/teams/new" class="btn btn-sm btn-outline-primary">
                <i class="fa-duotone fa-plus me-1"></i> New Team
            </a>
        </div>

        @if (teams.Count > 0)
        {
            <div class="list-group">
                @foreach (var t in teams)
                {
                    <a href="/@Slug/team/@t.Slug" class="list-group-item list-group-item-action">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <div class="fw-semibold">@t.Name</div>
                                @if (!string.IsNullOrEmpty(t.Description))
                                {
                                    <div class="text-muted small">@t.Description</div>
                                }
                            </div>
                            <div class="text-muted small">
                                <i class="fa-duotone fa-users me-1"></i>@t.MemberCount
                                <span class="badge bg-@(RoleBadgeColor(t.DefaultPermission)) ms-2">@t.DefaultPermission</span>
                            </div>
                        </div>
                    </a>
                }
            </div>
        }
        else
        {
            <div class="text-center py-4 text-muted">
                <p>No teams yet.</p>
            </div>
        }
    }
}
else if (!loading)
{
    <div class="text-center py-4 text-muted">
        <p>Organization not found.</p>
    </div>
}

@code {
    [Parameter] public string Slug { get; set; } = "";
    [CascadingParameter(Name = "UserId")] public string? UserId { get; set; }

    private GitOrganization? org;
    private List<GitRepository> repos = [];
    private List<OrgMember> members = [];
    private List<Team> teams = [];
    private HashSet<string> existingMemberIds = [];
    private bool loading = true;
    private string activeTab = "repos";
    private bool showAddMember;
    private GitRole newMemberRole = GitRole.Read;
    private string? memberError;
    private string? profileReadme;
    private bool isAnonymous => string.IsNullOrEmpty(UserId);

    // Activity tab
    private OrgActivity? activity;
    private bool loadingActivity;
    private int activityDays = 30;
    private string activityGranularity = "day";
    private bool includePrivate;
    private RepoActivity? modalRepo;
    private int modalBucketIndex = -1;

    // User search
    private string userSearchTerm = "";
    private List<DaisiGit.Web.Services.DaisiUserInfo> searchResults = [];
    private bool searching;
    private bool hasSearched;

    protected override async Task OnParametersSetAsync()
    {
        loading = true;
        try
        {
            org = await OrgService.GetBySlugAsync(Slug);
            if (org == null) { loading = false; return; }

            var allRepos = await RepoService.GetRepositoriesByOwnerAsync(org.Slug);
            // Anonymous viewers see only public repos. Authenticated viewers see what they
            // already had access to (full list — repo-page itself enforces deeper checks).
            repos = isAnonymous
                ? allRepos.Where(r => r.Visibility == GitRepoVisibility.Public).ToList()
                : allRepos;

            // Surface a profile README from the special ".daisi" repo (if it exists and is
            // public). Modeled after GitHub's `.github` profile-repo convention so users have
            // a way to update their org page.
            var profileRepo = allRepos.FirstOrDefault(r => r.Slug == ".daisi");
            if (profileRepo != null
                && (profileRepo.Visibility == GitRepoVisibility.Public || !isAnonymous))
            {
                profileReadme = await TryReadProfileReadmeAsync(profileRepo);
            }

            // Member/team management is sign-in only.
            if (!isAnonymous)
            {
                members = await OrgService.GetMembersAsync(org.id);
                existingMemberIds = members.Select(m => m.UserId).ToHashSet();
                teams = await TeamService.ListAsync(org.id);
            }
        }
        catch { }
        loading = false;
    }

    private async Task<string?> TryReadProfileReadmeAsync(GitRepository profileRepo)
    {
        try
        {
            var commitSha = await BrowseService.ResolveRefAsync(profileRepo.id, profileRepo.DefaultBranch);
            if (commitSha == null) return null;

            var rootTree = await BrowseService.GetTreeAtPathAsync(profileRepo.id, commitSha, "");
            if (rootTree == null || rootTree.Entries == null) return null;

            // Case-insensitive match for README.md, README.markdown, etc.
            var readmeEntry = rootTree.Entries.FirstOrDefault(e =>
                !e.IsTree && e.Name.StartsWith("README.", StringComparison.OrdinalIgnoreCase)
                          && (e.Name.EndsWith(".md", StringComparison.OrdinalIgnoreCase)
                           || e.Name.EndsWith(".markdown", StringComparison.OrdinalIgnoreCase)));
            if (readmeEntry == null) return null;

            var blob = await BrowseService.GetFileContentAsync(profileRepo.id, readmeEntry.Sha);
            return blob?.Text;
        }
        catch
        {
            return null;
        }
    }

    private void ToggleAddMember()
    {
        showAddMember = !showAddMember;
        if (!showAddMember)
        {
            searchResults = [];
            userSearchTerm = "";
            hasSearched = false;
        }
    }

    private async Task OnSearchKeyUp(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
            await SearchUsers();
    }

    private async Task SearchUsers()
    {
        if (string.IsNullOrWhiteSpace(userSearchTerm)) return;
        searching = true;
        memberError = null;
        try
        {
            searchResults = await UserService.SearchUsersAsync(userSearchTerm.Trim());
            hasSearched = true;
        }
        catch (Exception ex)
        {
            memberError = $"Failed to search users: {ex.Message}";
        }
        searching = false;
    }

    private async Task AddMember(DaisiGit.Web.Services.DaisiUserInfo user)
    {
        memberError = null;
        if (org == null) return;
        try
        {
            await OrgService.AddMemberAsync(org.id, user.Id, user.Name, newMemberRole);
            members = await OrgService.GetMembersAsync(org.id);
            existingMemberIds = members.Select(m => m.UserId).ToHashSet();
        }
        catch (Exception ex)
        {
            memberError = ex.Message;
        }
    }

    private void SetTabRepos() => activeTab = "repos";
    private void SetTabMembers() => activeTab = "members";
    private void SetTabTeams() => activeTab = "teams";
    private async Task SetTabActivity()
    {
        activeTab = "activity";
        if (activity == null) await ReloadActivity();
    }

    private async Task ReloadActivity()
    {
        if (org == null) return;
        loadingActivity = true;
        StateHasChanged();
        try
        {
            var granularity = activityGranularity.ToLowerInvariant() switch
            {
                "month" => ActivityGranularity.Month,
                "week" => ActivityGranularity.Week,
                _ => ActivityGranularity.Day
            };
            activity = await ActivityService.GetActivityAsync(
                org.Slug, activityDays, granularity, includePrivate, UserId);
        }
        catch { activity = null; }
        loadingActivity = false;
    }

    private void OpenCommitsModal(RepoActivity repo, int bucketIndex)
    {
        modalRepo = repo;
        modalBucketIndex = bucketIndex;
    }

    private void CloseCommitsModal()
    {
        modalRepo = null;
        modalBucketIndex = -1;
    }

    /// <summary>Inline style for a heatmap cell. Linear ramp on saturation across green.</summary>
    private static string CellStyle(int count, int max)
    {
        if (count <= 0) return "background:#ebedf0;";
        if (max <= 0) max = 1;
        var ratio = (double)count / max;
        // 5-step ramp similar to GitHub's contributions graph
        var color = ratio switch
        {
            <= 0.25 => "#9be9a8",
            <= 0.50 => "#40c463",
            <= 0.75 => "#30a14e",
            _       => "#216e39"
        };
        return $"background:{color};";
    }

    private static string RoleBadgeColor(GitRole role) => role switch
    {
        GitRole.Owner => "danger",
        GitRole.Admin => "warning",
        GitRole.Maintain => "info",
        GitRole.Write => "primary",
        _ => "secondary"
    };
}
