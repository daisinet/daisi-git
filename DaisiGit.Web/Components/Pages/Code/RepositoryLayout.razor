@inject RepositoryService RepoService
@inject GitRefService RefService
@inject BrowseService BrowseService
@inject NavigationManager Nav

@if (loading)
{
    <div class="text-center py-5">
        <div class="spinner-border text-primary" role="status">
            <span class="visually-hidden">Loading...</span>
        </div>
    </div>
}
else if (Repository == null)
{
    <div class="text-center py-5">
        <h4 class="text-muted">Repository not found</h4>
        <p class="text-muted">@Owner/@RepoSlug does not exist or you don't have access.</p>
    </div>
}
else
{
    <!-- Repo header -->
    <div class="repo-header">
        <div class="d-flex justify-content-between align-items-start mb-3">
            <div>
                <h3 class="mb-1">
                    <a href="/@Owner" class="text-muted text-decoration-none">@Owner</a>
                    <span class="text-muted">/</span>
                    <a href="/@Owner/@RepoSlug" class="text-decoration-none"><strong>@Repository.Name</strong></a>
                </h3>
                @if (!string.IsNullOrEmpty(Repository.Description))
                {
                    <p class="text-muted mb-0">@Repository.Description</p>
                }
            </div>
            <div class="d-flex align-items-center gap-2">
                <button class="btn btn-sm btn-outline-secondary" @onclick="ToggleStar" title="@(hasStarred ? "Unstar" : "Star")">
                    <i class="@(hasStarred ? "fa-solid" : "fa-regular") fa-star me-1"></i> @Repository.StarCount
                </button>
                <button class="btn btn-sm btn-outline-secondary" @onclick="ForkRepo" title="Fork">
                    <i class="fa-duotone fa-code-fork me-1"></i> @Repository.ForkCount
                </button>
                <span class="badge bg-@(Repository.Visibility == GitRepoVisibility.Public ? "success" : Repository.Visibility == GitRepoVisibility.Internal ? "warning" : "secondary")">
                    @Repository.Visibility
                </span>
            </div>
        </div>

        @if (!string.IsNullOrEmpty(Repository.ForkedFromId))
        {
            <p class="text-muted small mb-2">
                <i class="fa-duotone fa-code-fork me-1"></i> Forked from
                <a href="/@Repository.ForkedFromOwnerName/@Repository.ForkedFromSlug">@Repository.ForkedFromOwnerName/@Repository.ForkedFromSlug</a>
            </p>
        }

        <!-- Tabs -->
        <ul class="nav nav-tabs mb-0">
            <li class="nav-item">
                <a class="nav-link @(ActiveTab == "code" ? "active" : "")" href="/@Owner/@RepoSlug/tree/@SelectedBranch">
                    <i class="fa-duotone fa-code me-1"></i> Code
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link @(ActiveTab == "commits" ? "active" : "")" href="/@Owner/@RepoSlug/commits/@SelectedBranch">
                    <i class="fa-duotone fa-clock-rotate-left me-1"></i> Commits
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link @(ActiveTab == "branches" ? "active" : "")" href="/@Owner/@RepoSlug/branches">
                    <i class="fa-duotone fa-code-branch me-1"></i> Branches
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link @(ActiveTab == "pulls" ? "active" : "")" href="/@Owner/@RepoSlug/pulls">
                    <i class="fa-duotone fa-code-pull-request me-1"></i> Pull Requests
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link @(ActiveTab == "issues" ? "active" : "")" href="/@Owner/@RepoSlug/issues">
                    <i class="fa-duotone fa-circle-dot me-1"></i> Issues
                </a>
            </li>
        </ul>
    </div>

    <!-- Tab content -->
    <div class="mt-3">
        @ChildContent
    </div>
}

@code {
    [Parameter] public string Owner { get; set; } = "";
    [Parameter] public string RepoSlug { get; set; } = "";
    [Parameter] public string ActiveTab { get; set; } = "code";
    [Parameter] public string SelectedBranch { get; set; } = "main";
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [CascadingParameter(Name = "UserId")] string UserId { get; set; } = "";
    [CascadingParameter(Name = "UserName")] string UserName { get; set; } = "";
    [CascadingParameter(Name = "AccountId")] string AccountId { get; set; } = "";

    public GitRepository? Repository { get; private set; }
    private bool loading = true;
    private bool hasStarred;

    protected override async Task OnParametersSetAsync()
    {
        loading = true;
        try
        {
            Repository = await RepoService.GetRepositoryBySlugAsync(Owner, RepoSlug);
            if (Repository != null && string.IsNullOrEmpty(SelectedBranch))
                SelectedBranch = Repository.DefaultBranch;
            if (Repository != null && !string.IsNullOrEmpty(UserId))
                hasStarred = await RepoService.HasStarredAsync(UserId, Repository.id);
        }
        catch { }
        loading = false;
    }

    private async Task ToggleStar()
    {
        if (Repository == null) return;
        if (hasStarred)
        {
            await RepoService.UnstarAsync(UserId, Repository.id);
            Repository.StarCount = Math.Max(0, Repository.StarCount - 1);
            hasStarred = false;
        }
        else
        {
            await RepoService.StarAsync(UserId, UserName, Repository.id);
            Repository.StarCount++;
            hasStarred = true;
        }
    }

    private async Task ForkRepo()
    {
        if (Repository == null) return;
        var fork = await RepoService.ForkRepositoryAsync(AccountId, UserId, UserName, Repository);
        Nav.NavigateTo($"/{fork.OwnerName}/{fork.Slug}");
    }
}
