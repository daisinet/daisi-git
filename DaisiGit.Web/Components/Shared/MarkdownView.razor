@using Markdig
@using System.Text.RegularExpressions
@inject IJSRuntime JS

@if (!string.IsNullOrEmpty(Content))
{
    <div class="markdown-body">
        @((MarkupString)ProcessHtml(Markdig.Markdown.ToHtml(Content, Pipeline)))
    </div>
}

@code {
    [Parameter] public string? Content { get; set; }
    [Parameter] public string? Owner { get; set; }
    [Parameter] public string? RepoSlug { get; set; }
    [Parameter] public string? Branch { get; set; }
    [Parameter] public string? FilePath { get; set; }

    private static readonly MarkdownPipeline Pipeline = new MarkdownPipelineBuilder()
        .UseAdvancedExtensions()
        .UseAutoLinks()
        .UseTaskLists()
        .UseEmojiAndSmiley()
        .Build();

    private static readonly Regex MermaidBlockRegex = new(
        @"<pre><code\s+class=""language-mermaid"">([\s\S]*?)</code></pre>",
        RegexOptions.Compiled);

    private static readonly Regex RelativeLinkRegex = new(
        @"(<a\s+[^>]*href="")(?!https?://|//|#|mailto:)([^""]+)("")",
        RegexOptions.Compiled);

    private string ProcessHtml(string html)
    {
        // Convert mermaid code blocks to <pre class="mermaid"> for Mermaid.js rendering
        html = MermaidBlockRegex.Replace(html, m =>
        {
            var code = System.Net.WebUtility.HtmlDecode(m.Groups[1].Value).Trim();
            return $"<pre class=\"mermaid\">{System.Net.WebUtility.HtmlEncode(code)}</pre>";
        });

        // Rewrite relative links to route through the repo file browser
        if (!string.IsNullOrEmpty(Owner) && !string.IsNullOrEmpty(RepoSlug) && !string.IsNullOrEmpty(Branch))
        {
            html = RelativeLinkRegex.Replace(html, m =>
            {
                var prefix = m.Groups[1].Value;
                var href = m.Groups[2].Value;
                var suffix = m.Groups[3].Value;
                var resolved = ResolveRelativeLink(href);
                return $"{prefix}{resolved}{suffix}";
            });
        }

        return html;
    }

    private string ResolveRelativeLink(string href)
    {
        // Split anchor from path
        var anchor = "";
        var hashIdx = href.IndexOf('#');
        if (hashIdx >= 0)
        {
            anchor = href[hashIdx..];
            href = href[..hashIdx];
        }

        if (string.IsNullOrEmpty(href))
            return anchor; // pure anchor link

        // Get the directory of the current file
        var currentDir = "";
        if (!string.IsNullOrEmpty(FilePath))
        {
            var lastSlash = FilePath.LastIndexOf('/');
            if (lastSlash >= 0)
                currentDir = FilePath[..lastSlash];
        }

        // Resolve the relative path against the current directory
        var segments = new List<string>();
        if (!string.IsNullOrEmpty(currentDir))
            segments.AddRange(currentDir.Split('/'));

        foreach (var part in href.Split('/'))
        {
            if (part == ".." && segments.Count > 0)
                segments.RemoveAt(segments.Count - 1);
            else if (part != "." && part != "")
                segments.Add(part);
        }

        var resolvedPath = string.Join("/", segments);

        // Use /blob/ for files (has extension), /tree/ for directories
        var lastSegment = segments.Count > 0 ? segments[^1] : "";
        var routeType = lastSegment.Contains('.') ? "blob" : "tree";

        return $"/{Owner}/{RepoSlug}/{routeType}/{Branch}/{resolvedPath}{anchor}";
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!string.IsNullOrEmpty(Content))
        {
            try
            {
                await JS.InvokeVoidAsync("renderDiagrams");
            }
            catch (JSDisconnectedException) { }
        }
    }
}
