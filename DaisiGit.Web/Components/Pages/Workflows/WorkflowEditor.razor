@page "/{Owner}/{RepoSlug}/workflows/new"
@page "/{Owner}/{RepoSlug}/workflows/edit/{WorkflowId}"
@inject WorkflowService WorkflowService
@inject RepositoryService RepoService
@inject SecretService SecretService
@inject NavigationManager Nav

<PageTitle>@(isNew ? "New Workflow" : "Edit Workflow") - @Owner/@RepoSlug - Daisi Git</PageTitle>

<RepositoryLayout Owner="@Owner" RepoSlug="@RepoSlug" ActiveTab="workflows">
    @if (loading)
    {
        <div class="text-center py-4"><div class="spinner-border spinner-border-sm text-primary"></div></div>
    }
    else
    {
        <!-- Header -->
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h5 class="mb-0">@(isNew ? "New Workflow" : "Edit Workflow")</h5>
            <div class="d-flex gap-2">
                <a href="/@Owner/@RepoSlug/workflows" class="btn btn-sm btn-outline-secondary">Cancel</a>
                <button class="btn btn-sm btn-primary" @onclick="Save" disabled="@saving">
                    @if (saving) { <span class="spinner-border spinner-border-sm me-1"></span> }
                    @(isNew ? "Create" : "Save")
                </button>
            </div>
        </div>

        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="alert alert-danger alert-dismissible">@errorMessage</div>
        }

        <!-- Workflow metadata -->
        <div class="card mb-3">
            <div class="card-body">
                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label">Name</label>
                        <input type="text" class="form-control" @bind="workflow.Name" placeholder="My workflow" />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Trigger</label>
                        <select class="form-select" @bind="triggerTypeStr">
                            <option value="PushToRef">Push to branch</option>
                            <option value="BranchCreated">Branch created</option>
                            <option value="BranchDeleted">Branch deleted</option>
                            <option value="TagCreated">Tag created</option>
                            <option value="PullRequestCreated">Pull request opened</option>
                            <option value="PullRequestClosed">Pull request closed</option>
                            <option value="PullRequestMerged">Pull request merged</option>
                            <option value="IssueCreated">Issue opened</option>
                            <option value="IssueClosed">Issue closed</option>
                            <option value="IssueReopened">Issue reopened</option>
                            <option value="CommentCreated">Comment created</option>
                            <option value="ReviewSubmitted">Review submitted</option>
                            <option value="RepositoryForked">Repository forked</option>
                        </select>
                    </div>
                    <div class="col-md-2 d-flex align-items-end">
                        <div class="form-check form-switch">
                            <input class="form-check-input" type="checkbox" @bind="workflow.IsEnabled" id="wfEnabled" />
                            <label class="form-check-label" for="wfEnabled">Enabled</label>
                        </div>
                    </div>
                </div>

                @if (IsPushTrigger)
                {
                    <div class="row g-3 mt-1">
                        <div class="col-md-6">
                            <label class="form-label">Branch filter <span class="text-muted">(optional, comma-separated)</span></label>
                            <input type="text" class="form-control" @bind="branchFilter" placeholder="main, dev" />
                        </div>
                    </div>
                }

                <div class="mt-2">
                    <label class="form-label">Description <span class="text-muted">(optional)</span></label>
                    <input type="text" class="form-control" @bind="workflow.Description" />
                </div>
            </div>
        </div>

        <!-- Visual workflow designer -->
        <div class="card">
            <div class="card-body">
                <div class="wf-flow">
                    <!-- Trigger node -->
                    <div class="wf-node wf-node--trigger">
                        <i class="fa-duotone fa-bolt me-1"></i> @FormatTriggerShort(workflow.TriggerType)
                    </div>
                    <div class="wf-connector"></div>

                    <!-- Insert before first step -->
                    <div class="wf-insert">
                        <button class="btn btn-sm btn-outline-secondary wf-insert-btn" @onclick="() => InsertStep(0)">
                            <i class="fa-solid fa-plus"></i>
                        </button>
                    </div>

                    @for (var i = 0; i < workflow.Steps.Count; i++)
                    {
                        var idx = i;
                        var step = workflow.Steps[i];
                        <div class="wf-connector"></div>
                        <div class="wf-node wf-node--@step.StepType.ToString().ToLower() @(selectedStepIndex == idx ? "wf-node--selected" : "")"
                             @onclick="() => SelectStep(idx)">
                            <div class="wf-node-icon">@StepIcon(step.StepType)</div>
                            <div class="wf-node-label">
                                @if (!string.IsNullOrEmpty(step.Name))
                                {
                                    @step.Name
                                }
                                else
                                {
                                    @FormatStepType(step.StepType)
                                }
                            </div>
                            <button class="wf-node-delete btn btn-sm" @onclick="() => RemoveStep(idx)" @onclick:stopPropagation="true">
                                <i class="fa-solid fa-xmark"></i>
                            </button>
                        </div>

                        <div class="wf-insert">
                            <button class="btn btn-sm btn-outline-secondary wf-insert-btn" @onclick="() => InsertStep(idx + 1)">
                                <i class="fa-solid fa-plus"></i>
                            </button>
                        </div>
                    }

                    <div class="wf-connector"></div>
                    <!-- End node -->
                    <div class="wf-node wf-node--end">
                        <i class="fa-duotone fa-flag-checkered me-1"></i> End
                    </div>
                </div>
            </div>
        </div>

        <!-- Add step dialog -->
        @if (showAddStepMenu)
        {
            <div class="modal d-block" tabindex="-1" style="background: rgba(0,0,0,0.4);" @onclick="() => showAddStepMenu = false">
                <div class="modal-dialog modal-dialog-centered modal-lg" @onclick:stopPropagation="true">
                    <div class="modal-content">
                        <div class="modal-header">
                            <h5 class="modal-title"><i class="fa-duotone fa-plus-circle me-1"></i> Add a step</h5>
                            <button type="button" class="btn-close" @onclick="() => showAddStepMenu = false"></button>
                        </div>
                        <div class="modal-body">
                            <input type="text" class="form-control mb-3" placeholder="Search steps..."
                                   @bind="stepSearchQuery" @bind:event="oninput" />

                            @foreach (var group in StepCatalog.Where(g => g.Steps.Any(s => MatchesSearch(s))))
                            {
                                <h6 class="text-muted mt-2 mb-2">@group.GroupName</h6>
                                <div class="row g-2 mb-3">
                                    @foreach (var entry in group.Steps.Where(MatchesSearch))
                                    {
                                        <div class="col-md-6">
                                            <button class="btn btn-outline-secondary w-100 text-start wf-step-pick"
                                                    @onclick="() => AddStep(entry.Type, entry.Name)">
                                                <i class="@entry.Icon me-2 wf-step-pick-icon" style="color: @entry.Color;"></i>
                                                <div class="d-inline-block align-middle">
                                                    <div class="fw-semibold">@entry.Name</div>
                                                    <div class="text-muted small">@entry.Description</div>
                                                </div>
                                            </button>
                                        </div>
                                    }
                                </div>
                            }
                        </div>
                    </div>
                </div>
            </div>
        }
    }
</RepositoryLayout>

<!-- Step editor aside -->
@if (selectedStepIndex >= 0 && selectedStepIndex < workflow.Steps.Count)
{
    var step = workflow.Steps[selectedStepIndex];
    var catalogEntry = StepCatalog.SelectMany(g => g.Steps).FirstOrDefault(e => e.Type == step.StepType);

    <div class="wf-aside-backdrop" @onclick="() => selectedStepIndex = -1"></div>
    <aside class="wf-aside">
        <div class="wf-aside-header">
            <div class="d-flex align-items-center gap-2">
                @if (catalogEntry != null)
                {
                    <i class="@catalogEntry.Icon" style="color: @catalogEntry.Color; font-size: 1.2rem;"></i>
                }
                <div>
                    <div class="fw-semibold">@FormatStepType(step.StepType)</div>
                    @if (catalogEntry != null)
                    {
                        <div class="text-muted small">@catalogEntry.Description</div>
                    }
                </div>
            </div>
            <button class="btn btn-sm btn-outline-secondary" @onclick="() => selectedStepIndex = -1">
                <i class="fa-solid fa-xmark"></i>
            </button>
        </div>

        <div class="wf-aside-body">
            <div class="mb-3">
                <label class="form-label">Step name @InfoTip("A display label shown on the workflow canvas. e.g. \"Notify Slack\", \"Deploy staging\"")</label>
                <input type="text" class="form-control" @bind="step.Name" placeholder="Optional label" />
            </div>

            @switch (step.StepType)
            {
                case WorkflowStepType.HttpRequest:
                    <div class="mb-3">
                        <label class="form-label">Method @InfoTip("HTTP verb. GET for read, POST/PUT/PATCH for sending data, DELETE for removal.")</label>
                        <select class="form-select" @bind="step.HttpMethod">
                            <option>GET</option>
                            <option>POST</option>
                            <option>PUT</option>
                            <option>PATCH</option>
                            <option>DELETE</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">URL @InfoTip("Full URL including https://. Merge fields allowed: https://hooks.slack.com/{{secrets.SLACK_PATH}}")</label>
                        <input type="text" class="form-control" @bind="step.HttpUrl" placeholder="https://hooks.example.com/webhook" />
                    </div>
                    @if (step.HttpMethod is "POST" or "PUT" or "PATCH")
                    {
                        <div class="mb-3">
                            <label class="form-label">Body @InfoTip("JSON or text payload. Use merge fields like {{repo.name}}, {{push.branch}}, {{pr.title}}, {{actor.name}}, {{secrets.KEY}}")</label>
                            <textarea class="form-control font-monospace" rows="4" @bind="step.HttpBody"
                                      placeholder='{"repo": "{{repo.name}}", "branch": "{{push.branch}}"}'></textarea>
                        </div>
                    }
                    break;

                case WorkflowStepType.AddComment:
                    <div class="mb-3">
                        <label class="form-label">Comment body @InfoTip("Markdown text posted on the triggering PR or issue. Use merge fields: {{push.branch}}, {{actor.name}}, {{repo.name}}")</label>
                        <textarea class="form-control" rows="4" @bind="step.CommentBody"
                                  placeholder="Build triggered for {{push.branch}}"></textarea>
                    </div>
                    break;

                case WorkflowStepType.SetLabel:
                case WorkflowStepType.RemoveLabel:
                    <div class="mb-3">
                        <label class="form-label">Label name @InfoTip("Exact label text, case-sensitive. e.g. \"ready-to-merge\", \"bug\", \"needs-review\"")</label>
                        <input type="text" class="form-control" @bind="step.LabelName" placeholder="ready-to-merge" />
                    </div>
                    break;

                case WorkflowStepType.CloseIssue:
                    <div class="text-muted">Closes the issue that triggered this workflow. No configuration needed.</div>
                    break;

                case WorkflowStepType.ClosePullRequest:
                    <div class="text-muted">Closes the pull request that triggered this workflow. No configuration needed.</div>
                    break;

                case WorkflowStepType.RequireReview:
                    <div class="mb-3">
                        <label class="form-label">Required approvals @InfoTip("Number of approved reviews needed (1-10). Workflow fails this step if the PR has fewer approvals.")</label>
                        <input type="number" class="form-control" @bind="step.RequiredApprovals" min="1" max="10" />
                    </div>
                    break;

                case WorkflowStepType.Wait:
                    <div class="mb-3">
                        <label class="form-label">Days @InfoTip("Whole number of days to pause. The workflow resumes automatically after the total wait time elapses.")</label>
                        <input type="number" class="form-control" @bind="step.WaitDays" min="0" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Hours @InfoTip("0-23. Combined with days and minutes for total wait duration.")</label>
                        <input type="number" class="form-control" @bind="step.WaitHours" min="0" max="23" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Minutes @InfoTip("0-59. Minimum total wait is 1 minute if all fields are zero.")</label>
                        <input type="number" class="form-control" @bind="step.WaitMinutes" min="0" max="59" />
                    </div>
                    break;

                case WorkflowStepType.DeployAzureWebApp:
                    <div class="mb-3">
                        <label class="form-label">Azure App Name @InfoTip("The App Service resource name from Azure Portal. e.g. \"my-app\" for my-app.azurewebsites.net. Merge fields allowed.")</label>
                        <input type="text" class="form-control" @bind="step.AzureAppName" placeholder="my-web-app" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Deploy path @InfoTip("Optional subdirectory within the repo to deploy. e.g. \"src/web\" or \"publish\". Leave empty to deploy the entire repository.")</label>
                        <input type="text" class="form-control" @bind="step.AzureDeployPath" placeholder="src/web" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Username secret @InfoTip("Select the secret containing the deployment username. This is the $ username from your Azure publish profile (Azure Portal > App Service > Deployment Center > Manage publish profile).")</label>
                        @if (repoSecrets.Count > 0)
                        {
                            <select class="form-select" @bind="step.AzureUsernameSecret">
                                <option value="">-- select a secret --</option>
                                @foreach (var s in repoSecrets)
                                {
                                    <option value="@s">@s</option>
                                }
                            </select>
                        }
                        else
                        {
                            <input type="text" class="form-control" @bind="step.AzureUsernameSecret" placeholder="AZURE_DEPLOY_USERNAME" />
                        }
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Password secret @InfoTip("Select the secret containing the deployment password from your Azure publish profile.")</label>
                        @if (repoSecrets.Count > 0)
                        {
                            <select class="form-select" @bind="step.AzurePasswordSecret">
                                <option value="">-- select a secret --</option>
                                @foreach (var s in repoSecrets)
                                {
                                    <option value="@s">@s</option>
                                }
                            </select>
                        }
                        else
                        {
                            <input type="text" class="form-control" @bind="step.AzurePasswordSecret" placeholder="AZURE_DEPLOY_PASSWORD" />
                        }
                    </div>
                    @if (repoSecrets.Count == 0)
                    {
                        <div class="alert alert-warning mb-0">
                            <i class="fa-duotone fa-key me-1"></i>
                            No secrets found. <a href="/@Owner/@RepoSlug/settings">Add secrets</a> for your Azure publish profile credentials first.
                        </div>
                    }
                    break;
            }
        </div>
    </aside>
}

<style>
    .wf-flow {
        display: flex;
        flex-direction: column;
        align-items: center;
        padding: 1rem 0;
    }
    .wf-connector {
        width: 2px;
        height: 20px;
        background: var(--bs-border-color);
    }
    .wf-node {
        position: relative;
        display: flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.5rem 1.25rem;
        border: 2px solid var(--bs-border-color);
        border-radius: 8px;
        background: var(--bs-body-bg);
        cursor: pointer;
        min-width: 180px;
        justify-content: center;
        transition: border-color 0.15s, box-shadow 0.15s;
    }
    .wf-node:hover { border-color: var(--bs-primary); }
    .wf-node--selected { border-color: var(--bs-primary); box-shadow: 0 0 0 3px rgba(var(--bs-primary-rgb), 0.15); }
    .wf-node--trigger { background: var(--bs-success-bg-subtle); border-color: var(--bs-success); color: var(--bs-success); border-radius: 20px; cursor: default; }
    .wf-node--end { background: var(--bs-secondary-bg); border-color: var(--bs-secondary); color: var(--bs-secondary); border-radius: 20px; cursor: default; }
    .wf-node--httprequest { border-left: 4px solid #fd7e14; }
    .wf-node--addcomment { border-left: 4px solid #0d6efd; }
    .wf-node--setlabel, .wf-node--removelabel { border-left: 4px solid #6f42c1; }
    .wf-node--closeissue, .wf-node--closepullrequest { border-left: 4px solid #dc3545; }
    .wf-node--requirereview { border-left: 4px solid #198754; }
    .wf-node--wait { border-left: 4px solid #6c757d; }
    .wf-node--deployazurewebapp { border-left: 4px solid #0078d4; }
    .wf-node-delete {
        position: absolute;
        top: -8px;
        right: -8px;
        width: 22px;
        height: 22px;
        padding: 0;
        border-radius: 50%;
        background: var(--bs-danger);
        color: white;
        font-size: 0.7rem;
        display: none;
        align-items: center;
        justify-content: center;
    }
    .wf-node:hover .wf-node-delete { display: flex; }
    .wf-insert { padding: 4px 0; }
    .wf-insert-btn {
        width: 24px;
        height: 24px;
        padding: 0;
        border-radius: 50%;
        font-size: 0.65rem;
        opacity: 0.4;
        transition: opacity 0.15s;
    }
    .wf-insert-btn:hover { opacity: 1; }
    .wf-node-icon { font-size: 1rem; }
    .wf-node-label { font-size: 0.85rem; font-weight: 500; }
    .wf-step-pick { padding: 0.6rem 0.75rem; border-radius: 8px; transition: border-color 0.15s, background 0.15s; }
    .wf-step-pick:hover { background: var(--bs-primary-bg-subtle); border-color: var(--bs-primary); }
    .wf-step-pick-icon { font-size: 1.2rem; width: 1.5rem; text-align: center; }

    .wf-aside-backdrop {
        position: fixed; inset: 0; background: rgba(0,0,0,0.25); z-index: 1040;
    }
    .wf-aside {
        position: fixed; top: 0; right: 0; bottom: 0;
        width: min(420px, 90vw); z-index: 1050;
        background: var(--bs-body-bg);
        border-left: 1px solid var(--bs-border-color);
        box-shadow: -4px 0 24px rgba(0,0,0,0.1);
        display: flex; flex-direction: column;
        animation: wf-slide-in 0.15s ease-out;
    }
    @@keyframes wf-slide-in { from { transform: translateX(100%); } to { transform: translateX(0); } }
    .wf-aside-header {
        display: flex; justify-content: space-between; align-items: flex-start;
        padding: 1rem 1.25rem; border-bottom: 1px solid var(--bs-border-color);
    }
    .wf-aside-body { padding: 1.25rem; overflow-y: auto; flex: 1; }

    .wf-tip {
        position: relative; cursor: help; margin-left: 4px;
        color: var(--bs-secondary); font-size: 0.8rem; vertical-align: middle;
    }
    .wf-tip:hover { color: var(--bs-primary); }
    .wf-tip::after {
        content: attr(data-tip);
        position: absolute; bottom: calc(100% + 6px); left: 50%; transform: translateX(-50%);
        background: var(--bs-dark); color: #fff; font-size: 0.75rem; font-weight: 400;
        padding: 0.4rem 0.6rem; border-radius: 6px; line-height: 1.4;
        width: max-content; max-width: 280px; white-space: normal;
        pointer-events: none; opacity: 0; transition: opacity 0.15s;
        z-index: 9999; box-shadow: 0 2px 8px rgba(0,0,0,0.2);
    }
    .wf-tip:hover::after { opacity: 1; }
</style>

@code {
    [Parameter] public string Owner { get; set; } = "";
    [Parameter] public string RepoSlug { get; set; } = "";
    [Parameter] public string? WorkflowId { get; set; }
    [CascadingParameter(Name = "AccountId")] string AccountId { get; set; } = "";

    private GitWorkflow workflow = new();
    private GitRepository? repo;
    private bool isNew => string.IsNullOrEmpty(WorkflowId);
    private bool loading = true;
    private bool saving;
    private string? errorMessage;
    private int selectedStepIndex = -1;
    private bool showAddStepMenu;
    private int insertAtIndex;
    private string branchFilter = "";
    private List<string> repoSecrets = [];
    private string stepSearchQuery = "";

    private string triggerTypeStr
    {
        get => workflow.TriggerType.ToString();
        set { if (Enum.TryParse<GitTriggerType>(value, out var t)) workflow.TriggerType = t; }
    }

    private bool IsPushTrigger => workflow.TriggerType is GitTriggerType.PushToRef
        or GitTriggerType.BranchCreated or GitTriggerType.BranchDeleted
        or GitTriggerType.TagCreated or GitTriggerType.TagDeleted;

    protected override async Task OnParametersSetAsync()
    {
        loading = true;
        try
        {
            repo = await RepoService.GetRepositoryBySlugAsync(Owner, RepoSlug);
            if (repo != null)
                try { repoSecrets = await SecretService.ListSecretNamesAsync(repo.id); } catch { }
            if (!isNew && repo != null)
            {
                var wf = await WorkflowService.GetAsync(WorkflowId!, repo.AccountId);
                if (wf != null)
                {
                    workflow = wf;
                    branchFilter = wf.TriggerFilters?.GetValueOrDefault("branch", "") ?? "";
                }
            }
            else
            {
                workflow = new GitWorkflow
                {
                    AccountId = repo?.AccountId ?? "",
                    RepositoryId = repo?.id
                };
            }
        }
        catch { }
        loading = false;
    }

    private void SelectStep(int index)
    {
        selectedStepIndex = index;
        showAddStepMenu = false;
    }

    private void InsertStep(int index)
    {
        insertAtIndex = index;
        showAddStepMenu = true;
        stepSearchQuery = "";
        selectedStepIndex = -1;
    }

    private void AddStep(WorkflowStepType type, string name)
    {
        var step = new WorkflowStep
        {
            Order = insertAtIndex,
            Name = name,
            StepType = type,
            HttpMethod = type == WorkflowStepType.HttpRequest ? "POST" : null,
            RequiredApprovals = type == WorkflowStepType.RequireReview ? 1 : null
        };

        workflow.Steps.Insert(insertAtIndex, step);
        ReorderSteps();
        selectedStepIndex = insertAtIndex;
        showAddStepMenu = false;
    }

    private void RemoveStep(int index)
    {
        workflow.Steps.RemoveAt(index);
        ReorderSteps();
        if (selectedStepIndex == index) selectedStepIndex = -1;
        else if (selectedStepIndex > index) selectedStepIndex--;
    }

    private void ReorderSteps()
    {
        for (var i = 0; i < workflow.Steps.Count; i++)
            workflow.Steps[i].Order = i;
    }

    private async Task Save()
    {
        if (string.IsNullOrWhiteSpace(workflow.Name))
        {
            errorMessage = "Workflow name is required.";
            return;
        }

        saving = true;
        errorMessage = null;

        // Build trigger filters
        workflow.TriggerFilters = new();
        if (!string.IsNullOrWhiteSpace(branchFilter))
            workflow.TriggerFilters["branch"] = branchFilter.Trim();

        try
        {
            if (isNew)
            {
                workflow.AccountId = repo!.AccountId;
                workflow.RepositoryId = repo.id;
                await WorkflowService.CreateAsync(workflow);
            }
            else
            {
                await WorkflowService.UpdateAsync(workflow);
            }

            Nav.NavigateTo($"/{Owner}/{RepoSlug}/workflows");
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
        finally
        {
            saving = false;
        }
    }

    private static string StepIcon(WorkflowStepType type) => type switch
    {
        WorkflowStepType.HttpRequest => "🌐",
        WorkflowStepType.AddComment => "💬",
        WorkflowStepType.SetLabel => "🏷️",
        WorkflowStepType.RemoveLabel => "🏷️",
        WorkflowStepType.CloseIssue => "⊘",
        WorkflowStepType.ClosePullRequest => "⊘",
        WorkflowStepType.RequireReview => "✔",
        WorkflowStepType.Wait => "⏱",
        WorkflowStepType.DeployAzureWebApp => "☁",
        WorkflowStepType.Condition => "⑂",
        _ => "•"
    };

    private static string FormatStepType(WorkflowStepType type) => type switch
    {
        WorkflowStepType.HttpRequest => "HTTP Request",
        WorkflowStepType.AddComment => "Add Comment",
        WorkflowStepType.SetLabel => "Set Label",
        WorkflowStepType.RemoveLabel => "Remove Label",
        WorkflowStepType.CloseIssue => "Close Issue",
        WorkflowStepType.ClosePullRequest => "Close PR",
        WorkflowStepType.RequireReview => "Require Review",
        WorkflowStepType.Wait => "Wait",
        WorkflowStepType.DeployAzureWebApp => "Deploy to Azure",
        WorkflowStepType.Condition => "Condition",
        _ => type.ToString()
    };

    private static string FormatTriggerShort(GitTriggerType t) => t switch
    {
        GitTriggerType.PushToRef => "Push",
        GitTriggerType.BranchCreated => "Branch Created",
        GitTriggerType.PullRequestCreated => "PR Opened",
        GitTriggerType.PullRequestMerged => "PR Merged",
        GitTriggerType.PullRequestClosed => "PR Closed",
        GitTriggerType.IssueCreated => "Issue Opened",
        GitTriggerType.IssueClosed => "Issue Closed",
        GitTriggerType.CommentCreated => "Comment",
        GitTriggerType.ReviewSubmitted => "Review",
        _ => t.ToString()
    };

    private static MarkupString InfoTip(string text) =>
        new($"<span class=\"wf-tip\" data-tip=\"{System.Net.WebUtility.HtmlEncode(text)}\"><i class=\"fa-duotone fa-circle-info\"></i></span>");

    // ── Step catalog for the Add Step dialog ──

    private record StepEntry(WorkflowStepType Type, string Name, string Description, string Icon, string Color);
    private record StepGroup(string GroupName, StepEntry[] Steps);

    private bool MatchesSearch(StepEntry entry)
    {
        if (string.IsNullOrWhiteSpace(stepSearchQuery)) return true;
        var q = stepSearchQuery.Trim();
        return entry.Name.Contains(q, StringComparison.OrdinalIgnoreCase)
            || entry.Description.Contains(q, StringComparison.OrdinalIgnoreCase);
    }

