@page "/{Owner}/{RepoSlug}/workflows/{WorkflowId}/history"
@inject WorkflowService WorkflowService
@inject RepositoryService RepoService
@implements IDisposable
@using DaisiGit.Core.Models
@using DaisiGit.Core.Enums

<PageTitle>Workflow History - @Owner/@RepoSlug - Daisi Git</PageTitle>

<RepositoryLayout Owner="@Owner" RepoSlug="@RepoSlug" ActiveTab="workflows">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <a href="/@Owner/@RepoSlug/workflows" class="text-muted text-decoration-none">
                <i class="fa-duotone fa-arrow-left me-1"></i> Workflows
            </a>
            @if (workflowName != null)
            {
                <span class="text-muted mx-1">/</span>
                <span class="fw-semibold">@workflowName</span>
            }
        </div>
        @if (anyActive)
        {
            <span class="text-muted small"><i class="fa-duotone fa-rotate fa-spin me-1"></i> Live - refreshing every @RefreshSeconds s</span>
        }
    </div>

    <h5 class="mb-3">Execution History</h5>

    @if (loading)
    {
        <div class="text-center py-4"><div class="spinner-border spinner-border-sm text-primary"></div></div>
    }
    else if (executions.Count == 0)
    {
        <div class="text-center py-5 text-muted">
            <i class="fa-duotone fa-clock-rotate-left fa-2x mb-2 d-block"></i>
            <p>No executions yet. This workflow hasn't been triggered.</p>
        </div>
    }
    else
    {
        <div class="list-group">
            @foreach (var exec in executions)
            {
                <div class="list-group-item">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <div class="fw-semibold">
                                @StatusBadge(exec.Status)
                                <span class="ms-1">@exec.WorkflowName</span>
                                <span class="text-muted small ms-2">@exec.TriggerType</span>
                            </div>
                            <div class="text-muted small mt-1">
                                Step @exec.CurrentStepIndex / @exec.TotalSteps
                                <span class="ms-2">Duration: @FormatExecutionDuration(exec)</span>
                                @if (!string.IsNullOrEmpty(exec.Error))
                                {
                                    <span class="text-danger ms-2">@exec.Error</span>
                                }
                            </div>
                        </div>
                        <div class="text-muted small text-end">
                            <div>Started: @FormatLocal(exec.StartedUtc ?? exec.CreatedUtc)</div>
                            @if (exec.FinishedUtc != null)
                            {
                                <div>Finished: @FormatLocal(exec.FinishedUtc.Value)</div>
                            }
                            <button class="btn btn-sm btn-link p-0 ms-2 mt-1" @onclick="() => ToggleDetail(exec.id)">
                                <i class="fa-duotone fa-chevron-@(expandedId == exec.id ? "up" : "down")"></i>
                            </button>
                        </div>
                    </div>

                    @if (expandedId == exec.id)
                    {
                        <div class="mt-2 border-top pt-2">
                            @{
                                var rows = BuildStepRows(exec);
                            }
                            <table class="table table-sm table-borderless mb-0">
                                <thead>
                                    <tr class="text-muted small">
                                        <th style="width:3em;">#</th>
                                        <th>Step</th>
                                        <th style="width:5em;">Result</th>
                                        <th style="width:9em;">Started</th>
                                        <th style="width:9em;">Finished</th>
                                        <th style="width:7em;">Duration</th>
                                        <th>Detail</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var row in rows)
                                    {
                                        <tr>
                                            <td>@(row.Index + 1)</td>
                                            <td>@row.Label</td>
                                            <td>@StepStatusIcon(row.State)</td>
                                            <td class="text-muted small font-monospace">@FormatStepStart(row)</td>
                                            <td class="text-muted small font-monospace">@FormatStepEnd(row)</td>
                                            <td class="text-muted small font-monospace">@FormatStepDuration(row)</td>
                                            <td class="text-muted small">
                                                @if (row.Result is { } r)
                                                {
                                                    @if (r.HttpStatusCode.HasValue)
                                                    {
                                                        <span>HTTP @r.HttpStatusCode</span>
                                                    }
                                                    @if (!string.IsNullOrEmpty(r.Error))
                                                    {
                                                        <span class="text-danger">@r.Error</span>
                                                    }
                                                    @if (!string.IsNullOrEmpty(r.DeployUrl))
                                                    {
                                                        <a href="@r.DeployUrl" target="_blank" class="ms-1">@r.DeployUrl</a>
                                                    }
                                                    @if (r.ExitCode.HasValue)
                                                    {
                                                        <span class="ms-1">exit @r.ExitCode</span>
                                                    }
                                                    @if (!string.IsNullOrEmpty(r.ScriptOutput))
                                                    {
                                                        <details class="ms-1 d-inline"><summary class="d-inline small">output</summary><pre class="mt-1 p-2 bg-dark text-light rounded small" style="max-height:200px;overflow:auto;">@r.ScriptOutput</pre></details>
                                                    }
                                                    else if (!string.IsNullOrEmpty(r.RenderedBody))
                                                    {
                                                        <code class="ms-1">@Truncate(r.RenderedBody, 80)</code>
                                                    }
                                                }
                                                else if (row.State == StepState.Running)
                                                {
                                                    <span class="text-primary small">running...</span>
                                                }
                                                else if (row.State == StepState.Pending)
                                                {
                                                    <span class="text-muted small">queued</span>
                                                }
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            }
        </div>
    }
</RepositoryLayout>

@code {
    [Parameter] public string Owner { get; set; } = "";
    [Parameter] public string RepoSlug { get; set; } = "";
    [Parameter] public string WorkflowId { get; set; } = "";
    [CascadingParameter(Name = "AccountId")] string AccountId { get; set; } = "";

    private const int RefreshSeconds = 3;

    private List<WorkflowExecution> executions = [];
    private List<WorkflowStep> workflowSteps = [];
    private string? workflowName;
    private string? accountId;
    private bool loading = true;
    private string? expandedId;
    private System.Threading.Timer? refreshTimer;
    private bool anyActive;

    protected override async Task OnParametersSetAsync()
    {
        loading = true;
        try
        {
            var repo = await RepoService.GetRepositoryBySlugAsync(Owner, RepoSlug);
            if (repo != null)
            {
                accountId = repo.AccountId;
                var wf = await WorkflowService.GetAsync(WorkflowId, repo.AccountId);
                workflowName = wf?.Name;
                workflowSteps = wf?.Steps ?? [];
                executions = await WorkflowService.ListExecutionsAsync(repo.AccountId, workflowId: WorkflowId);
            }
        }
        catch { }
        loading = false;
        UpdateRefreshState();
    }

    private void UpdateRefreshState()
    {
        anyActive = executions.Any(e => e.Status is "Running" or "Dispatched");
        if (anyActive && refreshTimer == null && !disposed)
        {
            refreshTimer = new System.Threading.Timer(TimerTick,
                null, TimeSpan.FromSeconds(RefreshSeconds), TimeSpan.FromSeconds(RefreshSeconds));
        }
        else if (!anyActive && refreshTimer != null)
        {
            refreshTimer.Dispose();
            refreshTimer = null;
        }
    }

    private void TimerTick(object? _)
    {
        if (disposed) return;
        _ = InvokeAsync(async () =>
        {
            try { await RefreshExecutions(); }
            catch { /* Refresh is best-effort; never let it crash the circuit. */ }
        });
    }

    private async Task RefreshExecutions()
    {
        if (disposed || string.IsNullOrEmpty(accountId)) return;
        executions = await WorkflowService.ListExecutionsAsync(accountId, workflowId: WorkflowId);
        UpdateRefreshState();
        StateHasChanged();
    }

    private bool disposed;
    public void Dispose()
    {
        disposed = true;
        var t = refreshTimer;
        refreshTimer = null;
        t?.Dispose();
    }

    private void ToggleDetail(string id)
    {
        expandedId = expandedId == id ? null : id;
    }

    private List<StepRow> BuildStepRows(WorkflowExecution exec)
    {
        var rows = new List<StepRow>();
        var resultsByIndex = exec.StepResults.GroupBy(r => r.StepIndex)
            .ToDictionary(g => g.Key, g => g.Last());

        // Use the workflow's planned Steps for layout; fall back to whatever results we have if the
        // definition has changed since the execution started.
        var planned = workflowSteps.OrderBy(s => s.Order).ToList();
        var rowCount = Math.Max(planned.Count, exec.StepResults.Count == 0 ? 0 : exec.StepResults.Max(r => r.StepIndex) + 1);

        for (var i = 0; i < rowCount; i++)
        {
            var result = resultsByIndex.GetValueOrDefault(i);
            string label;
            if (result != null && !string.IsNullOrWhiteSpace(result.StepName))
                label = result.StepName;
            else if (i < planned.Count)
                label = string.IsNullOrWhiteSpace(planned[i].Name) ? planned[i].StepType.ToString() : planned[i].Name;
            else
                label = result?.StepType.ToString() ?? "(unknown)";

            StepState state;
            if (result != null) state = result.Success ? StepState.Ok : StepState.Failed;
            else if (exec.Status is "Running" && i == exec.CurrentStepIndex) state = StepState.Running;
            else if (exec.Status is "Failed" or "Cancelled") state = StepState.Skipped;
            else state = StepState.Pending;

            rows.Add(new StepRow(i, label, state, result));
        }
        return rows;
    }

    private static MarkupString StepStatusIcon(StepState state) => new(state switch
    {
        StepState.Ok => "<span class='text-success'><i class='fa-solid fa-check'></i></span>",
        StepState.Failed => "<span class='text-danger'><i class='fa-solid fa-xmark'></i></span>",
        StepState.Running => "<span class='text-primary'><i class='fa-solid fa-spinner fa-spin'></i></span>",
        StepState.Pending => "<span class='text-muted' title='Queued'><i class='fa-regular fa-hourglass'></i></span>",
        StepState.Skipped => "<span class='text-muted' title='Skipped after earlier failure'><i class='fa-regular fa-circle-minus'></i></span>",
        _ => ""
    });

    private static MarkupString StatusBadge(string status) => new(status switch
    {
        "Completed" => "<span class='badge bg-success'>Completed</span>",
        "Failed" => "<span class='badge bg-danger'>Failed</span>",
        "Running" => "<span class='badge bg-primary'>Running</span>",
        "Dispatched" => "<span class='badge bg-info text-dark'>Dispatched</span>",
        "Cancelled" => "<span class='badge bg-secondary'>Cancelled</span>",
        _ => $"<span class='badge bg-secondary'>{status}</span>"
    });

    private static string Truncate(string s, int max) =>
        s.Length <= max ? s : s[..max] + "...";

    private static string FormatLocal(DateTime utc) => utc.ToLocalTime().ToString("HH:mm:ss");

    private string FormatStepStart(StepRow row)
        => row.Result is { ExecutedUtc: var t } ? FormatLocal(t) : "-";

    private string FormatStepEnd(StepRow row)
    {
        if (row.Result?.FinishedUtc is { } end) return FormatLocal(end);
        if (row.State == StepState.Running) return "running...";
        return "-";
    }

    private string FormatStepDuration(StepRow row)
    {
        if (row.Result is null) return "-";
        var start = row.Result.ExecutedUtc;
        var end = row.Result.FinishedUtc ?? (row.State == StepState.Running ? DateTime.UtcNow : (DateTime?)null);
        return end is null ? "-" : FormatDuration(end.Value - start);
    }

    private static string FormatExecutionDuration(WorkflowExecution exec)
    {
        var start = exec.StartedUtc ?? exec.CreatedUtc;
        var end = exec.FinishedUtc ?? (exec.Status is "Running" or "Dispatched" ? DateTime.UtcNow : (DateTime?)null);
        return end is null ? "-" : FormatDuration(end.Value - start);
    }

    private static string FormatDuration(TimeSpan d)
    {
        if (d.TotalSeconds < 0) d = TimeSpan.Zero;
        if (d.TotalSeconds < 1) return $"{(int)d.TotalMilliseconds}ms";
        if (d.TotalMinutes < 1) return $"{d.TotalSeconds:0.0}s";
        if (d.TotalHours < 1) return $"{(int)d.TotalMinutes}m {d.Seconds}s";
        return $"{(int)d.TotalHours}h {d.Minutes}m";
    }

    private enum StepState { Pending, Running, Ok, Failed, Skipped }

    private record StepRow(int Index, string Label, StepState State, WorkflowStepResult? Result);
}
