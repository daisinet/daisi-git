@page "/{Owner}/{RepoSlug}/tree/{Branch}/{**Path}"
@page "/{Owner}/{RepoSlug}/tree/{Branch}"
@inject BrowseService BrowseService
@inject RepositoryService RepoService
@inject PermissionService PermissionService
@inject GitObjectStore ObjectStore
@inject GitRefService RefService
@inject NavigationManager Nav
@inject IJSRuntime JS

<PageTitle>@(string.IsNullOrEmpty(Path) ? $"{Owner}/{RepoSlug}" : $"{Path} - {Owner}/{RepoSlug}") - Daisi Git</PageTitle>

<RepositoryLayout Owner="@Owner" RepoSlug="@RepoSlug" ActiveTab="code" SelectedBranch="@Branch">
    @if (isEmpty && !loading)
    {
        <div class="text-center py-5 text-muted">
            <div class="mb-3"><i class="fa-duotone fa-folder-open" style="font-size: 3rem;"></i></div>
            <h5>This repository is empty</h5>
            <p>Get started by creating a README file or pushing code from the command line.</p>
            @if (canWrite)
            {
                <button type="button" class="btn btn-primary" @onclick="CreateReadme" @onclick:preventDefault disabled="@creatingReadme">
                    @if (creatingReadme) { <span class="spinner-border spinner-border-sm me-1"></span> }
                    <i class="fa-duotone fa-file-lines me-1"></i> Create README.md
                </button>
            }
            @if (!string.IsNullOrEmpty(readmeError))
            {
                <div class="alert alert-danger mt-3">@readmeError</div>
            }
            @if (readmeCreated)
            {
                <div class="alert alert-success mt-3">README.md created! Reloading...</div>
            }
        </div>
    }
    else if (browseResult != null)
    {
        <!-- Branch selector + path breadcrumb + clone button -->
        <div class="d-flex align-items-center gap-2 mb-3">
            <div class="dropdown">
                <button class="btn btn-sm btn-outline-secondary dropdown-toggle" type="button" data-bs-toggle="dropdown">
                    <i class="fa-duotone fa-code-branch me-1"></i> @Branch
                </button>
                <ul class="dropdown-menu">
                    @foreach (var b in branches)
                    {
                        <li>
                            <a class="dropdown-item @(b == Branch ? "active" : "")"
                               href="/@Owner/@RepoSlug/tree/@b/@Path">@b</a>
                        </li>
                    }
                </ul>
            </div>

            <!-- Breadcrumb -->
            @if (!string.IsNullOrEmpty(Path))
            {
                <nav aria-label="breadcrumb" class="flex-grow-1">
                    <ol class="breadcrumb mb-0">
                        <li class="breadcrumb-item">
                            <a href="/@Owner/@RepoSlug/tree/@Branch">@RepoSlug</a>
                        </li>
                        @{
                            var segments = Path.Trim('/').Split('/');
                            var accumulated = "";
                            for (var i = 0; i < segments.Length; i++)
                            {
                                accumulated = string.IsNullOrEmpty(accumulated) ? segments[i] : $"{accumulated}/{segments[i]}";
                                var isLast = i == segments.Length - 1;
                                if (isLast)
                                {
                                    <li class="breadcrumb-item active">@segments[i]</li>
                                }
                                else
                                {
                                    var linkPath = accumulated;
                                    <li class="breadcrumb-item">
                                        <a href="/@Owner/@RepoSlug/tree/@Branch/@linkPath">@segments[i]</a>
                                    </li>
                                }
                            }
                        }
                    </ol>
                </nav>
            }
            else
            {
                <div class="flex-grow-1"></div>
            }

            <!-- Clone button -->
            <button type="button" class="btn btn-sm btn-success" @onclick="() => showCloneDialog = true">
                <i class="fa-duotone fa-clone me-1"></i> Clone
            </button>
        </div>

        <!-- Clone dialog -->
        @if (showCloneDialog)
        {
            var baseUrl = Nav.BaseUri.TrimEnd('/');
            var httpsUrl = $"{baseUrl}/{Owner}/{RepoSlug}.git";

            <div class="modal d-block" tabindex="-1" style="background: rgba(0,0,0,0.4);">
                <div class="modal-dialog modal-dialog-centered">
                    <div class="modal-content">
                        <div class="modal-header">
                            <h5 class="modal-title"><i class="fa-duotone fa-clone me-1"></i> Clone repository</h5>
                            <button type="button" class="btn-close" @onclick="() => showCloneDialog = false"></button>
                        </div>
                        <div class="modal-body">
                            <div class="mb-3">
                                <label class="form-label fw-semibold">HTTPS</label>
                                <div class="input-group input-group-sm">
                                    <input type="text" class="form-control font-monospace" readonly value="@httpsUrl" />
                                    <button class="btn @(copySuccess == true ? "btn-success" : copySuccess == false ? "btn-danger" : "btn-outline-secondary")"
                                            type="button" @onclick="() => CopyToClipboard(httpsUrl)">
                                        <i class="fa-duotone @(copySuccess == true ? "fa-check" : copySuccess == false ? "fa-xmark" : "fa-copy")"></i>
                                    </button>
                                </div>
                            </div>

                            <hr />

                            <div class="mb-3">
                                <label class="form-label fw-semibold small text-muted">Clone with Git</label>
                                <div class="bg-dark text-light p-2 rounded font-monospace small">
                                    git clone @httpsUrl
                                </div>
                            </div>

                            <div class="mb-3">
                                <label class="form-label fw-semibold small text-muted">Clone with DaisiGit CLI</label>
                                <div class="bg-dark text-light p-2 rounded font-monospace small">
                                    dg clone @Owner/@RepoSlug
                                </div>
                            </div>

                            <div class="mb-3">
                                <label class="form-label fw-semibold small text-muted">Open in VS Code</label>
                                <div class="bg-dark text-light p-2 rounded font-monospace small">
                                    git clone @httpsUrl && code @RepoSlug
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }

        @if (browseResult.IsFile)
        {
            <!-- File view — redirect to blob page -->
            Nav.NavigateTo($"/{Owner}/{RepoSlug}/blob/{Branch}/{Path}", replace: true);
        }
        else
        {
            <!-- Tree (directory) listing -->
            <div class="card">
                @if (lastCommit != null)
                {
                    <div class="card-header bg-light d-flex align-items-center gap-2">
                        <strong class="text-truncate">@lastCommit.AuthorName</strong>
                        <span class="text-muted text-truncate flex-grow-1">@lastCommit.MessageFirstLine</span>
                        <a href="/@Owner/@RepoSlug/commit/@lastCommit.Sha" class="text-muted text-nowrap">
                            <code>@lastCommit.ShortSha</code>
                        </a>
                        <span class="text-muted text-nowrap">@FormatRelativeDate(lastCommit.AuthorDate)</span>
                    </div>
                }
                <div class="list-group list-group-flush">
                    @if (!string.IsNullOrEmpty(Path))
                    {
                        var parentPath = string.Join("/", Path.Trim('/').Split('/').SkipLast(1));
                        <a href="/@Owner/@RepoSlug/tree/@Branch/@parentPath" class="list-group-item list-group-item-action dg-tree-entry">
                            <i class="fa-duotone fa-arrow-up text-muted dg-tree-icon"></i>
                            <span>..</span>
                        </a>
                    }
                    @foreach (var entry in browseResult.Entries)
                    {
                        var entryPath = string.IsNullOrEmpty(Path) ? entry.Name : $"{Path.TrimEnd('/')}/{entry.Name}";
                        var linkType = entry.IsTree ? "tree" : "blob";
                        <a href="/@Owner/@RepoSlug/@linkType/@Branch/@entryPath"
                           class="list-group-item list-group-item-action dg-tree-entry">
                            @if (entry.IsTree)
                            {
                                <i class="fa-duotone fa-folder text-primary dg-tree-icon"></i>
                            }
                            else
                            {
                                <i class="fa-duotone fa-file-code text-muted dg-tree-icon"></i>
                            }
                            <span>@entry.Name</span>
                        </a>
                    }
                </div>
            </div>

            @* README / LICENSE tabs below file list (root only) *@
            @if (string.IsNullOrEmpty(Path) && (readmeContent != null || licenseContent != null))
            {
                <div class="mt-3">
                    <ul class="nav nav-tabs">
                        @if (readmeContent != null)
                        {
                            <li class="nav-item">
                                <button type="button" class="nav-link @(docTab == "readme" ? "active" : "")"
                                        @onclick='() => docTab = "readme"'>
                                    <i class="fa-duotone fa-book me-1"></i> @readmeFileName
                                </button>
                            </li>
                        }
                        @if (licenseContent != null)
                        {
                            <li class="nav-item">
                                <button type="button" class="nav-link @(docTab == "license" ? "active" : "")"
                                        @onclick='() => docTab = "license"'>
                                    <i class="fa-duotone fa-scale-balanced me-1"></i> @licenseFileName
                                </button>
                            </li>
                        }
                    </ul>
                    <div class="card border-top-0 rounded-top-0">
                        <div class="card-body">
                            @if (docTab == "readme" && readmeContent != null)
                            {
                                @if (readmeFileName?.EndsWith(".md", StringComparison.OrdinalIgnoreCase) == true)
                                {
                                    <MarkdownView Content="@readmeContent" />
                                }
                                else
                                {
                                    <pre style="white-space: pre-wrap; font-family: inherit; margin: 0;">@readmeContent</pre>
                                }
                            }
                            else if (docTab == "license" && licenseContent != null)
                            {
                                @if (licenseFileName?.EndsWith(".md", StringComparison.OrdinalIgnoreCase) == true)
                                {
                                    <MarkdownView Content="@licenseContent" />
                                }
                                else
                                {
                                    <pre style="white-space: pre-wrap; font-family: inherit; margin: 0;">@licenseContent</pre>
                                }
                            }
                        </div>
                    </div>
                </div>
            }
        }
    }
</RepositoryLayout>

@code {
    [Parameter] public string Owner { get; set; } = "";
    [Parameter] public string RepoSlug { get; set; } = "";
    [Parameter] public string Branch { get; set; } = "main";
    [Parameter] public string? Path { get; set; }

    [CascadingParameter(Name = "UserId")] string UserId { get; set; } = "";
    [CascadingParameter(Name = "UserName")] string UserName { get; set; } = "";

    private GitRepository? repo;
    private BrowseResult? browseResult;
    private CommitInfo? lastCommit;
    private List<string> branches = [];
    private bool loading = true;
    private bool isEmpty;
    private bool canWrite;
    private bool creatingReadme;
    private bool showCloneDialog;
    private bool? copySuccess;
    private string? readmeContent;
    private string? readmeFileName;
    private string? licenseContent;
    private string? licenseFileName;
    private string docTab = "readme";
    private string? readmeError;
    private bool readmeCreated;

    protected override async Task OnParametersSetAsync()
    {
        loading = true;
        try
        {
            repo = await RepoService.GetRepositoryBySlugAsync(Owner, RepoSlug);
            if (repo == null) { loading = false; return; }

            if (!string.IsNullOrEmpty(UserId))
                canWrite = await PermissionService.CanWriteAsync(UserId, repo);

            // Load branches
            var refs = await BrowseService.GetBranchesAsync(repo.id, repo.DefaultBranch);
            branches = refs.Select(b => b.Name).ToList();

            // Resolve branch to SHA
            var commitSha = await BrowseService.ResolveRefAsync(repo.id, Branch);
            if (commitSha == null) { isEmpty = true; loading = false; return; }

            browseResult = await BrowseService.GetTreeAtPathAsync(repo.id, commitSha, Path ?? "");

            // Empty repo = null result or root tree with no entries
            isEmpty = browseResult == null
                || (!browseResult.IsFile && string.IsNullOrEmpty(Path) && browseResult.Entries.Count == 0);

            // If it resolved to a file, redirect to blob view
            if (browseResult is { IsFile: true })
            {
                loading = false;
                return;
            }

            // Get last commit for header
            var commits = await BrowseService.GetCommitLogAsync(repo.id, commitSha, 1);
            lastCommit = commits.FirstOrDefault();

            // Load README and LICENSE at root
            if (string.IsNullOrEmpty(Path) && browseResult?.Entries != null)
            {
                await LoadDocFileAsync(repo.id, browseResult, "README.md", "README", "README.txt",
                    (name, content) => { readmeFileName = name; readmeContent = content; });
                await LoadDocFileAsync(repo.id, browseResult, "LICENSE", "LICENSE.md", "LICENSE.txt",
                    (name, content) => { licenseFileName = name; licenseContent = content; });

                docTab = readmeContent != null ? "readme" : licenseContent != null ? "license" : "readme";
            }
        }
        catch { }
        loading = false;
    }

    private async Task CreateReadme()
    {
        if (repo == null) return;
        creatingReadme = true;
        try
        {
            var readmeContent = $"# {repo.Name}\n\n{repo.Description ?? "A new repository."}\n";
            var readmeBytes = System.Text.Encoding.UTF8.GetBytes(readmeContent);

            // Create blob
            var blob = new DaisiGit.Core.Git.GitBlob { Data = readmeBytes };
            var blobSha = await ObjectStore.StoreObjectAsync(repo, blob);

            // Create tree with README.md entry
            var tree = new DaisiGit.Core.Git.GitTree
            {
                Entries = [new DaisiGit.Core.Git.GitTreeEntry { Name = "README.md", Mode = "100644", Sha = blobSha }]
            };
            var treeSha = await ObjectStore.StoreObjectAsync(repo, tree);

            // Get current HEAD commit as parent
            var headSha = await RefService.ResolveHeadAsync(repo.id);
            var parentShas = headSha != null ? new List<string> { headSha } : new List<string>();

            // Create commit
            var signature = new DaisiGit.Core.Git.GitSignature
            {
                Name = UserName,
                Email = $"{UserName}@daisigit.local",
                Timestamp = DateTimeOffset.UtcNow
            };
            var commit = new DaisiGit.Core.Git.GitCommit
            {
                TreeSha = treeSha,
                ParentShas = parentShas,
                Author = signature,
                Committer = signature,
                Message = "Add README.md\n"
            };
            var commitSha = await ObjectStore.StoreObjectAsync(repo, commit);

            // Update ref
            await RefService.SetRefAsync(repo.id, $"refs/heads/{repo.DefaultBranch}", commitSha);

            // Mark repo as non-empty
            if (repo.IsEmpty)
            {
                repo.IsEmpty = false;
                await RepoService.UpdateRepositoryAsync(repo);
            }

            // Verify the commit was stored and can be read back
            var verifyObj = await ObjectStore.GetObjectAsync(repo.id, commitSha);
            var verifyRef = await RefService.GetRefAsync(repo.id, $"refs/heads/{repo.DefaultBranch}");

            // Refresh data in place
            isEmpty = false;
            var refBranch = string.IsNullOrEmpty(Branch) ? repo.DefaultBranch : Branch;
            var newCommitSha = await BrowseService.ResolveRefAsync(repo.id, refBranch);
            if (newCommitSha != null)
            {
                browseResult = await BrowseService.GetTreeAtPathAsync(repo.id, newCommitSha, "");
                var commits = await BrowseService.GetCommitLogAsync(repo.id, newCommitSha, 1);
                lastCommit = commits.FirstOrDefault();
                readmeCreated = false;
            }
            else
            {
                readmeError = $"README committed (sha={commitSha[..7]}) but ref resolve failed. " +
                    $"Ref target={verifyRef?[..7] ?? "null"}, object readable={verifyObj != null}, branch={refBranch}";
            }
        }
        catch (Exception ex)
        {
            readmeError = $"Failed to create README: {ex.Message}";
        }
        finally
        {
            creatingReadme = false;
        }
    }

    private async Task LoadDocFileAsync(string repoId, BrowseResult tree, string name1, string name2, string name3,
        Action<string, string> setter)
    {
        foreach (var name in new[] { name1, name2, name3 })
        {
            var entry = tree.Entries.FirstOrDefault(e =>
                !e.IsTree && string.Equals(e.Name, name, StringComparison.OrdinalIgnoreCase));
            if (entry != null)
            {
                try
                {
                    var content = await BrowseService.GetFileContentAsync(repoId, entry.Sha);
                    if (content is { IsBinary: false, Text: not null })
                    {
                        setter(entry.Name, content.Text);
                        return;
                    }
                }
                catch { }
            }
        }
    }

    private async Task CopyToClipboard(string text)
    {
        try
        {
            await JS.InvokeVoidAsync("navigator.clipboard.writeText", text);
            copySuccess = true;
        }
        catch
        {
            copySuccess = false;
        }
        StateHasChanged();
        await Task.Delay(2000);
        copySuccess = null;
    }

    private static string FormatRelativeDate(DateTimeOffset date)
    {
        var diff = DateTimeOffset.UtcNow - date;
        if (diff.TotalMinutes < 1) return "just now";
        if (diff.TotalHours < 1) return $"{(int)diff.TotalMinutes}m ago";
        if (diff.TotalDays < 1) return $"{(int)diff.TotalHours}h ago";
        if (diff.TotalDays < 30) return $"{(int)diff.TotalDays}d ago";
        if (diff.TotalDays < 365) return $"{(int)(diff.TotalDays / 30)}mo ago";
        return $"{(int)(diff.TotalDays / 365)}y ago";
    }
}
