<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <system.webServer>
    <security>
      <requestFiltering>
        <!-- Allow file extensions in URL paths that IIS blocks by default.
             Required for the blob API: /api/git/repos/{owner}/{slug}/blob/{branch}/{path}
             where path can contain .cs, .config, .json, etc. -->
        <fileExtensions allowUnlisted="true">
          <remove fileExtension=".cs" />
          <remove fileExtension=".config" />
          <remove fileExtension=".asax" />
          <remove fileExtension=".csproj" />
          <remove fileExtension=".vb" />
          <remove fileExtension=".resx" />
          <remove fileExtension=".sln" />
        </fileExtensions>
        <hiddenSegments>
          <remove segment="bin" />
        </hiddenSegments>
      </requestFiltering>
    </security>
  </system.webServer>
</configuration>
