    // ── Output popover ──

    private void ToggleOutputPopover(int idx) =>
        outputPopoverIndex = outputPopoverIndex == idx ? -1 : idx;

    private List<string> GetOutputFields(WorkflowStep step, int idx)
    {
        var prefix = !string.IsNullOrEmpty(step.Name) ? $"steps.{step.Name}" : $"steps.{idx}";
        var fields = new List<string> { $"{{{{{prefix}.success}}}}" };

        switch (step.StepType)
        {
            case WorkflowStepType.HttpRequest:
                fields.Add($"{{{{{prefix}.status}}}}");
                fields.Add($"{{{{{prefix}.response}}}}");
                break;
            case WorkflowStepType.RunScript:
            case WorkflowStepType.RunMinion:
                fields.Add($"{{{{{prefix}.exitCode}}}}");
                fields.Add($"{{{{{prefix}.output}}}}");
                break;
            case WorkflowStepType.DeployAzureWebApp:
                fields.Add($"{{{{{prefix}.deployUrl}}}}");
                break;
            case WorkflowStepType.AddComment:
            case WorkflowStepType.SetLabel:
            case WorkflowStepType.RemoveLabel:
            case WorkflowStepType.SendEmail:
                fields.Add($"{{{{{prefix}.body}}}}");
                break;
            case WorkflowStepType.Checkout:
                fields.Add($"{{{{{prefix}.body}}}}");
                break;
            case WorkflowStepType.ImportFromUrl:
                fields.Add($"{{{{{prefix}.body}}}}");
                break;
        }

        fields.Add($"{{{{{prefix}.error}}}}");
        return fields;
    }

    // ── Branch filter autocomplete ──

    private Task<IEnumerable<string>> SearchCurrentRepoBranches(string? value, CancellationToken ct)
    {
        var available = currentRepoBranches.Where(b => !branchFilterList.Contains(b));
        if (string.IsNullOrWhiteSpace(value))
            return Task.FromResult(available);
        return Task.FromResult(available.Where(b => b.Contains(value, StringComparison.OrdinalIgnoreCase)));
    }

    private void RemoveBranchFilter(string branch)
    {
        branchFilterList.Remove(branch);
    }

    // ── Checkout autocomplete helpers ──

    private Task<IEnumerable<string>> SearchRepos(string? value, CancellationToken ct)
    {
        var slugs = accountRepos.Select(r => $"{r.OwnerName}/{r.Slug}");
        if (string.IsNullOrWhiteSpace(value))
            return Task.FromResult(slugs);
        return Task.FromResult(slugs.Where(s => s.Contains(value, StringComparison.OrdinalIgnoreCase)));
    }

    private async Task<IEnumerable<string>> SearchBranches(string? value, string? repoSlug, CancellationToken ct)
    {
        if (string.IsNullOrWhiteSpace(repoSlug))
            return [];

        if (!branchCache.TryGetValue(repoSlug, out var branches))
        {
            branches = await LoadBranchesAsync(repoSlug);
            branchCache[repoSlug] = branches;
        }

        if (string.IsNullOrWhiteSpace(value))
            return branches;
        return branches.Where(b => b.Contains(value, StringComparison.OrdinalIgnoreCase));
    }

    private async Task<List<string>> LoadBranchesAsync(string repoSlug)
    {
        try
        {
            var parts = repoSlug.Split('/', 2);
            if (parts.Length != 2) return [];
            var target = await RepoService.GetRepositoryBySlugAsync(parts[0], parts[1]);
            if (target == null) return [];
            var branchInfos = await BrowseService.GetBranchesAsync(target.id, target.DefaultBranch);
            return branchInfos.Select(b => b.Name).ToList();
        }
        catch { return []; }
    }

    private static bool IsInternalRepo(string? value) =>
        !string.IsNullOrWhiteSpace(value) &&
        !value.StartsWith("https://", StringComparison.OrdinalIgnoreCase) &&
        !value.StartsWith("http://", StringComparison.OrdinalIgnoreCase) &&
        !value.StartsWith("git://", StringComparison.OrdinalIgnoreCase);

    private void OnCheckoutRepoChanged(WorkflowStep step)
    {
        // Clear branch cache + selection when repo changes
        step.CheckoutBranch = null;
    }

    // ── Step catalog for the Add Step dialog ──

    // Context flags for step availability based on trigger type
    [Flags] enum StepContext { Any = 0, PR = 1, Issue = 2, PROrIssue = PR | Issue }

    private record StepEntry(WorkflowStepType Type, string Name, string Description, string Icon, string Color, StepContext Requires = StepContext.Any);
    private record StepGroup(string GroupName, string ShortName, string Icon, string Color, StepEntry[] Steps);

    private string? selectedGroup;

    private StepContext CurrentTriggerContext => workflow.TriggerType switch
    {
        GitTriggerType.PullRequestCreated or GitTriggerType.PullRequestUpdated
            or GitTriggerType.PullRequestClosed or GitTriggerType.PullRequestMerged
            or GitTriggerType.ReviewSubmitted or GitTriggerType.ReviewDismissed
            => StepContext.PR | StepContext.Issue, // PR context includes issue-like operations (comments, labels)
        GitTriggerType.IssueCreated or GitTriggerType.IssueClosed or GitTriggerType.IssueReopened
            => StepContext.Issue,
        GitTriggerType.CommentCreated
            => StepContext.PR | StepContext.Issue, // comments can be on either
        _ => StepContext.Any // push, branch, tag, fork — no PR/issue context
    };

    private bool IsStepAvailable(StepEntry entry)
    {
        if (entry.Requires == StepContext.Any) return true;
        var ctx = CurrentTriggerContext;
        if (ctx == StepContext.Any) return false; // trigger has no PR/issue context but step needs one
        return (ctx & entry.Requires) != 0;
    }

    private IEnumerable<StepGroup> AvailableGroups =>
        StepCatalog.Where(g => g.Steps.Any(IsStepAvailable));

    private IEnumerable<StepGroup> FilteredCatalog =>
        StepCatalog
            .Where(g => selectedGroup == null || g.GroupName == selectedGroup)
            .Select(g => g with { Steps = g.Steps.Where(s => IsStepAvailable(s) && MatchesSearch(s)).ToArray() })
            .Where(g => g.Steps.Length > 0);

    private bool MatchesSearch(StepEntry entry)
    {
        if (string.IsNullOrWhiteSpace(stepSearchQuery)) return true;
        var q = stepSearchQuery.Trim();
        return entry.Name.Contains(q, StringComparison.OrdinalIgnoreCase)
            || entry.Description.Contains(q, StringComparison.OrdinalIgnoreCase);
    }

