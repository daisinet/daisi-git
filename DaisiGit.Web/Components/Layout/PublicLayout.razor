@inherits LayoutComponentBase
@inject NavigationManager Nav

<nav style="background: #1a1a2e; border-bottom: 1px solid rgba(255,255,255,0.1);">
    <div class="container d-flex align-items-center justify-content-between py-3">
        <a href="/welcome" class="text-decoration-none d-flex align-items-center">
            <img src="images/daisi-logo-color-white.svg" alt="Daisi Git" style="height: 24px;" />
            <span class="ms-2" style="font-family: 'Anta', system-ui; color: #F78C1D; font-size: 1.1rem;">GIT</span>
        </a>
        <div class="d-flex gap-2">
            <a href="/explore" class="btn btn-sm btn-outline-light">Explore</a>
            <a href="@loginUrl" class="btn btn-sm text-white" style="background: #F78C1D; border: none;">Sign In</a>
        </div>
    </div>
</nav>

@Body

@code {
    private string loginUrl = "/";

    protected override void OnInitialized()
    {
        var appUrl = Daisi.SDK.Models.DaisiStaticSettings.SsoAppUrl;
        var authorityUrl = Daisi.SDK.Models.DaisiStaticSettings.SsoAuthorityUrl;

        if (!string.IsNullOrEmpty(authorityUrl) && !string.IsNullOrEmpty(appUrl))
        {
            var callbackUrl = Uri.EscapeDataString($"{appUrl}/sso/callback");
            var origin = Uri.EscapeDataString(appUrl);
            loginUrl = $"{authorityUrl}/sso/authorize?returnUrl={callbackUrl}&origin={origin}";
        }
    }
}
