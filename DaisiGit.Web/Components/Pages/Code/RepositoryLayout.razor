@inject RepositoryService RepoService
@inject GitRefService RefService
@inject BrowseService BrowseService
@inject OrganizationService OrgService
@inject UserProfileService ProfileService
@inject PermissionService PermissionService
@inject NavigationManager Nav

@if (loading)
{
    <div class="text-center py-5">
        <div class="spinner-border text-primary" role="status">
            <span class="visually-hidden">Loading...</span>
        </div>
    </div>
}
else if (Repository == null || !hasAccess)
{
    <div class="text-center py-5">
        <h4 class="text-muted">Repository not found</h4>
        <p class="text-muted">@Owner/@RepoSlug does not exist or you don't have access.</p>
        @if (!isLoggedIn)
        {
            <a href="/" class="btn btn-primary mt-2">Sign in</a>
        }
    </div>
}
else
{
    <!-- Repo header -->
    <div class="repo-header">
        <div class="d-flex justify-content-between align-items-start mb-3">
            <div>
                <h3 class="mb-1 d-flex align-items-center gap-2">
                    <OwnerAvatar OwnerName="@Owner" Size="28" />
                    <a href="/@Owner" class="text-muted text-decoration-none">@Owner</a>
                    <span class="text-muted mx-1">/</span>
                    <a href="/@Owner/@RepoSlug" class="text-decoration-none"><strong>@Repository.Name</strong></a>
                    <span class="text-muted mx-1">/</span>
                    <div class="dropdown d-inline-block">
                        <a class="text-decoration-none dropdown-toggle" href="#" role="button"
                           data-bs-toggle="dropdown" aria-expanded="false">@SelectedBranch</a>
                        <ul class="dropdown-menu" style="max-height: 300px; overflow-y: auto;">
                            @foreach (var branch in branches)
                            {
                                var bName = branch;
                                <li>
                                    <a class="dropdown-item @(bName == SelectedBranch ? "active" : "")"
                                       href="/@Owner/@RepoSlug/tree/@bName">@bName</a>
                                </li>
                            }
                            @if (branches.Count == 0)
                            {
                                <li><span class="dropdown-item text-muted">No branches</span></li>
                            }
                        </ul>
                    </div>
                </h3>
                @if (!string.IsNullOrEmpty(Repository.Description))
                {
                    <p class="text-muted mb-0">@Repository.Description</p>
                }
            </div>
            <div class="d-flex align-items-center gap-2">
                @if (isLoggedIn)
                {
                    <button class="btn btn-sm btn-outline-secondary" @onclick="ToggleStar" title="@(hasStarred ? "Unstar" : "Star")">
                        <i class="@(hasStarred ? "fa-solid" : "fa-regular") fa-star me-1"></i> @Repository.StarCount
                    </button>
                    <button class="btn btn-sm btn-outline-secondary" @onclick="ShowForkDialog" title="Fork">
                        <i class="fa-duotone fa-code-fork me-1"></i> @Repository.ForkCount
                    </button>
                }
                else
                {
                    <span class="btn btn-sm btn-outline-secondary disabled">
                        <i class="fa-regular fa-star me-1"></i> @Repository.StarCount
                    </span>
                    <span class="btn btn-sm btn-outline-secondary disabled">
                        <i class="fa-duotone fa-code-fork me-1"></i> @Repository.ForkCount
                    </span>
                }
                <span class="badge bg-@(Repository.Visibility == GitRepoVisibility.Public ? "success" : Repository.Visibility == GitRepoVisibility.Internal ? "warning" : "secondary")">
                    @Repository.Visibility
                </span>
            </div>
        </div>

        @if (!string.IsNullOrEmpty(Repository.ForkedFromId))
        {
            <p class="text-muted small mb-2">
                <i class="fa-duotone fa-code-fork me-1"></i> Forked from
                <a href="/@Repository.ForkedFromOwnerName/@Repository.ForkedFromSlug">@Repository.ForkedFromOwnerName/@Repository.ForkedFromSlug</a>
            </p>
        }

        <!-- Tabs -->
        <ul class="nav nav-tabs mb-0">
            <li class="nav-item">
                <a class="nav-link @(ActiveTab == "code" ? "active" : "")" href="/@Owner/@RepoSlug/tree/@SelectedBranch">
                    <i class="fa-duotone fa-code me-1"></i> Code
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link @(ActiveTab == "commits" ? "active" : "")" href="/@Owner/@RepoSlug/commits/@SelectedBranch">
                    <i class="fa-duotone fa-clock-rotate-left me-1"></i> Commits
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link @(ActiveTab == "branches" ? "active" : "")" href="/@Owner/@RepoSlug/branches">
                    <i class="fa-duotone fa-code-branch me-1"></i> Branches
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link @(ActiveTab == "pulls" ? "active" : "")" href="/@Owner/@RepoSlug/pulls">
                    <i class="fa-duotone fa-code-pull-request me-1"></i> Pull Requests
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link @(ActiveTab == "issues" ? "active" : "")" href="/@Owner/@RepoSlug/issues">
                    <i class="fa-duotone fa-circle-dot me-1"></i> Issues
                </a>
            </li>
            @if (isLoggedIn)
            {
                <li class="nav-item">
                    <a class="nav-link @(ActiveTab == "workflows" ? "active" : "")" href="/@Owner/@RepoSlug/workflows">
                        <i class="fa-duotone fa-bolt me-1"></i> Workflows
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link @(ActiveTab == "settings" ? "active" : "")" href="/@Owner/@RepoSlug/settings">
                        <i class="fa-duotone fa-gear me-1"></i> Settings
                    </a>
                </li>
            }
        </ul>
    </div>

    <!-- Tab content -->
    <div class="mt-3">
        @ChildContent
    </div>

    <!-- Fork dialog -->
    @if (showForkConfirm)
    {
        <div class="modal d-block" tabindex="-1" style="background: rgba(0,0,0,0.4);">
            <div class="modal-dialog modal-sm modal-dialog-centered">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title"><i class="fa-duotone fa-code-fork me-1"></i> Fork @Repository.Name</h5>
                        <button type="button" class="btn-close" @onclick="() => showForkConfirm = false"></button>
                    </div>
                    <div class="modal-body">
                        <label class="form-label">Fork to</label>
                        <select class="form-select" @bind="forkOwner">
                            @if (!string.IsNullOrEmpty(userHandle))
                            {
                                <option value="@userHandle">@userHandle (personal)</option>
                            }
                            @foreach (var org in forkOrgs)
                            {
                                <option value="@org.Slug">@org.Slug (@org.Name)</option>
                            }
                        </select>
                        <div class="form-text mt-2">
                            The repository will be forked as <strong>@forkOwner/@(Slugify(Repository.Name))</strong>
                        </div>
                        @if (!string.IsNullOrEmpty(forkError))
                        {
                            <div class="alert alert-danger mt-2 mb-0 py-2 small">@forkError</div>
                        }
                    </div>
                    <div class="modal-footer">
                        <button class="btn btn-outline-secondary btn-sm" @onclick="() => showForkConfirm = false">Cancel</button>
                        <button class="btn btn-success btn-sm" @onclick="ForkRepo" disabled="@forking">
                            @if (forking) { <span class="spinner-border spinner-border-sm me-1"></span> }
                            Create Fork
                        </button>
                    </div>
                </div>
            </div>
        </div>
    }
}

@code {
    [Parameter] public string Owner { get; set; } = "";
    [Parameter] public string RepoSlug { get; set; } = "";
    [Parameter] public string ActiveTab { get; set; } = "code";
    [Parameter] public string SelectedBranch { get; set; } = "main";
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [CascadingParameter(Name = "UserId")] string UserId { get; set; } = "";
    [CascadingParameter(Name = "UserName")] string UserName { get; set; } = "";
    [CascadingParameter(Name = "AccountId")] string AccountId { get; set; } = "";

    public GitRepository? Repository { get; private set; }
    private bool loading = true;
    private bool isLoggedIn;
    private bool hasAccess = true;
    private bool hasStarred;
    private bool showForkConfirm;
    private bool forking;
    private string forkOwner = "";
    private string? forkError;
    private string? userHandle;
    private List<GitOrganization> forkOrgs = [];
    private List<string> branches = [];
    private bool branchesLoaded;
    private string? loadedOwner;
    private string? loadedSlug;

    protected override async Task OnParametersSetAsync()
    {
        // Only reload when the route actually changes
        if (loadedOwner == Owner && loadedSlug == RepoSlug)
            return;

        loadedOwner = Owner;
        loadedSlug = RepoSlug;
        loading = true;
        branchesLoaded = false;
        isLoggedIn = !string.IsNullOrEmpty(UserId);
        try
        {
            Repository = await RepoService.GetRepositoryBySlugAsync(Owner, RepoSlug);
            if (Repository != null)
            {
                // Check read permission
                hasAccess = await PermissionService.CanReadAsync(UserId ?? "", Repository);
                if (!hasAccess) { loading = false; return; }

                if (string.IsNullOrEmpty(SelectedBranch))
                    SelectedBranch = Repository.DefaultBranch;
                if (!string.IsNullOrEmpty(UserId))
                    hasStarred = await RepoService.HasStarredAsync(UserId, Repository.id);
                await LoadBranches();
            }
        }
        catch { }
        loading = false;
    }

    private async Task LoadBranches()
    {
        if (branchesLoaded || Repository == null) return;
        branchesLoaded = true;
        try
        {
            var refs = await RefService.GetAllRefsAsync(Repository.id);
            branches = refs.Keys
                .Where(r => r.StartsWith("refs/heads/"))
                .Select(r => r["refs/heads/".Length..])
                .OrderByDescending(b => b == Repository.DefaultBranch)
                .ThenBy(b => b)
                .ToList();
        }
        catch { }
    }

    private async Task ToggleStar()
    {
        if (Repository == null) return;
        if (hasStarred)
        {
            await RepoService.UnstarAsync(UserId, Repository.id);
            Repository.StarCount = Math.Max(0, Repository.StarCount - 1);
            hasStarred = false;
        }
        else
        {
            await RepoService.StarAsync(UserId, UserName, Repository.id);
            Repository.StarCount++;
            hasStarred = true;
        }
    }

    private async Task ShowForkDialog()
    {
        var profile = await ProfileService.GetProfileAsync(UserId, AccountId);
        userHandle = profile?.Handle;
        forkOwner = userHandle ?? "";
        forkError = null;
        try
        {
            if (forkOrgs.Count == 0)
                forkOrgs = await OrgService.ListAsync(AccountId);
        }
        catch { }
        showForkConfirm = true;
    }

    private async Task ForkRepo()
    {
        if (Repository == null) return;
        forking = true;
        forkError = null;
        try
        {
            var ownerName = forkOwner;
            var ownerId = UserId;

            var org = forkOrgs.FirstOrDefault(o => o.Slug == forkOwner);
            if (org != null)
            {
                ownerName = org.Slug;
                ownerId = org.id;
            }

            var fork = await RepoService.ForkRepositoryAsync(AccountId, ownerId, ownerName, Repository);
            showForkConfirm = false;
            Nav.NavigateTo($"/{fork.OwnerName}/{fork.Slug}");
        }
        catch (Exception ex)
        {
            forkError = ex.Message;
        }
        finally
        {
            forking = false;
        }
    }

    private static string Slugify(string name)
    {
        return System.Text.RegularExpressions.Regex.Replace(
            name.ToLowerInvariant().Trim(), @"[^a-z0-9\-]", "-").Trim('-');
    }
}
