@page "/{Owner}/{RepoSlug}/workflows/new"
@page "/{Owner}/{RepoSlug}/workflows/edit/{WorkflowId}"
@inject WorkflowService WorkflowService
@inject RepositoryService RepoService
@inject SecretService SecretService
@inject BrowseService BrowseService
@inject DaisinetModelCatalog DaisinetCatalog
@inject NavigationManager Nav

<PageTitle>@(isNew ? "New Workflow" : "Edit Workflow") - @Owner/@RepoSlug - Daisi Git</PageTitle>

<RepositoryLayout Owner="@Owner" RepoSlug="@RepoSlug" ActiveTab="workflows">
    @if (loading)
    {
        <div class="text-center py-4"><div class="spinner-border spinner-border-sm text-primary"></div></div>
    }
    else
    {
        <!-- Header -->
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h5 class="mb-0">@(isNew ? "New Workflow" : "Edit Workflow")</h5>
            <div class="d-flex gap-2">
                @if (!isNew)
                {
                    <button class="btn btn-sm btn-outline-success" @onclick="RunNow" disabled="@runningNow">
                        @if (runningNow) { <span class="spinner-border spinner-border-sm me-1"></span> }
                        <i class="fa-duotone fa-play me-1"></i> Run Now
                    </button>
                }
                <a href="/@Owner/@RepoSlug/workflows" class="btn btn-sm btn-outline-secondary">Cancel</a>
                <button class="btn btn-sm btn-primary" @onclick="Save" disabled="@saving">
                    @if (saving) { <span class="spinner-border spinner-border-sm me-1"></span> }
                    @(isNew ? "Create" : "Save")
                </button>
            </div>
        </div>

        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="alert alert-danger alert-dismissible">@errorMessage</div>
        }

        <!-- Workflow metadata -->
        <div class="card mb-3">
            <div class="card-body">
                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label">Name</label>
                        <input type="text" class="form-control" @bind="workflow.Name" placeholder="My workflow" />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Trigger</label>
                        <select class="form-select" @bind="triggerTypeStr">
                            <option value="PushToRef">Push to branch</option>
                            <option value="BranchCreated">Branch created</option>
                            <option value="BranchDeleted">Branch deleted</option>
                            <option value="TagCreated">Tag created</option>
                            <option value="PullRequestCreated">Pull request opened</option>
                            <option value="PullRequestClosed">Pull request closed</option>
                            <option value="PullRequestMerged">Pull request merged</option>
                            <option value="IssueCreated">Issue opened</option>
                            <option value="IssueClosed">Issue closed</option>
                            <option value="IssueReopened">Issue reopened</option>
                            <option value="CommentCreated">Comment created</option>
                            <option value="ReviewSubmitted">Review submitted</option>
                            <option value="RepositoryForked">Repository forked</option>
                            <option value="Scheduled">Scheduled (timer)</option>
                        </select>
                    </div>
                    <div class="col-md-2 d-flex align-items-end">
                        <div class="form-check form-switch">
                            <input class="form-check-input" type="checkbox" @bind="workflow.IsEnabled" id="wfEnabled" />
                            <label class="form-check-label" for="wfEnabled">Enabled</label>
                        </div>
                    </div>
                </div>

                @if (ShowsBranchFilter)
                {
                    <div class="row g-3 mt-1">
                        <div class="col-md-6">
                            <label class="form-label">@BranchFilterLabel <span class="text-muted">(optional)</span> <Tip Text="@BranchFilterTip" /></label>
                            <MudAutocomplete T="string" @bind-Value="branchFilterInput"
                                             SearchFunc="SearchCurrentRepoBranches"
                                             Placeholder="Type to search branches..."
                                             Variant="MudBlazor.Variant.Outlined" Margin="MudBlazor.Margin.Dense"
                                             CoerceValue="true" />
                            @if (branchFilterList.Count > 0)
                            {
                                <div class="d-flex flex-wrap gap-1 mt-2">
                                    @foreach (var b in branchFilterList)
                                    {
                                        <span class="badge bg-primary d-flex align-items-center gap-1">
                                            @b
                                            <button type="button" class="btn-close btn-close-white" style="font-size: 0.5rem;"
                                                    @onclick="() => RemoveBranchFilter(b)"></button>
                                        </span>
                                    }
                                </div>
                            }
                        </div>
                    </div>
                }

                @if (IsScheduledTrigger)
                {
                    <div class="row g-3 mt-1">
                        <div class="col-md-6">
                            <label class="form-label">Schedule <Tip Text="Pick a preset or type a custom expression. Custom examples: 'every 5m', 'daily at 14:30', or a cron expression like '0 9 * * 1-5'." /></label>
                            <div class="input-group">
                                <input type="text" class="form-control" @bind="scheduleExpression" @bind:after="OnScheduleChanged"
                                       placeholder="e.g. every 30m, daily at 09:00, */15 * * * *" />
                                <button class="btn btn-outline-secondary dropdown-toggle" type="button" data-bs-toggle="dropdown" aria-expanded="false">Presets</button>
                                <ul class="dropdown-menu dropdown-menu-end">
                                    <li><button class="dropdown-item" type="button" @onclick='() => SetSchedulePreset("every 1m")'>Every minute</button></li>
                                    <li><button class="dropdown-item" type="button" @onclick='() => SetSchedulePreset("every 5m")'>Every 5 minutes</button></li>
                                    <li><button class="dropdown-item" type="button" @onclick='() => SetSchedulePreset("every 15m")'>Every 15 minutes</button></li>
                                    <li><button class="dropdown-item" type="button" @onclick='() => SetSchedulePreset("every 30m")'>Every 30 minutes</button></li>
                                    <li><hr class="dropdown-divider" /></li>
                                    <li><button class="dropdown-item" type="button" @onclick='() => SetSchedulePreset("hourly")'>Hourly</button></li>
                                    <li><button class="dropdown-item" type="button" @onclick='() => SetSchedulePreset("every 6h")'>Every 6 hours</button></li>
                                    <li><button class="dropdown-item" type="button" @onclick='() => SetSchedulePreset("every 12h")'>Every 12 hours</button></li>
                                    <li><hr class="dropdown-divider" /></li>
                                    <li><button class="dropdown-item" type="button" @onclick='() => SetSchedulePreset("daily at 08:00")'>Daily at 08:00 UTC</button></li>
                                    <li><button class="dropdown-item" type="button" @onclick='() => SetSchedulePreset("daily at 00:00")'>Daily at midnight UTC</button></li>
                                    <li><hr class="dropdown-divider" /></li>
                                    <li><button class="dropdown-item" type="button" @onclick='() => SetSchedulePreset("0 9 * * 1-5")'>Weekdays at 09:00 UTC</button></li>
                                    <li><button class="dropdown-item" type="button" @onclick='() => SetSchedulePreset("0 0 * * 0")'>Weekly (Sunday midnight)</button></li>
                                </ul>
                            </div>
                            @if (!string.IsNullOrEmpty(scheduleError))
                            {
                                <div class="text-danger small mt-1">@scheduleError</div>
                            }
                            else if (!string.IsNullOrEmpty(scheduleExpression))
                            {
                                <div class="text-muted small mt-1">@CronScheduleService.Describe(scheduleExpression)</div>
                            }
                        </div>
                    </div>
                }

                <div class="row g-3 mt-1">
                    <div class="col-md-6">
                        <label class="form-label">Description <span class="text-muted">(optional)</span></label>
                        <input type="text" class="form-control" @bind="workflow.Description" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Runtime <Tip Text="Container environment for script execution. Minimal has basic tools only. Select a language runtime or Full for all runtimes. You can also install additional tools via RunScript on any image." /></label>
                        <select class="form-select" @bind="runtimeStr">
                            <option value="Minimal">Minimal (git, curl, jq)</option>
                            <option value="DotNet">.NET 10 SDK</option>
                            <option value="Node">Node.js 22 LTS</option>
                            <option value="Python">Python 3</option>
                            <option value="Full">Full (all runtimes)</option>
                        </select>
                    </div>
                </div>
            </div>
        </div>

        @if (yamlMode)
        {
            <!-- YAML editor -->
            <div class="card">
                <div class="card-body" style="position: relative;">
                    <button class="btn btn-sm btn-outline-primary wf-mode-toggle"
                            @onclick="ToggleYamlMode">
                        <i class="fa-duotone fa-drafting-compass me-1"></i> Visual
                    </button>
                    @if (!string.IsNullOrEmpty(yamlError))
                    {
                        <div class="alert alert-danger py-2 mb-2">@yamlError</div>
                    }
                    <textarea class="form-control font-monospace" rows="24" @bind="yamlContent"
                              spellcheck="false" style="tab-size: 2; resize: vertical;"></textarea>
                </div>
            </div>
        }
        else
        {
            <!-- Visual workflow designer -->
            <div class="card">
                <div class="card-body" style="position: relative;">
                    <button class="btn btn-sm btn-outline-secondary wf-mode-toggle"
                            @onclick="ToggleYamlMode">
                        <i class="fa-duotone fa-code me-1"></i> Advanced
                    </button>
                    <div class="wf-flow">
                        <!-- Trigger node -->
                        <div class="wf-node wf-node--trigger">
                            <i class="fa-duotone fa-bolt me-1"></i> @FormatTriggerShort(workflow.TriggerType)
                        </div>
                        <div class="wf-connector"></div>

                        <!-- Insert before first step -->
                        <div class="wf-insert">
                            <button class="btn btn-sm btn-outline-secondary wf-insert-btn" @onclick="() => InsertStep(0)">
                                <i class="fa-solid fa-plus"></i>
                            </button>
                        </div>

                        @for (var i = 0; i < workflow.Steps.Count; i++)
                        {
                            var idx = i;
                            var step = workflow.Steps[i];
                            <div class="wf-connector"></div>
                            <div class="wf-node wf-node--@step.StepType.ToString().ToLower() @(selectedStepIndex == idx ? "wf-node--selected" : "")"
                                 @onclick="() => SelectStep(idx)">
                                <div class="wf-node-icon">@StepIcon(step.StepType)</div>
                                <div class="wf-node-label">
                                    @if (!string.IsNullOrEmpty(step.Name))
                                    {
                                        @step.Name
                                    }
                                    else
                                    {
                                        @FormatStepType(step.StepType)
                                    }
                                </div>
                                <button class="wf-node-delete btn btn-sm" @onclick="() => RemoveStep(idx)" @onclick:stopPropagation="true">
                                    <i class="fa-solid fa-xmark"></i>
                                </button>
                                <button class="wf-node-output btn btn-sm" @onclick="() => ToggleOutputPopover(idx)" @onclick:stopPropagation="true"
                                        title="Output fields">
                                    <i class="fa-duotone fa-arrow-right-from-bracket"></i>
                                </button>
                                @if (outputPopoverIndex == idx)
                                {
                                    <div class="wf-output-popover" @onclick:stopPropagation="true">
                                        <div class="wf-output-popover-header">
                                            <span class="fw-semibold small">Output fields</span>
                                            <button class="btn-close" style="font-size: 0.5rem;" @onclick="() => outputPopoverIndex = -1"></button>
                                        </div>
                                        <div class="wf-output-popover-body">
                                            @foreach (var field in GetOutputFields(step, idx))
                                            {
                                                <code class="wf-output-field">@field</code>
                                            }
                                        </div>
                                    </div>
                                }
                            </div>

                            <div class="wf-insert">
                                <button class="btn btn-sm btn-outline-secondary wf-insert-btn" @onclick="() => InsertStep(idx + 1)">
                                    <i class="fa-solid fa-plus"></i>
                                </button>
                            </div>
                        }

                        <div class="wf-connector"></div>
                        <!-- End node -->
                        <div class="wf-node wf-node--end">
                            <i class="fa-duotone fa-flag-checkered me-1"></i> End
                        </div>
                    </div>
                </div>
            </div>
        }

        <!-- Add step dialog -->
        @if (showAddStepMenu)
        {
            <div class="modal d-block" tabindex="-1" style="background: rgba(0,0,0,0.4);" @onclick="() => showAddStepMenu = false">
                <div class="modal-dialog modal-dialog-centered modal-lg" @onclick:stopPropagation="true">
                    <div class="modal-content">
                        <div class="modal-header">
                            <h5 class="modal-title"><i class="fa-duotone fa-plus-circle me-1"></i> Add a step</h5>
                            <button type="button" class="btn-close" @onclick="() => showAddStepMenu = false"></button>
                        </div>
                        <div class="modal-body d-flex flex-column" style="max-height: 70vh; overflow: hidden;">
                            <input type="text" class="form-control mb-3 flex-shrink-0" placeholder="Search steps..."
                                   @bind="stepSearchQuery" @bind:event="oninput" />

                            <!-- Group filter bar -->
                            <div class="wf-group-bar mb-3 flex-shrink-0">
                                <button class="wf-group-btn @(selectedGroup == null ? "wf-group-btn--active" : "")"
                                        @onclick="() => selectedGroup = null">
                                    <i class="fa-duotone fa-grid-2 wf-group-btn-icon"></i>
                                    <span class="wf-group-btn-label">All</span>
                                </button>
                                @foreach (var group in AvailableGroups)
                                {
                                    <button class="wf-group-btn @(selectedGroup == group.GroupName ? "wf-group-btn--active" : "")"
                                            @onclick="() => selectedGroup = group.GroupName">
                                        <i class="@group.Icon wf-group-btn-icon" style="color: @group.Color;"></i>
                                        <span class="wf-group-btn-label">@group.ShortName</span>
                                    </button>
                                }
                            </div>

                            <!-- Scrollable step list -->
                            <div class="flex-grow-1" style="overflow-y: auto; overflow-x: hidden;">
                                @foreach (var group in FilteredCatalog)
                                {
                                    <h6 class="text-muted mt-2 mb-2">@group.GroupName</h6>
                                    <div class="row g-2 mb-3">
                                        @foreach (var entry in group.Steps.Where(MatchesSearch))
                                        {
                                            <div class="col-md-6">
                                                <button class="btn btn-outline-secondary w-100 text-start wf-step-pick d-flex align-items-center"
                                                        @onclick="() => AddStep(entry.Type, entry.Name)">
                                                    <i class="@entry.Icon me-2 wf-step-pick-icon flex-shrink-0" style="color: @entry.Color;"></i>
                                                    <div class="min-width-0">
                                                        <div class="fw-semibold">@entry.Name</div>
                                                        <div class="text-muted small">@entry.Description</div>
                                                    </div>
                                                </button>
                                            </div>
                                        }
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }
    }
</RepositoryLayout>

<!-- Step editor aside -->
@if (selectedStepIndex >= 0 && selectedStepIndex < workflow.Steps.Count)
{
    var step = workflow.Steps[selectedStepIndex];
    var catalogEntry = StepCatalog.SelectMany(g => g.Steps).FirstOrDefault(e => e.Type == step.StepType);

    <div class="wf-aside-backdrop" @onclick="() => selectedStepIndex = -1"></div>
    <aside class="wf-aside">
        <div class="wf-aside-header">
            <div class="d-flex align-items-center gap-2">
                @if (catalogEntry != null)
                {
                    <i class="@catalogEntry.Icon" style="color: @catalogEntry.Color; font-size: 1.2rem;"></i>
                }
                <div>
                    <div class="fw-semibold">@FormatStepType(step.StepType)</div>
                    @if (catalogEntry != null)
                    {
                        <div class="text-muted small">@catalogEntry.Description</div>
                    }
                </div>
            </div>
            <button class="btn btn-sm btn-outline-secondary" @onclick="() => selectedStepIndex = -1">
                <i class="fa-solid fa-xmark"></i>
            </button>
        </div>

        <div class="wf-aside-body">
            <div class="mb-3">
                <label class="form-label">Step name <Tip Text="A display label shown on the workflow canvas. e.g. &quot;Notify Slack&quot;, &quot;Deploy staging&quot;" /></label>
                <input type="text" class="form-control" @bind="step.Name" placeholder="Optional label" />
            </div>

            @switch (step.StepType)
            {
                case WorkflowStepType.HttpRequest:
                    <div class="mb-3">
                        <label class="form-label">Method</label>
                        <select class="form-select" @bind="step.HttpMethod">
                            <option>GET</option>
                            <option>POST</option>
                            <option>PUT</option>
                            <option>PATCH</option>
                            <option>DELETE</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">URL</label>
                        <VarBtn InputId="wf-http-url" TriggerType="workflow.TriggerType" StepIndex="selectedStepIndex" Steps="workflow.Steps" Secrets="repoSecrets">
                            <input id="wf-http-url" type="text" class="form-control" @bind="step.HttpUrl" placeholder="https://hooks.example.com/webhook" />
                        </VarBtn>
                    </div>
                    @if (step.HttpMethod is "POST" or "PUT" or "PATCH")
                    {
                        <div class="mb-3">
                            <label class="form-label">Body</label>
                            <VarBtn InputId="wf-http-body" TriggerType="workflow.TriggerType" StepIndex="selectedStepIndex" Steps="workflow.Steps" Secrets="repoSecrets">
                                <textarea id="wf-http-body" class="form-control font-monospace" rows="4" @bind="step.HttpBody"
                                          placeholder='{"repo": "{{repo.name}}", "branch": "{{push.branch}}"}'></textarea>
                            </VarBtn>
                        </div>
                    }
                    break;

                case WorkflowStepType.AddComment:
                    <div class="mb-3">
                        <label class="form-label">Comment body</label>
                        <VarBtn InputId="wf-comment-body" TriggerType="workflow.TriggerType" StepIndex="selectedStepIndex" Steps="workflow.Steps" Secrets="repoSecrets">
                            <textarea id="wf-comment-body" class="form-control" rows="4" @bind="step.CommentBody"
                                      placeholder="Build triggered for {{push.branch}}"></textarea>
                        </VarBtn>
                    </div>
                    break;

                case WorkflowStepType.SetLabel:
                case WorkflowStepType.RemoveLabel:
                    <div class="mb-3">
                        <label class="form-label">Label name</label>
                        <VarBtn InputId="wf-label-name" TriggerType="workflow.TriggerType" StepIndex="selectedStepIndex" Steps="workflow.Steps" Secrets="repoSecrets">
                            <input id="wf-label-name" type="text" class="form-control" @bind="step.LabelName" placeholder="ready-to-merge" />
                        </VarBtn>
                    </div>
                    break;

                case WorkflowStepType.CloseIssue:
                    <div class="text-muted">Closes the issue that triggered this workflow. No configuration needed.</div>
                    break;

                case WorkflowStepType.ClosePullRequest:
                    <div class="text-muted">Closes the pull request that triggered this workflow. No configuration needed.</div>
                    break;

                case WorkflowStepType.RequireReview:
                    <div class="mb-3">
                        <label class="form-label">Required approvals <Tip Text="Number of approved reviews needed (1-10). Workflow fails this step if the PR has fewer approvals." /></label>
                        <input type="number" class="form-control" @bind="step.RequiredApprovals" min="1" max="10" />
                    </div>
                    break;

                case WorkflowStepType.Wait:
                    <div class="mb-3">
                        <label class="form-label">Days <Tip Text="Whole number of days to pause. The workflow resumes automatically after the total wait time elapses." /></label>
                        <input type="number" class="form-control" @bind="step.WaitDays" min="0" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Hours <Tip Text="0-23. Combined with days and minutes for total wait duration." /></label>
                        <input type="number" class="form-control" @bind="step.WaitHours" min="0" max="23" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Minutes <Tip Text="0-59. Minimum total wait is 1 minute if all fields are zero." /></label>
                        <input type="number" class="form-control" @bind="step.WaitMinutes" min="0" max="59" />
                    </div>
                    break;

                case WorkflowStepType.Checkout:
                    <div class="mb-3">
                        <label class="form-label">Repository <Tip Text="Select a DaisiGit repo, or type an external .git URL (https://github.com/org/repo.git). Leave empty for the repo that triggered this workflow." /></label>
                        <MudAutocomplete T="string" Value="step.CheckoutRepo"
                                         ValueChanged="@(v => { step.CheckoutRepo = v; OnCheckoutRepoChanged(step); })"
                                         SearchFunc="SearchRepos"
                                         Placeholder="owner/slug or https://...git URL"
                                         Variant="MudBlazor.Variant.Outlined" Margin="MudBlazor.Margin.Dense"
                                         Clearable="true" CoerceValue="true"
                                         ResetValueOnEmptyText="true" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Branch <Tip Text="Branch name to check out. Leave empty to use the branch from the trigger event. e.g. &quot;main&quot;, &quot;dev&quot;, &quot;{{push.branch}}&quot;" /></label>
                        @if (IsInternalRepo(step.CheckoutRepo))
                        {
                            <MudAutocomplete T="string" @bind-Value="step.CheckoutBranch"
                                             SearchFunc="@((v, ct) => SearchBranches(v, step.CheckoutRepo, ct))"
                                             Placeholder="Leave empty for trigger branch"
                                             Variant="MudBlazor.Variant.Outlined" Margin="MudBlazor.Margin.Dense"
                                             Clearable="true" CoerceValue="true"
                                             ResetValueOnEmptyText="true" />
                        }
                        else
                        {
                            <input type="text" class="form-control" @bind="step.CheckoutBranch" placeholder="Leave empty for trigger branch" />
                        }
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Path in workspace <Tip Text="Subdirectory within the workspace to place the files. Use this when checking out multiple repos. e.g. &quot;sdk&quot;, &quot;src/deps/my-lib&quot;. Leave empty for workspace root." /></label>
                        <input type="text" class="form-control" @bind="step.CheckoutPath" placeholder="Leave empty for workspace root" />
                    </div>
                    break;

                case WorkflowStepType.ImportFromUrl:
                    <div class="mb-3">
                        <label class="form-label">Git URL <Tip Text="The public git clone URL to import from. All objects and refs will be pulled into this repository. Supports merge fields like {{secrets.REPO_URL}}." /></label>
                        <VarBtn InputId="wf-import-url" TriggerType="workflow.TriggerType" StepIndex="selectedStepIndex" Steps="workflow.Steps" Secrets="repoSecrets">
                            <input id="wf-import-url" type="text" class="form-control" @bind="step.ImportUrl"
                                   placeholder="https://github.com/owner/repo.git" />
                        </VarBtn>
                    </div>
                    break;

                case WorkflowStepType.RunMinion:
                    <div class="alert alert-info small">
                        <i class="fa-duotone fa-robot me-1"></i>
                        Runs <code>daisi-minion</code> in the workspace, powered by daisinet. Requires runtime <code>dotnet</code> or <code>full</code>.
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Instructions source</label>
                        <div class="btn-group w-100" role="group">
                            <input type="radio" class="btn-check" id="minion-inline" name="minion-src"
                                   checked="@(!minionUseFile)"
                                   @onchange="@(() => { minionUseFile = false; step.MinionInstructionsFile = null; })" />
                            <label class="btn btn-outline-secondary" for="minion-inline">Inline prompt</label>

                            <input type="radio" class="btn-check" id="minion-file" name="minion-src"
                                   checked="@minionUseFile"
                                   @onchange="@(() => { minionUseFile = true; step.MinionInstructions = null; })" />
                            <label class="btn btn-outline-secondary" for="minion-file">File in repo</label>
                        </div>
                    </div>
                    @if (minionUseFile)
                    {
                        <div class="mb-3">
                            <label class="form-label">Instructions file <Tip Text="Workspace-relative path to a file whose contents become the minion's goal. e.g. &quot;.minion/doc-task.md&quot;" /></label>
                            <input type="text" class="form-control" @bind="step.MinionInstructionsFile"
                                   placeholder=".minion/doc-task.md" />
                        </div>
                    }
                    else
                    {
                        <div class="mb-3">
                            <label class="form-label">Instructions</label>
                            <VarBtn InputId="wf-minion-instr" TriggerType="workflow.TriggerType" StepIndex="selectedStepIndex" Steps="workflow.Steps" Secrets="repoSecrets">
                                <textarea id="wf-minion-instr" class="form-control" rows="4" @bind="step.MinionInstructions"
                                          placeholder="Analyze the repo and print a summary."></textarea>
                            </VarBtn>
                        </div>
                    }
                    <div class="mb-3">
                        <label class="form-label">Model <Tip Text="Daisinet model name. Leave empty to use the ORC's default text-generation model." /></label>
                        @if (daisinetModelsError != null)
                        {
                            <input type="text" class="form-control" @bind="step.MinionModel" placeholder="Qwen 3.5" />
                            <div class="form-text text-warning">@daisinetModelsError</div>
                        }
                        else if (daisinetModels == null)
                        {
                            <div class="form-text"><i class="fa-duotone fa-spinner fa-spin me-1"></i>Loading models from ORC…</div>
                        }
                        else
                        {
                            <select class="form-select" @bind="step.MinionModel">
                                <option value="">-- ORC default text-gen model --</option>
                                @foreach (var m in daisinetModels)
                                {
                                    <option value="@m.Name">@m.Name @(m.IsDefault ? "(default)" : "") @(m.HasReasoning ? "[reasoning]" : "")</option>
                                }
                            </select>
                        }
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Working directory <Tip Text="Workspace-relative subdir the minion runs in. Leave empty for workspace root." /></label>
                        <input type="text" class="form-control" @bind="step.MinionWorkingDirectory"
                               placeholder="Leave empty for workspace root" />
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Role <Tip Text="coder, cto, chat, team-lead, etc." /></label>
                            <input type="text" class="form-control" @bind="step.MinionRole" placeholder="coder" />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Max iterations <Tip Text="Goal-loop cap. Default 20." /></label>
                            <input type="number" class="form-control" @bind="step.MinionMaxIterations" min="1" max="100" placeholder="20" />
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-4 mb-3">
                            <label class="form-label">Context size</label>
                            <input type="number" class="form-control" @bind="step.MinionContextSize" min="512" placeholder="default" />
                        </div>
                        <div class="col-md-4 mb-3">
                            <label class="form-label">Max tokens</label>
                            <input type="number" class="form-control" @bind="step.MinionMaxTokens" min="64" placeholder="default" />
                        </div>
                        <div class="col-md-4 mb-3">
                            <label class="form-label">Timeout (s) <Tip Text="Default 1500. Hard-capped at 1800 (30m container limit)." /></label>
                            <input type="number" class="form-control" @bind="step.MinionTimeoutSeconds" min="30" max="1800" placeholder="1500" />
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">ORC address <Tip Text="Override host:port. Leave empty to use the SDK default." /></label>
                        <input type="text" class="form-control" @bind="step.MinionOrcAddress" placeholder="orc.daisinet.com:443" />
                    </div>
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" id="wf-minion-json"
                               checked="@(step.MinionJsonOutput == true)"
                               @onchange="@((ChangeEventArgs e) => step.MinionJsonOutput = (bool?)e.Value)" />
                        <label class="form-check-label" for="wf-minion-json">
                            JSON event output <Tip Text="Emits structured JSON events on stderr. Useful for parsing minion progress in downstream steps." />
                        </label>
                    </div>
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" id="wf-minion-grammar"
                               checked="@(step.MinionGrammar == true)"
                               @onchange="@((ChangeEventArgs e) => step.MinionGrammar = (bool?)e.Value)" />
                        <label class="form-check-label" for="wf-minion-grammar">
                            GBNF grammar-constrained tool calls <Tip Text="Forces valid JSON tool calls. Slower, but eliminates malformed calls." />
                        </label>
                    </div>
                    break;

                case WorkflowStepType.RunScript:
                    <div class="mb-3">
                        <label class="form-label">Command</label>
                        <VarBtn InputId="wf-script-cmd" TriggerType="workflow.TriggerType" StepIndex="selectedStepIndex" Steps="workflow.Steps" Secrets="repoSecrets">
                            <textarea id="wf-script-cmd" class="form-control font-monospace" rows="3" @bind="step.ScriptCommand"
                                      placeholder="dotnet publish -c Release -o publish"></textarea>
                        </VarBtn>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Working directory <Tip Text="Directory relative to the workspace root. e.g. &quot;src/web&quot; to run the command inside that folder. Leave empty for workspace root." /></label>
                        <input type="text" class="form-control" @bind="step.ScriptWorkDir" placeholder="Leave empty for workspace root" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Timeout (seconds) <Tip Text="Max seconds before the process is killed. Default 300 (5 min), max 1800 (30 min). Long builds like dotnet publish may need 600+." /></label>
                        <input type="number" class="form-control" @bind="step.ScriptTimeoutSeconds" min="10" max="1800" placeholder="300" />
                    </div>
                    break;

                case WorkflowStepType.DeployAzureWebApp:
                    <div class="mb-3">
                        <label class="form-label">Azure App Name</label>
                        <VarBtn InputId="wf-azure-app" TriggerType="workflow.TriggerType" StepIndex="selectedStepIndex" Steps="workflow.Steps" Secrets="repoSecrets">
                            <input id="wf-azure-app" type="text" class="form-control" @bind="step.AzureAppName" placeholder="my-web-app" />
                        </VarBtn>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Working directory <Tip Text="Base directory in the workspace. Use this when your build runs in a subdirectory. e.g. &quot;src/web&quot;. Deploy path is resolved relative to this. Leave empty for workspace root." /></label>
                        <input type="text" class="form-control" @bind="step.AzureWorkDir" placeholder="Leave empty for workspace root" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Deploy path <Tip Text="Subdirectory to zip and deploy, relative to working directory. e.g. &quot;publish&quot; or &quot;dist&quot;. Leave empty to deploy the entire working directory." /></label>
                        <input type="text" class="form-control" @bind="step.AzureDeployPath" placeholder="publish" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Username secret <Tip Text="Select the secret containing the deployment username. This is the $ username from your Azure publish profile (Azure Portal > App Service > Deployment Center > Manage publish profile)." /></label>
                        @if (repoSecrets.Count > 0)
                        {
                            <select class="form-select" @bind="step.AzureUsernameSecret">
                                <option value="">-- select a secret --</option>
                                @foreach (var s in repoSecrets)
                                {
                                    <option value="@s">@s</option>
                                }
                            </select>
                        }
                        else
                        {
                            <input type="text" class="form-control" @bind="step.AzureUsernameSecret" placeholder="AZURE_DEPLOY_USERNAME" />
                        }
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Password secret <Tip Text="Select the secret containing the deployment password from your Azure publish profile." /></label>
                        @if (repoSecrets.Count > 0)
                        {
                            <select class="form-select" @bind="step.AzurePasswordSecret">
                                <option value="">-- select a secret --</option>
                                @foreach (var s in repoSecrets)
                                {
                                    <option value="@s">@s</option>
                                }
                            </select>
                        }
                        else
                        {
                            <input type="text" class="form-control" @bind="step.AzurePasswordSecret" placeholder="AZURE_DEPLOY_PASSWORD" />
                        }
                    </div>
                    @if (repoSecrets.Count == 0)
                    {
                        <div class="alert alert-warning mb-0">
                            <i class="fa-duotone fa-key me-1"></i>
                            No secrets found. <a href="/@Owner/@RepoSlug/settings">Add secrets</a> for your Azure publish profile credentials first.
                        </div>
                    }
                    break;

                case WorkflowStepType.SendEmail:
                    <div class="mb-3">
                        <label class="form-label">To</label>
                        <VarBtn InputId="wf-email-to" TriggerType="workflow.TriggerType" StepIndex="selectedStepIndex" Steps="workflow.Steps" Secrets="repoSecrets">
                            <input id="wf-email-to" type="text" class="form-control" @bind="step.EmailTo" placeholder="user@example.com" />
                        </VarBtn>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Subject</label>
                        <VarBtn InputId="wf-email-subject" TriggerType="workflow.TriggerType" StepIndex="selectedStepIndex" Steps="workflow.Steps" Secrets="repoSecrets">
                            <input id="wf-email-subject" type="text" class="form-control" @bind="step.EmailSubject" placeholder="Build completed for {{repo.name}}" />
                        </VarBtn>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Body</label>
                        <VarBtn InputId="wf-email-body" TriggerType="workflow.TriggerType" StepIndex="selectedStepIndex" Steps="workflow.Steps" Secrets="repoSecrets">
                            <textarea id="wf-email-body" class="form-control" rows="5" @bind="step.EmailBody"
                                      placeholder="Build for {{repo.name}} on branch {{push.branch}} completed successfully."></textarea>
                        </VarBtn>
                    </div>
                    <div class="text-muted small">
                        <i class="fa-duotone fa-envelope-circle-check me-1"></i>
                        Emails are sent from Daisi Git (<code>noreply@git.daisi.ai</code>).
                    </div>
                    break;
            }
        </div>
    </aside>
}

<style>
    .wf-flow {
        display: flex;
        flex-direction: column;
        align-items: center;
        padding: 1rem 0;
    }
    .wf-connector {
        width: 2px;
        height: 20px;
        background: var(--bs-border-color);
    }
    .wf-node {
        position: relative;
        display: flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.5rem 1.25rem;
        border: 2px solid var(--bs-border-color);
        border-radius: 8px;
        background: var(--bs-body-bg);
        cursor: pointer;
        min-width: 180px;
        justify-content: center;
        transition: border-color 0.15s, box-shadow 0.15s;
    }
    .wf-node:hover { border-color: var(--bs-primary); }
    .wf-node--selected { border-color: var(--bs-primary); box-shadow: 0 0 0 3px rgba(var(--bs-primary-rgb), 0.15); }
    .wf-node--trigger { background: var(--bs-success-bg-subtle); border-color: var(--bs-success); color: var(--bs-success); border-radius: 20px; cursor: default; }
    .wf-node--end { background: var(--bs-secondary-bg); border-color: var(--bs-secondary); color: var(--bs-secondary); border-radius: 20px; cursor: default; }
    .wf-node--httprequest { border-left: 4px solid #fd7e14; }
    .wf-node--addcomment { border-left: 4px solid #0d6efd; }
    .wf-node--setlabel, .wf-node--removelabel { border-left: 4px solid #6f42c1; }
    .wf-node--closeissue, .wf-node--closepullrequest { border-left: 4px solid #dc3545; }
    .wf-node--requirereview { border-left: 4px solid #198754; }
    .wf-node--wait { border-left: 4px solid #6c757d; }
    .wf-node--deployazurewebapp { border-left: 4px solid #0078d4; }
    .wf-node--checkout { border-left: 4px solid #0d6efd; }
    .wf-node--runscript { border-left: 4px solid #212529; }
    .wf-node--sendemail { border-left: 4px solid #20c997; }
    .wf-node-delete {
        position: absolute;
        top: -8px;
        right: -8px;
        width: 22px;
        height: 22px;
        padding: 0;
        border-radius: 50%;
        background: var(--bs-danger);
        color: white;
        font-size: 0.7rem;
        display: none;
        align-items: center;
        justify-content: center;
    }
    .wf-node:hover .wf-node-delete { display: flex; }
    .wf-node-delete:hover { background: var(--bs-danger) !important; color: white !important; border-color: var(--bs-danger) !important; opacity: 0.85; }
    .wf-node-output {
        position: absolute; bottom: -8px; right: -8px;
        width: 22px; height: 22px; padding: 0; border-radius: 50%;
        background: var(--bs-info); color: white; font-size: 0.6rem;
        display: none; align-items: center; justify-content: center;
    }
    .wf-node:hover .wf-node-output { display: flex; }
    .wf-node-output:hover { background: var(--bs-info) !important; color: white !important; border-color: var(--bs-info) !important; opacity: 0.85; }
    .wf-output-popover {
        position: absolute; top: calc(100% + 12px); right: -8px; z-index: 1060;
        background: var(--bs-body-bg); border: 1px solid var(--bs-border-color);
        border-radius: 8px; box-shadow: 0 4px 16px rgba(0,0,0,0.15);
        min-width: 260px; max-width: 340px;
    }
    .wf-output-popover-header {
        display: flex; justify-content: space-between; align-items: center;
        padding: 0.5rem 0.75rem; border-bottom: 1px solid var(--bs-border-color);
    }
    .wf-output-popover-body {
        padding: 0.5rem 0.75rem; display: flex; flex-direction: column; gap: 0.25rem;
    }
    .wf-output-field {
        display: block; padding: 0.2rem 0.4rem; border-radius: 4px;
        background: var(--bs-tertiary-bg); font-size: 0.75rem;
        word-break: break-all; cursor: default;
    }
    .wf-insert { padding: 4px 0; }
    .wf-insert-btn {
        width: 24px;
        height: 24px;
        padding: 0;
        border-radius: 50%;
        font-size: 0.65rem;
        opacity: 0.4;
        transition: opacity 0.15s;
    }
    .wf-insert-btn:hover { opacity: 1; }
    .wf-node-icon { font-size: 1rem; }
    .wf-node-label { font-size: 0.85rem; font-weight: 500; }
    .wf-step-pick { padding: 0.6rem 0.75rem; border-radius: 8px; transition: border-color 0.15s, background 0.15s; justify-content: flex-start; }
    .wf-step-pick:hover { background: var(--bs-primary-bg-subtle); border-color: var(--bs-primary); }
    .wf-step-pick-icon { font-size: 1.2rem; width: 1.5rem; text-align: center; flex-shrink: 0; }

    .wf-aside-backdrop {
        position: fixed; inset: 0; background: rgba(0,0,0,0.25); z-index: 1040;
    }
    .wf-aside {
        position: fixed; top: 0; right: 0; bottom: 0;
        width: min(420px, 90vw); z-index: 1050;
        background: var(--bs-body-bg);
        border-left: 1px solid var(--bs-border-color);
        box-shadow: -4px 0 24px rgba(0,0,0,0.1);
        display: flex; flex-direction: column;
        animation: wf-slide-in 0.15s ease-out;
    }
    @@keyframes wf-slide-in { from { transform: translateX(100%); } to { transform: translateX(0); } }
    .wf-aside-header {
        display: flex; justify-content: space-between; align-items: flex-start;
        padding: 1rem 1.25rem; border-bottom: 1px solid var(--bs-border-color);
    }
    .wf-aside-body { padding: 1.25rem; overflow-y: auto; flex: 1; }

    .wf-mode-toggle { position: absolute; top: 0.5rem; right: 0.75rem; z-index: 10; background: var(--bs-body-bg); }

    .wf-tip { cursor: help; margin-left: 4px; color: var(--bs-secondary); font-size: 0.8rem; vertical-align: middle; }
    .wf-tip:hover { color: var(--bs-primary); }

    .wf-group-bar {
        display: flex; gap: 0.5rem; overflow-x: auto; padding-bottom: 4px;
        scrollbar-width: thin;
    }
    .wf-group-btn {
        display: flex; flex-direction: column; align-items: center; gap: 0.25rem;
        padding: 0.5rem 0.75rem; border: 2px solid var(--bs-border-color); border-radius: 10px;
        background: var(--bs-body-bg); cursor: pointer; flex-shrink: 0;
        transition: border-color 0.15s, background 0.15s;
        min-width: 72px;
    }
    .wf-group-btn:hover { border-color: var(--bs-primary); background: var(--bs-primary-bg-subtle); }
    .wf-group-btn--active { border-color: var(--bs-primary); background: var(--bs-primary-bg-subtle); }
    .wf-group-btn-icon { font-size: 1.25rem; }
    .wf-group-btn-label { font-size: 0.7rem; font-weight: 600; white-space: nowrap; }
</style>

@code {
    [Parameter] public string Owner { get; set; } = "";
    [Parameter] public string RepoSlug { get; set; } = "";
    [Parameter] public string? WorkflowId { get; set; }
    [CascadingParameter(Name = "AccountId")] string AccountId { get; set; } = "";
    [CascadingParameter(Name = "UserId")] string UserId { get; set; } = "";
    [CascadingParameter(Name = "UserName")] string UserName { get; set; } = "";

    private GitWorkflow workflow = new();
    private GitRepository? repo;
    private bool isNew => string.IsNullOrEmpty(WorkflowId);
    private bool loading = true;
    private bool saving;
    private bool runningNow;
    private bool yamlMode;
    private string yamlContent = "";
    private string? yamlError;
    private int outputPopoverIndex = -1;
    private string? errorMessage;
    private int selectedStepIndex = -1;
    private bool showAddStepMenu;
    private int insertAtIndex;
    private List<string> branchFilterList = [];
    private string? _branchFilterInput;
    private string? branchFilterInput
    {
        get => _branchFilterInput;
        set
        {
            _branchFilterInput = value;
            if (!string.IsNullOrWhiteSpace(value) && !branchFilterList.Contains(value))
            {
                branchFilterList.Add(value);
                _branchFilterInput = null;
            }
        }
    }
    private List<string> currentRepoBranches = [];
    private List<string> repoSecrets = [];
    private List<GitRepository> accountRepos = [];
    private Dictionary<string, List<string>> branchCache = new();
    private string stepSearchQuery = "";

    // Run-minion editor state
    private IReadOnlyList<DaisinetModelInfo>? daisinetModels;
    private string? daisinetModelsError;
    private bool minionUseFile;
    private bool minionModelsRequested;

    private string triggerTypeStr
    {
        get => workflow.TriggerType.ToString();
        set { if (Enum.TryParse<GitTriggerType>(value, out var t)) workflow.TriggerType = t; }
    }

    private string runtimeStr
    {
        get => workflow.Runtime.ToString();
        set { if (Enum.TryParse<WorkflowRuntime>(value, out var r)) workflow.Runtime = r; }
    }

    private bool IsPushTrigger => workflow.TriggerType is GitTriggerType.PushToRef
        or GitTriggerType.BranchCreated or GitTriggerType.BranchDeleted
        or GitTriggerType.TagCreated or GitTriggerType.TagDeleted;

    private bool IsPRTrigger => workflow.TriggerType is GitTriggerType.PullRequestCreated
        or GitTriggerType.PullRequestUpdated or GitTriggerType.PullRequestClosed
        or GitTriggerType.PullRequestMerged;

    // Push triggers filter on the pushed branch; PR triggers filter on the target branch.
    private bool ShowsBranchFilter => IsPushTrigger || IsPRTrigger;
    private string BranchFilterLabel => IsPRTrigger ? "Target branch filter" : "Branch filter";
    private string BranchFilterTip => IsPRTrigger
        ? "Only trigger when the PR's target (base) branch matches one of these. Leave empty to trigger for any target branch."
        : "Only trigger when pushed to these branches. Leave empty to trigger on all branches.";

    private bool IsScheduledTrigger => workflow.TriggerType == GitTriggerType.Scheduled;
    private string scheduleExpression = "";
    private string? scheduleError;

    private void SetSchedulePreset(string preset)
    {
        scheduleExpression = preset;
        OnScheduleChanged();
    }

    private void OnScheduleChanged()
    {
        scheduleError = CronScheduleService.Validate(scheduleExpression);
        workflow.TriggerFilters ??= new();
        workflow.TriggerFilters["schedule"] = scheduleExpression;
    }

    protected override async Task OnParametersSetAsync()
    {
        loading = true;
        try
        {
            repo = await RepoService.GetRepositoryBySlugAsync(Owner, RepoSlug);
            if (repo != null)
            {
                try { repoSecrets = await SecretService.ListSecretNamesAsync(repo.id); } catch { }
                try { accountRepos = await RepoService.GetRepositoriesAsync(repo.AccountId); } catch { }
                try
                {
                    var branches = await BrowseService.GetBranchesAsync(repo.id, repo.DefaultBranch);
                    currentRepoBranches = branches.Select(b => b.Name).ToList();
                }
                catch { }
            }
            if (!isNew && repo != null)
            {
                var wf = await WorkflowService.GetAsync(WorkflowId!, repo.AccountId);
                if (wf != null)
                {
                    workflow = wf;
                    var bf = wf.TriggerFilters?.GetValueOrDefault("branch", "") ?? "";
                    branchFilterList = bf.Split(',', StringSplitOptions.TrimEntries | StringSplitOptions.RemoveEmptyEntries).ToList();
                    scheduleExpression = wf.TriggerFilters?.GetValueOrDefault("schedule", "") ?? "";
                }
            }
            else
            {
                workflow = new GitWorkflow
                {
                    AccountId = repo?.AccountId ?? "",
                    RepositoryId = repo?.id
                };
            }
        }
        catch { }
        loading = false;
    }

    private void SelectStep(int index)
    {
        selectedStepIndex = index;
        showAddStepMenu = false;

        // Initialize run-minion file/inline toggle from the step's current state.
        if (index >= 0 && index < workflow.Steps.Count
            && workflow.Steps[index].StepType == WorkflowStepType.RunMinion)
        {
            minionUseFile = !string.IsNullOrEmpty(workflow.Steps[index].MinionInstructionsFile);
            _ = EnsureDaisinetModelsLoadedAsync();
        }
    }

    private async Task EnsureDaisinetModelsLoadedAsync()
    {
        if (minionModelsRequested) return;
        minionModelsRequested = true;
        try
        {
            daisinetModels = await DaisinetCatalog.GetTextGenModelsAsync(CancellationToken.None);
        }
        catch (Exception ex)
        {
            daisinetModelsError = ex.Message;
        }
        StateHasChanged();
    }

    private void InsertStep(int index)
    {
        insertAtIndex = index;
        showAddStepMenu = true;
        stepSearchQuery = "";
        selectedGroup = null;
        selectedStepIndex = -1;
    }

    private void AddStep(WorkflowStepType type, string name)
    {
        var step = new WorkflowStep
        {
            Order = insertAtIndex,
            Name = name,
            StepType = type,
            HttpMethod = type == WorkflowStepType.HttpRequest ? "POST" : null,
            RequiredApprovals = type == WorkflowStepType.RequireReview ? 1 : null
        };

        workflow.Steps.Insert(insertAtIndex, step);
        ReorderSteps();
        selectedStepIndex = insertAtIndex;
        showAddStepMenu = false;
    }

    private void RemoveStep(int index)
    {
        workflow.Steps.RemoveAt(index);
        ReorderSteps();
        if (selectedStepIndex == index) selectedStepIndex = -1;
        else if (selectedStepIndex > index) selectedStepIndex--;
    }

    private void ReorderSteps()
    {
        for (var i = 0; i < workflow.Steps.Count; i++)
            workflow.Steps[i].Order = i;
    }

    private async Task Save()
    {
        if (string.IsNullOrWhiteSpace(workflow.Name))
        {
            errorMessage = "Workflow name is required.";
            return;
        }

        saving = true;
        errorMessage = null;

        // If in YAML mode, parse back to visual before saving
        if (yamlMode)
        {
            if (!WorkflowYamlParser.TryParse(yamlContent, out var parseError, out var parsed))
            {
                errorMessage = parseError ?? "Invalid YAML.";
                saving = false;
                return;
            }
            workflow.Steps = parsed!.Steps;
        }

        // Build trigger filters
        workflow.TriggerFilters = new();
        if (branchFilterList.Count > 0)
            workflow.TriggerFilters["branch"] = string.Join(", ", branchFilterList);

        try
        {
            if (isNew)
            {
                workflow.AccountId = repo!.AccountId;
                workflow.RepositoryId = repo.id;
                await WorkflowService.CreateAsync(workflow);
            }
            else
            {
                await WorkflowService.UpdateAsync(workflow);
            }

            Nav.NavigateTo($"/{Owner}/{RepoSlug}/workflows");
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
        finally
        {
            saving = false;
        }
    }

    private void ToggleYamlMode()
    {
        yamlError = null;
        if (!yamlMode)
        {
            // Visual -> YAML: serialize current workflow to YAML
            yamlContent = WorkflowYamlParser.ToYaml(workflow);
            yamlMode = true;
            selectedStepIndex = -1;
        }
        else
        {
            // YAML -> Visual: parse YAML back into workflow steps
            if (!WorkflowYamlParser.TryParse(yamlContent, out var parseError, out var parsed))
            {
                yamlError = parseError ?? "Invalid YAML.";
                return;
            }
            workflow.Steps = parsed!.Steps;
            if (!string.IsNullOrEmpty(parsed.Name))
                workflow.Name = parsed.Name;
            if (parsed.Env is { Count: > 0 })
                workflow.Env = parsed.Env;
            yamlMode = false;
        }
    }

    private async Task RunNow()
    {
        if (repo == null || isNew) return;
        runningNow = true;
        errorMessage = null;
        try
        {
            await WorkflowService.RunNowAsync(workflow, repo, UserId, UserName);
            Nav.NavigateTo($"/{Owner}/{RepoSlug}/workflows/{workflow.id}/history");
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
        finally
        {
            runningNow = false;
        }
    }

