@inject UserProfileService ProfileService
@inject OrganizationService OrgService

@if (!string.IsNullOrEmpty(avatarUrl))
{
    <img src="@avatarUrl" alt="@OwnerName" class="rounded-circle"
         style="width: @(Size)px; height: @(Size)px; object-fit: cover;"
         @onerror="() => { avatarUrl = null; StateHasChanged(); }" />
}
else
{
    <div class="rounded-circle bg-secondary d-flex align-items-center justify-content-center text-white"
         style="width: @(Size)px; height: @(Size)px; font-size: @(Size * 0.45)px;">
        @(OwnerName?.Length > 0 ? OwnerName[0..1].ToUpperInvariant() : "?")
    </div>
}

@code {
    [Parameter] public string OwnerName { get; set; } = "";
    [Parameter] public int Size { get; set; } = 24;
    [CascadingParameter(Name = "AccountId")] string AccountId { get; set; } = "";

    private string? avatarUrl;
    private static readonly Dictionary<string, string?> _cache = new();

    protected override async Task OnParametersSetAsync()
    {
        if (string.IsNullOrEmpty(OwnerName)) return;

        if (_cache.TryGetValue(OwnerName, out var cached))
        {
            avatarUrl = cached;
            return;
        }

        try
        {
            // Try org first
            var org = await OrgService.GetBySlugAsync(OwnerName);
            if (org != null)
            {
                avatarUrl = !string.IsNullOrEmpty(org.AvatarUrl)
                    ? org.AvatarUrl
                    : $"/api/git/avatars/org/{org.id}";
                _cache[OwnerName] = avatarUrl;
                return;
            }

            // Try user profile by handle
            var profile = await ProfileService.GetByHandleAsync(OwnerName);
            if (profile != null)
            {
                avatarUrl = !string.IsNullOrEmpty(profile.AvatarUrl)
                    ? profile.AvatarUrl
                    : $"/api/git/avatars/user/{profile.UserId}";
                _cache[OwnerName] = avatarUrl;
                return;
            }
        }
        catch { }

        _cache[OwnerName] = null;
    }
}
